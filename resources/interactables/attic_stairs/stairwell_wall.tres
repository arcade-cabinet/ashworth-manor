[resource]
script = ExtResource("1")
object_id = "stairwell_wall"
object_type = "observation"
title = "Cracked Wall"
content = "Through the largest crack, you see bare wooden lath. And scratches on the wood. From the other side. Fingernail marks."
on_read_flags = PackedStringArray()
