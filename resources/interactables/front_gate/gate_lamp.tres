script = ExtResource("1")
object_id = "gate_lamp"
object_type = "observation"
title = "Gas Lamp"
content = "Still lit. After over a century, the gas lamp by the gate still burns. The flame doesn't flicker like fire — it pulses, like breathing."
on_read_flags = PackedStringArray()
