[gd_resource type="Resource" script_class="InteractableData" format=3]

[ext_resource type="Script" path="res://scripts/interactable_data.gd" id="1"]

[resource]
script = ExtResource("1")
object_id = "maintenance_log"
object_type = "note"
title = "Maintenance Log"
content = "Dec 15, 1891 — Strange sounds from the pipes again. The staff refuse to come down here after dark. Something is wrong with this house."
on_read_flags = PackedStringArray("read_maintenance_log", "knows_staff_afraid")
