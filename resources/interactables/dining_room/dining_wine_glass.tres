[resource]
script = ExtResource("1")
object_id = "dining_wine_glass"
object_type = "observation"
title = "Wine Glass"
content = "Dried residue clings to the inside. Not wine — too dark, too thick. Whatever was in this glass, it wasn't served at dinner."
on_read_flags = PackedStringArray("examined_wine_glass")
