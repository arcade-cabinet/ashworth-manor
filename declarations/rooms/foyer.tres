; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited_foyer"]
script = ExtResource("7")
set_state = {"visited_foyer": true}

[sub_resource type="Resource" id="act_show_foyer"]
script = ExtResource("7")
show_room_name = "Grand Foyer"

[sub_resource type="Resource" id="act_settling_sfx"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/distant_settling.ogg"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_foyer"
once = true
trigger_id = "foyer_first_entry"
actions = Array[Resource]([SubResource("act_visited_foyer"), SubResource("act_show_foyer"), SubResource("act_settling_sfx")])

; === Ambient Events ===

[sub_resource type="Resource" id="act_crystal_tinkle"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/crystal_tinkle.ogg"

[sub_resource type="Resource" id="ambient_chandelier"]
script = ExtResource("8")
event_id = "chandelier_tinkle"
interval_min = 30.0
interval_max = 60.0
condition = ""
actions = Array[Resource]([SubResource("act_crystal_tinkle")])

; === Flashback: Post-Truth ===

[sub_resource type="Resource" id="flashback_elizabeth"]
script = ExtResource("10")
flashback_id = "foyer_family_flashback"
condition = "knows_full_truth"
once = true
model = "res://assets/horror/models/bloodwraith.glb"
model_position = Vector3(0, 0, 0)
model_scale = 0.6
duration = 4.0
fade_amount = 0.8
stinger_sfx = "res://assets/audio/sfx/stinger/pl_horror_stinger_05_slow.wav"
camera_shake = 0.1

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "foyer"
room_name = "Grand Foyer"
floor_name = "ground_floor"
environment_preset = "ground_floor"
dimensions = Vector3(12, 4.8, 10)
is_exterior = false
wall_texture = "wall0_texture"
floor_texture = "floor0_texture"
ceiling_texture = "ceiling0_texture"
wall_north = PackedStringArray("wall", "wall", "doorway:foyer_to_parlor", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "window", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "doorway:foyer_to_dining_room", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "doorway:foyer_to_kitchen", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Moonlight Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_ground.wav"
reverb_bus = "Hall"
footstep_surface = "marble"
spawn_position = Vector3(0, 0, -3)
spawn_rotation_y = 0.0
interactables = Array[Resource]([SubResource("inter_painting"), SubResource("inter_mirror"), SubResource("inter_clock"), SubResource("inter_switch"), SubResource("inter_mail"), SubResource("inter_stairs")])
lights = Array[Resource]([SubResource("light_chandelier"), SubResource("light_sconce_w"), SubResource("light_sconce_e"), SubResource("light_window")])
props = Array[Resource]([SubResource("prop_chandelier"), SubResource("prop_rug"), SubResource("prop_drawers"), SubResource("prop_coat_stand"), SubResource("prop_package"), SubResource("prop_wall_map"), SubResource("prop_table_lamp"), SubResource("prop_pillar_l"), SubResource("prop_pillar_r"), SubResource("prop_stairs"), SubResource("prop_banister"), SubResource("prop_candle_w"), SubResource("prop_candle_e"), SubResource("prop_window_ray")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_chandelier")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([SubResource("flashback_elizabeth")])
