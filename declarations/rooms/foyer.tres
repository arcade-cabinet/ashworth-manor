[sub_resource type="Resource" id="light_table_east"]
script = ExtResource("4")
id = "foyer_table_lamp_east"
type = "omni"
position = Vector3(5, 1.5, -3)
color = Color(1.0, 0.78, 0.52, 1)
energy = 0.0
range = 3.0
shadows = false
flickering = false

; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited_foyer"]
script = ExtResource("7")
set_state = {"foyer_threshold_crossed": true, "visited_foyer": true}

[sub_resource type="Resource" id="act_visited_foyer_sovereign"]
script = ExtResource("7")
set_state = {"foyer_chandelier_awakened": true, "foyer_threshold_crossed": true, "visited_foyer": true}

[sub_resource type="Resource" id="act_show_foyer"]
script = ExtResource("7")
show_room_name = "Grand Foyer"

[sub_resource type="Resource" id="act_threshold_text"]
script = ExtResource("7")
show_text = "The front door shuts against the weather. Beyond a thin wash of moonlight, the hall offers only extinguished brass and the black curve of the stair. Whatever warmth once lived here will have to be made by hand."

[sub_resource type="Resource" id="act_threshold_text_sovereign"]
script = ExtResource("7")
show_text = "The front door shuts behind you. Before your eyes can settle, the chandelier answers overhead with a thin gold bloom, less like welcome than a memorial lamp being raised for a ceremony the house has repeated too many times."

[sub_resource type="Resource" id="act_settling_sfx"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/distant_settling.ogg"

[sub_resource type="Resource" id="act_threshold_light"]
script = ExtResource("7")
light_change = {"foyer_chandelier": {"energy": 1.85, "duration": 0.18}}

[sub_resource type="Resource" id="act_threshold_sway"]
script = ExtResource("7")
camera_shake = 0.025

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_foyer AND elizabeth_route != elder AND macro_thread != sovereign"
once = true
trigger_id = "foyer_first_entry"
actions = Array[Resource]([SubResource("act_visited_foyer"), SubResource("act_show_foyer"), SubResource("act_settling_sfx"), SubResource("act_threshold_sway"), SubResource("act_threshold_text")])

[sub_resource type="Resource" id="trig_first_entry_sovereign"]
script = ExtResource("6")
condition = "NOT visited_foyer AND elizabeth_route == elder OR NOT visited_foyer AND macro_thread == sovereign"
once = true
trigger_id = "foyer_first_entry_sovereign"
actions = Array[Resource]([SubResource("act_visited_foyer_sovereign"), SubResource("act_show_foyer"), SubResource("act_settling_sfx"), SubResource("act_threshold_light"), SubResource("act_threshold_sway"), SubResource("act_threshold_text_sovereign")])

; === Ambient Events ===

[sub_resource type="Resource" id="act_crystal_tinkle"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/crystal_tinkle.ogg"

[sub_resource type="Resource" id="ambient_chandelier"]
script = ExtResource("8")
event_id = "chandelier_tinkle"
interval_min = 30.0
interval_max = 60.0
condition = "foyer_chandelier_awakened"
actions = Array[Resource]([SubResource("act_crystal_tinkle")])

; === Flashback: Post-Truth ===

[sub_resource type="Resource" id="flashback_elizabeth"]
script = ExtResource("10")
flashback_id = "foyer_family_flashback"
condition = "knows_full_truth"
once = true
visual_kind = "bloodwraith_apparition"
model_position = Vector3(0, 0, 0)
model_scale = 0.6
duration = 4.0
fade_amount = 0.8
stinger_sfx = "res://assets/audio/sfx/stinger/pl_horror_stinger_05_slow.wav"
camera_shake = 0.1

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "foyer"
room_name = "Grand Foyer"
floor_name = "ground_floor"
environment_preset = "ground_floor"
dimensions = Vector3(12, 4.7, 10)
is_exterior = false
spatial_class = "threshold_room"
exposure_faces = PackedStringArray("south")
outlook_zones = {"south": "front_drive_and_night_glow"}
window_view_mode = "local_outlook"
wall_north = PackedStringArray("wall", "wall", "doorway:foyer_to_parlor", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "doorway:foyer_to_front_steps", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "doorway:foyer_to_dining_room", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "doorway:foyer_to_kitchen", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Moonlight Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_ground.wav"
reverb_bus = "Hall"
footstep_surface = "marble"
spawn_position = Vector3(-0.3, 0, -3.7)
spawn_rotation_y = 8.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_front_door")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_hall_axis")])
interactables = Array[Resource]([SubResource("inter_painting"), SubResource("inter_mirror"), SubResource("inter_clock"), SubResource("inter_switch"), SubResource("inter_mail"), SubResource("inter_stairs")])
lights = Array[Resource]([SubResource("light_chandelier"), SubResource("light_sconce_w"), SubResource("light_sconce_e"), SubResource("light_window"), SubResource("light_north_sconce_left"), SubResource("light_north_sconce_right"), SubResource("light_table_west"), SubResource("light_table_east")])
props = Array[Resource]([SubResource("prop_chandelier"), SubResource("prop_rug"), SubResource("prop_runner_entry"), SubResource("prop_runner_north"), SubResource("prop_drawers"), SubResource("prop_drawers_east"), SubResource("prop_coat_stand"), SubResource("prop_package"), SubResource("prop_wall_map"), SubResource("prop_pillar_l"), SubResource("prop_pillar_r"), SubResource("prop_candle_w"), SubResource("prop_candle_e"), SubResource("prop_north_door_frame"), SubResource("prop_north_wall_column_left"), SubResource("prop_north_wall_column_right"), SubResource("prop_upper_frieze_left"), SubResource("prop_upper_frieze_right"), SubResource("prop_east_door_frame"), SubResource("prop_west_door_frame"), SubResource("prop_north_candle_left"), SubResource("prop_north_candle_right")])
mount_slots = Array[Resource]([SubResource("mount_slot_drawers_west_table"), SubResource("mount_slot_drawers_east_table"), SubResource("mount_slot_wall_east_display"), SubResource("mount_slot_upper_north_portrait")])
mount_payloads = Array[Resource]([SubResource("mount_payload_table_lamp_west"), SubResource("mount_payload_table_lamp_east"), SubResource("mount_payload_wall_picture_east"), SubResource("mount_payload_upper_portrait_standard"), SubResource("mount_payload_upper_portrait_elder")])
on_entry = Array[Resource]([SubResource("trig_first_entry"), SubResource("trig_first_entry_sovereign")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_chandelier")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([SubResource("flashback_elizabeth")])
