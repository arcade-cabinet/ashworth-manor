; === White Lily Responses (Diamond #4 B-path: key in soil) ===

[sub_resource type="Resource" id="resp_lily_dig"]
script = ExtResource("3")
condition = "examined_lily"
title = "White Lily"
text = "You brush the soil at the base of the lily. Your fingers find something hard beneath the roots -- a small brass key, buried in the warm earth. Elizabeth hid it with the living things, not the dead."
set_state = {"found_jewelry_key_lily": true}
gives_item = "jewelry_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="resp_lily_default"]
script = ExtResource("3")
condition = ""
title = "White Lily"
text = "A single white lily, alive despite the frost that took everything else. Its petals are perfect. The soil around its base is warmer than it should be -- as if something buried there is still generating heat. Elizabeth's favorite flower. Victoria planted it the year she was born."
set_state = {"examined_lily": true}

; Lily thread variants
[sub_resource type="Resource" id="resp_lily_captive"]
script = ExtResource("3")
condition = ""
title = "White Lily"
text = "A white lily, alive in the dead garden. The only living thing on the grounds. As if something is keeping it alive from below -- feeding it warmth through the frozen soil. A prisoner can still tend a garden if the garden is directly above her cell. The roots reach down. She reaches up."
set_state = {"examined_lily": true}

[sub_resource type="Resource" id="resp_lily_mourning"]
script = ExtResource("3")
condition = ""
title = "White Lily"
text = "A white lily, Elizabeth's flower, still alive after all these years. Victoria planted it and watered it every morning until she could not walk anymore. Then someone else kept watering it. The soil is damp. Fresh. Who is tending this flower?"
set_state = {"examined_lily": true}

[sub_resource type="Resource" id="resp_lily_sovereign"]
script = ExtResource("3")
condition = ""
title = "White Lily"
text = "A white lily that turns toward you as you approach. Not toward the moon. Toward YOU. The petals flex slightly -- breathing. She is in everything. Even the flowers. Especially the flowers. This lily is not a memorial. It is a sensor."
set_state = {"examined_lily": true}

; === Frozen Fountain Responses (Swap #3 A-path) ===

[sub_resource type="Resource" id="resp_fountain_thaw"]
script = ExtResource("3")
condition = "HAS candle_lit"
title = "Fountain"
text = "You hold the candle close to the fountain's icy surface. The ice thins, revealing an inscription carved into the basin: 'Where the fifth branch withers, the root remembers.' The same symbol appears on the binding circle in the attic."
set_state = {"fountain_clue_found": true}
play_sfx = "res://assets/audio/sfx/ambient/ice_crack.ogg"

[sub_resource type="Resource" id="resp_fountain_default"]
script = ExtResource("3")
condition = ""
title = "Fountain"
text = "A stone fountain, dry and frozen solid. Ice fills the basin in a thick, opaque sheet. Something is carved into the basin beneath the ice, but you cannot read it through the frost. You would need to melt it somehow."

; === Gazebo Responses (Swap #3 B-path) ===

[sub_resource type="Resource" id="resp_gazebo_spot"]
script = ExtResource("3")
condition = "examined_gazebo_vines"
title = "Gazebo Vines"
text = "You step back to where the moonlight falls and look again. The dead vines on the lattice form a pattern -- not random decay but deliberate training. Someone wound these vines into a shape. It is the same symbol from the binding book: 'Where the fifth branch withers, the root remembers.' The same clue, delivered by the garden itself."
set_state = {"gazebo_clue_found": true}

[sub_resource type="Resource" id="resp_gazebo_default"]
script = ExtResource("3")
condition = ""
title = "Gazebo"
text = "A wooden gazebo with dead vines covering its lattice. The vines are brown and brittle, frozen into whatever shape they grew last summer. From this angle they look random. But there are worn spots on the flagstones nearby -- someone stood here often, looking at these vines from a specific position."
set_state = {"examined_gazebo_vines": true}

; === Garden Bench Responses ===

[sub_resource type="Resource" id="resp_bench_default"]
script = ExtResource("3")
condition = ""
title = "Stone Bench"
text = "A stone bench beneath a dead oak tree. The seat has been worn smooth. Someone sat here often, watching the house. You can see the attic window from this spot."

[sub_resource type="Resource" id="resp_beds_default"]
script = ExtResource("3")
condition = ""
title = "Dead Flower Beds"
text = "Formal flower beds line the rear walk in neat stone frames, all of them dead and black with winter rot. Someone maintained this garden carefully once. The only refusal is the white lily, blooming where it should not."

; === Interactables ===

[sub_resource type="Resource" id="inter_lily"]
script = ExtResource("2")
id = "garden_lily"
type = "observation"
position = Vector3(3, 0.2, 5)
collision_size = Vector3(1.5, 1.0, 1.5)
responses = Array[Resource]([SubResource("resp_lily_dig"), SubResource("resp_lily_default")])
thread_responses = {"captive": [SubResource("resp_lily_dig"), SubResource("resp_lily_captive")], "mourning": [SubResource("resp_lily_dig"), SubResource("resp_lily_mourning")], "sovereign": [SubResource("resp_lily_dig"), SubResource("resp_lily_sovereign")]}

