; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_garden": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Garden"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_garden"
once = true
trigger_id = "garden_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name")])

; === Ambient: Wind through dead branches ===

[sub_resource type="Resource" id="act_wind"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/wind_gust.ogg"

[sub_resource type="Resource" id="ambient_wind"]
script = ExtResource("8")
event_id = "garden_wind"
interval_min = 15.0
interval_max = 35.0
condition = ""
actions = Array[Resource]([SubResource("act_wind")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "garden"
room_name = "Garden"
floor_name = "grounds"
environment_preset = "garden_mist"
dimensions = Vector3(16, 6, 16)
is_exterior = true
wall_north = PackedStringArray()
wall_south = PackedStringArray()
wall_east = PackedStringArray()
wall_west = PackedStringArray()
ambient_loop = "res://assets/audio/loops/Subtle Changes Loop3_D.ogg"
tension_loop = "res://assets/audio/tension/tension_exploration.wav"
reverb_bus = "OpenAir"
footstep_surface = "grass"
spawn_position = Vector3(0, 0, 0)
spawn_rotation_y = 0.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_kitchen"), SubResource("anchor_entry_chapel"), SubResource("anchor_entry_greenhouse"), SubResource("anchor_entry_crypt")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_fountain_axis"), SubResource("anchor_focus_lily_tableau")])
interactables = Array[Resource]([SubResource("inter_lily"), SubResource("inter_fountain"), SubResource("inter_gazebo"), SubResource("inter_bench"), SubResource("inter_beds")])
lights = Array[Resource]([SubResource("light_moon"), SubResource("light_gazebo_candle")])
props = Array[Resource]([SubResource("prop_fountain_model"), SubResource("prop_fountain_ice"), SubResource("prop_bench_model"), SubResource("prop_gazebo_model"), SubResource("prop_gazebo_table"), SubResource("prop_bench_north"), SubResource("prop_beds_west"), SubResource("prop_beds_east"), SubResource("prop_path_west"), SubResource("prop_path_center"), SubResource("prop_path_north"), SubResource("prop_path_chapel"), SubResource("prop_path_crypt"), SubResource("prop_north_wall_w"), SubResource("prop_north_wall_e"), SubResource("prop_east_wall_s"), SubResource("prop_east_wall_n"), SubResource("prop_corner_ne"), SubResource("prop_column_l"), SubResource("prop_column_r"), SubResource("prop_vase_l"), SubResource("prop_vase_r"), SubResource("prop_crypt_pillar_l"), SubResource("prop_crypt_pillar_r"), SubResource("prop_crypt_gate"), SubResource("prop_gazebo_candle_holder"), SubResource("prop_gazebo_candle")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_wind")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
