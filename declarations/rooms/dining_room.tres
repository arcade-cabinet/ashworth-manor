; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_dining_room": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Dining Room"

[sub_resource type="Resource" id="act_entry_text"]
script = ExtResource("7")
show_text = "The dinner table holds its breath. Chairs wait, candles sag, and every place setting suggests the meal stopped in the middle of deciding who would survive the night."

[sub_resource type="Resource" id="trig_entry"]
script = ExtResource("6")
condition = "NOT visited_dining_room"
once = true
trigger_id = "dining_room_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name"), SubResource("act_entry_text")])

; === Ambient ===

[sub_resource type="Resource" id="act_silverware"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/silverware_clink.ogg"

[sub_resource type="Resource" id="ambient_clink"]
script = ExtResource("8")
event_id = "silverware_clink"
interval_min = 25.0
interval_max = 50.0
condition = ""
actions = Array[Resource]([SubResource("act_silverware")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "dining_room"
room_name = "Dining Room"
floor_name = "ground_floor"
environment_preset = "ground_floor"
dimensions = Vector3(8, 2.4, 10)
is_exterior = false
wall_texture = "wall5_texture"
floor_texture = "floor1_texture"
ceiling_texture = "ceiling0_texture"
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "doorway:dining_room_to_foyer", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Keep it up Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_ground.wav"
reverb_bus = "Room"
footstep_surface = "wood_parquet"
spawn_position = Vector3(0, 0, -7)
spawn_rotation_y = 180.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_foyer")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_tableau")])
interactables = Array[Resource]([SubResource("inter_photo"), SubResource("inter_chair"), SubResource("inter_wine"), SubResource("inter_candles"), SubResource("inter_bell")])
lights = Array[Resource]([SubResource("light_chandelier"), SubResource("light_candles")])
props = Array[Resource]([SubResource("prop_table"), SubResource("prop_chandelier"), SubResource("prop_chair_l0"), SubResource("prop_chair_l1"), SubResource("prop_chair_l2"), SubResource("prop_chair_r0"), SubResource("prop_chair_r1"), SubResource("prop_chair_push"), SubResource("prop_photo_frame"), SubResource("prop_lamp"), SubResource("prop_bottle_1"), SubResource("prop_bottle_2"), SubResource("prop_bottle_3"), SubResource("prop_serving_vessel"), SubResource("prop_plate_1"), SubResource("prop_plate_2"), SubResource("prop_plate_3"), SubResource("prop_plate_4"), SubResource("prop_plate_5"), SubResource("prop_plate_6"), SubResource("prop_water_glass_1"), SubResource("prop_water_glass_2"), SubResource("prop_fork"), SubResource("prop_knife"), SubResource("prop_spoon")])
on_entry = Array[Resource]([SubResource("trig_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_clink")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
