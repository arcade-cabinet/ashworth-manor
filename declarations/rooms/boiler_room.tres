[gd_resource type="Resource" script_class="RoomDeclaration" format=3]

[ext_resource type="Script" path="res://engine/declarations/room_declaration.gd" id="1"]
[ext_resource type="Script" path="res://engine/declarations/interactable_decl.gd" id="2"]
[ext_resource type="Script" path="res://engine/declarations/response_decl.gd" id="3"]
[ext_resource type="Script" path="res://engine/declarations/light_decl.gd" id="4"]
[ext_resource type="Script" path="res://engine/declarations/prop_decl.gd" id="5"]
[ext_resource type="Script" path="res://engine/declarations/trigger_decl.gd" id="6"]
[ext_resource type="Script" path="res://engine/declarations/action_decl.gd" id="7"]
[ext_resource type="Script" path="res://engine/declarations/ambient_event_decl.gd" id="8"]
[ext_resource type="Script" path="res://engine/declarations/progression_step.gd" id="9"]

; === Maintenance Log Responses ===

[sub_resource type="Resource" id="resp_log_default"]
script = ExtResource("3")
condition = ""
title = "Maintenance Log"
text = "A caretaker's logbook. Entries describe boiler maintenance, pipe repairs, coal deliveries. The tone shifts in November 1891: 'Pipes making noise again. Not steam. Voices. The girl upstairs is using the pipes to talk to the basement. I can hear her through the walls.'"
set_state = {"read_maintenance_log": true}

[sub_resource type="Resource" id="resp_log_captive"]
script = ExtResource("3")
condition = ""
title = "Maintenance Log"
text = "A caretaker's logbook. November 12th: 'The pipes rattle at night. Lord Ashworth says ignore it. I cannot ignore it. The rattling forms patterns. Three taps, then silence, then three more. She is sending messages through the plumbing. The pipes connect every room in this house. They cannot cage her if the pipes are open.' He tried to seal the pipe joints. The next entry: 'The seals broke overnight. All of them.'"
set_state = {"read_maintenance_log": true}

[sub_resource type="Resource" id="resp_log_mourning"]
script = ExtResource("3")
condition = ""
title = "Maintenance Log"
text = "A caretaker's logbook. November 15th: 'They dine while the girl cries. I can hear her through the pipes. The sound carries down to the boiler room and echoes. It is the saddest sound I have ever heard. I left a biscuit on the pipe junction near the attic. It was gone in the morning.' He was feeding her through the walls. The only person in this house who tried."
set_state = {"read_maintenance_log": true}

[sub_resource type="Resource" id="resp_log_sovereign"]
script = ExtResource("3")
condition = ""
title = "Maintenance Log"
text = "A caretaker's logbook. November 20th: 'The boiler started itself today. No one lit it. No coal in the firebox. It is generating heat from nothing. The pipes are warm throughout the house -- every room, every floor. She is using the heating system as a nervous system. The boiler is her heart. The pipes are her veins. This house has a circulatory system now and it pumps because she tells it to.'"
set_state = {"read_maintenance_log": true}

; === Boiler Observation ===

[sub_resource type="Resource" id="resp_boiler_default"]
script = ExtResource("3")
condition = ""
title = "Boiler"
text = "The boiler is warm. The iron radiates heat despite no visible fire, no coal, no gas. The pressure gauge reads normal. The temperature gauge reads 37 degrees Celsius. Body temperature."

[sub_resource type="Resource" id="resp_boiler_captive"]
script = ExtResource("3")
condition = ""
title = "Boiler"
text = "The boiler is warm. Iron straps circle its body like chains. The pressure gauge reads normal but the needle trembles. Something inside is pushing against the walls of the boiler. Not steam. Not pressure. Something that wants out."

[sub_resource type="Resource" id="resp_boiler_mourning"]
script = ExtResource("3")
condition = ""
title = "Boiler"
text = "The boiler is warm. A gentle warmth, like a hand held over a sleeping child. The iron surface is slightly damp with condensation. It looks like the boiler has been weeping. The pipes leading out of it are warm too -- carrying heat to every room. Even now, even empty, the house tries to keep its inhabitants warm."

[sub_resource type="Resource" id="resp_boiler_sovereign"]
script = ExtResource("3")
condition = ""
title = "Boiler"
text = "The boiler is warm. 37 degrees exactly. Body temperature. You press your hand against the iron and it pulses. Not vibration from machinery -- a pulse. A heartbeat. Slow and steady. The boiler is the heart of the house. She keeps it beating."

; === Clock ===

[sub_resource type="Resource" id="resp_clock_default"]
script = ExtResource("3")
condition = ""
title = "Boiler Room Clock"
text = "A clock mounted above the boiler. 3:33. Same as every clock in the house. The same moment, frozen in every room."
set_state = {"examined_boiler_clock": true}

; === Pipe Valves Responses (Swap #2 A-path) ===

[sub_resource type="Resource" id="resp_valve_step1"]
script = ExtResource("3")
condition = ""
title = "Pipe Valves"
text = "You turn the first valve. The pipes groan -- a low, resonant note that travels through the walls. The pitch is wrong. Too low."
set_state = {"valve_1_turned": true}
play_sfx = "res://assets/audio/sfx/impact/metal_heavy.ogg"

[sub_resource type="Resource" id="resp_valve_step2"]
script = ExtResource("3")
condition = ""
title = "Pipe Valves"
text = "The second valve. A higher note joins the first -- the pipes are singing now, a dissonant chord that makes the walls vibrate. One more."
set_state = {"valve_2_turned": true}
play_sfx = "res://assets/audio/sfx/impact/metal_heavy.ogg"

[sub_resource type="Resource" id="resp_valve_step3"]
script = ExtResource("3")
condition = ""
title = "Pipe Valves"
text = "The third valve. The pipes harmonize -- three notes forming a chord. And through the chord, carried by the vibrating metal, you hear her voice. Elizabeth, speaking through the plumbing. 'The fifth branch withers. The root remembers. The binding breaks where water meets fire.' Then silence. The pipes cool. She said what she needed to say."
set_state = {"pipe_voice_heard": true}
play_sfx = "res://assets/audio/sfx/horror/whisper_close.ogg"

; === Electrical Panel Responses (Swap #2 B-path) ===

[sub_resource type="Resource" id="resp_electrical_step1"]
script = ExtResource("3")
condition = ""
title = "Electrical Panel"
text = "A fuse box with six slots. Three fuses are in the wrong positions -- the labels have been rearranged. Someone swapped them deliberately to kill the lights in certain rooms. The labels read: ATTIC, BASEMENT, CHAPEL, KITCHEN, LIBRARY, GARDEN."
set_state = {"examined_fuse_box": true}

[sub_resource type="Resource" id="resp_electrical_step2"]
script = ExtResource("3")
condition = ""
title = "Electrical Panel"
text = "You rearrange the fuses to match their correct slots. ATTIC in position 1, LIBRARY in position 5. The panel clicks. Somewhere above, lights flicker on in rooms that have been dark for twenty years. The extra illumination reveals details previously hidden in shadow -- scratches on walls, marks on floors, writing in places no one was meant to read."
set_state = {"power_restored": true}
play_sfx = "res://assets/audio/sfx/impact/click_heavy.ogg"

; === Pipe Valve Progressive Interactable (Swap #2 A-path) ===

[sub_resource type="Resource" id="prog_valve_1"]
script = ExtResource("9")
step_id = "valve_turn_1"
required_state = ""
response = SubResource("resp_valve_step1")

[sub_resource type="Resource" id="prog_valve_2"]
script = ExtResource("9")
step_id = "valve_turn_2"
required_state = "valve_1_turned"
response = SubResource("resp_valve_step2")

[sub_resource type="Resource" id="prog_valve_3"]
script = ExtResource("9")
step_id = "valve_turn_3"
required_state = "valve_2_turned"
response = SubResource("resp_valve_step3")

; === Interactables ===

[sub_resource type="Resource" id="inter_log"]
script = ExtResource("2")
id = "maintenance_log"
type = "note"
position = Vector3(-2.5, 1, -3)
collision_size = Vector3(1.5, 1.5, 1.5)
responses = Array[Resource]([SubResource("resp_log_default")])
thread_responses = {"captive": [SubResource("resp_log_captive")], "mourning": [SubResource("resp_log_mourning")], "sovereign": [SubResource("resp_log_sovereign")]}

[sub_resource type="Resource" id="inter_boiler"]
script = ExtResource("2")
id = "boiler_observation"
type = "observation"
position = Vector3(0, 1.5, 3.5)
wall = "north"
collision_size = Vector3(2.0, 2.0, 1.5)
responses = Array[Resource]([SubResource("resp_boiler_default")])
thread_responses = {"captive": [SubResource("resp_boiler_captive")], "mourning": [SubResource("resp_boiler_mourning")], "sovereign": [SubResource("resp_boiler_sovereign")]}

[sub_resource type="Resource" id="inter_clock"]
script = ExtResource("2")
id = "boiler_clock"
type = "clock"
position = Vector3(0, 3, 3.5)
wall = "north"
collision_size = Vector3(1.0, 1.0, 0.5)
responses = Array[Resource]([SubResource("resp_clock_default")])

[sub_resource type="Resource" id="inter_pipe_valves"]
script = ExtResource("2")
id = "boiler_pipe_valves"
type = "switch"
position = Vector3(2.5, 1.2, 3.5)
wall = "north"
collision_size = Vector3(1.5, 1.5, 1.0)
progressive = true
progression_steps = Array[Resource]([SubResource("prog_valve_1"), SubResource("prog_valve_2"), SubResource("prog_valve_3")])

[sub_resource type="Resource" id="inter_electrical"]
script = ExtResource("2")
id = "boiler_electrical_panel"
type = "switch"
position = Vector3(-2.5, 1.2, 3.5)
wall = "north"
collision_size = Vector3(1.5, 1.5, 1.0)
model = "res://assets/mansion_psx/electrical_equipment_1.glb"
responses = Array[Resource]([SubResource("resp_electrical_step2"), SubResource("resp_electrical_step1")])

; === Lights ===

[sub_resource type="Resource" id="light_boiler"]
script = ExtResource("4")
id = "boiler_glow"
type = "omni"
position = Vector3(0, 1, 3.5)
color = Color(1.0, 0.4, 0.1, 1)
energy = 0.8
range = 5.0
shadows = true
flickering = true
flicker_pattern = "ember"

; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_boiler_room": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Boiler Room"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_boiler_room"
once = true
trigger_id = "boiler_room_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name")])

; === Ambient: Pipe rattle ===

[sub_resource type="Resource" id="act_rattle"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/pipe_rattle.ogg"

[sub_resource type="Resource" id="ambient_rattle"]
script = ExtResource("8")
event_id = "pipe_rattle"
interval_min = 15.0
interval_max = 30.0
condition = ""
actions = Array[Resource]([SubResource("act_rattle")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "boiler_room"
room_name = "Boiler Room"
floor_name = "basement"
environment_preset = "basement"
dimensions = Vector3(6, 4, 8)
is_exterior = false
wall_texture = "wall8_texture"
floor_texture = "floor4_texture"
ceiling_texture = "ceiling2_texture"
wall_north = PackedStringArray("wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "doorway:boiler_room_to_storage_basement", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Insufficient Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_basement.wav"
reverb_bus = "Dungeon"
footstep_surface = "metal_grate"
spawn_position = Vector3(-2, 0, 0)
spawn_rotation_y = 90.0
interactables = Array[Resource]([SubResource("inter_log"), SubResource("inter_boiler"), SubResource("inter_clock"), SubResource("inter_pipe_valves"), SubResource("inter_electrical")])
lights = Array[Resource]([SubResource("light_boiler")])
props = Array[Resource]([])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_rattle")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
