[sub_resource type="Resource" id="anchor_entry_storage"]
script = ExtResource("9")
anchor_id = "entry_storage"
anchor_type = "entry"
position = Vector3(-2.35, 0, -1.25)
rotation_y = 44.0
target_anchor_id = "focus_boiler_core"
tags = PackedStringArray("default", "storage")

[sub_resource type="Resource" id="anchor_focus_boiler_core"]
script = ExtResource("9")
anchor_id = "focus_boiler_core"
anchor_type = "focal"
position = Vector3(0.25, 1.35, 3.15)
rotation_y = 0.0
tags = PackedStringArray("boiler", "heat")

; === Maintenance Log Responses ===

[sub_resource type="Resource" id="resp_log_default"]
script = ExtResource("3")
condition = ""
title = "Maintenance Log"
text = "A caretaker's logbook left open on the workbench. Entries describe boiler maintenance, pipe repairs, coal deliveries. The handwriting grows unsteady through autumn 1891: 'Pressure irregular again. Third time this month. Foreman says the seals are fine but I can hear the joints weeping at night. I am the last one willing to come down here alone.'"
set_state = {"knows_staff_afraid": true, "read_maintenance_log": true}

[sub_resource type="Resource" id="resp_log_captive"]
script = ExtResource("3")
condition = ""
title = "Maintenance Log"
text = "A caretaker's logbook. November 12th: 'Three workers quit this week. They say the pipes rattle at night and Lord Ashworth will not explain. I remain because he pays triple and because someone must keep the boiler fed. The house cannot heat itself.' He underlined the last sentence twice, as though convincing himself."
set_state = {"knows_staff_afraid": true, "read_maintenance_log": true}

[sub_resource type="Resource" id="resp_log_mourning"]
script = ExtResource("3")
condition = ""
title = "Maintenance Log"
text = "A caretaker's logbook. November 15th: 'I left a biscuit on the pipe junction near the attic. It was gone in the morning. The family will not feed her properly. Someone must. I cannot reach the room but the pipes connect every floor.' He was using the service infrastructure to reach someone the house had sealed away."
set_state = {"knows_staff_afraid": true, "read_maintenance_log": true}

[sub_resource type="Resource" id="resp_log_sovereign"]
script = ExtResource("3")
condition = ""
title = "Maintenance Log"
text = "A caretaker's logbook. November 20th: 'The boiler started itself today. No one lit it. I checked the firebox — cold ash, no coal. But the pressure gauge reads normal and the pipes are warm throughout the house. I reported it to Lord Ashworth. He told me not to write it down. I am writing it down.'"
set_state = {"knows_staff_afraid": true, "read_maintenance_log": true}

; === Boiler Observation Responses ===

[sub_resource type="Resource" id="resp_boiler_restored"]
script = ExtResource("3")
condition = "gas_restored"
title = "Boiler"
text = "The boiler idles at low pressure, feeding gas to the house pipes. The iron ticks as it warms. Ordinary service machinery doing ordinary work — the first honest sound this house has made since you arrived."

[sub_resource type="Resource" id="resp_boiler_default"]
script = ExtResource("3")
condition = ""
title = "Boiler"
text = "Cast iron, riveted, enormous. A coal-and-gas combination unit — the kind that heated manor houses before electricity made them obsolete. The firebox is cold, the ash grey and undisturbed. But the gas feed line runs to a shutoff valve on the right side. If the mains still hold pressure, the pilot assembly might catch."

[sub_resource type="Resource" id="resp_boiler_captive"]
script = ExtResource("3")
condition = ""
title = "Boiler"
text = "The boiler sits cold and enormous. Iron straps circle its body like reinforcement bands — standard for pressure vessels of this era, though the bolts have been tightened far past what maintenance would require. Someone was afraid of what might happen if the seams gave way."

[sub_resource type="Resource" id="resp_boiler_mourning"]
script = ExtResource("3")
condition = ""
title = "Boiler"
text = "The boiler sits cold but not hostile. The iron surface is slightly damp with condensation — the temperature difference between the basement stone and the residual warmth in the pipes. The coal scuttle beside it is empty. Whoever maintained this machine cared about the work. The logbook confirms it."

[sub_resource type="Resource" id="resp_boiler_sovereign"]
script = ExtResource("3")
condition = ""
title = "Boiler"
text = "The boiler sits at the centre of the pipe network, cold but structurally sound. Every pipe in the ceiling runs through or past this machine. Whoever designed the heating system made the boiler the single point of control — shut it down and the entire house goes dark and cold. A house this size, governed by one valve."

; === Clock ===

[sub_resource type="Resource" id="resp_clock_default"]
script = ExtResource("3")
condition = ""
title = "Boiler Room Clock"
text = "A clock mounted above the boiler. 3:33. Same as every clock in the house. This one is spring-wound, not pendulum — built for reliability in a service space. It should not have stopped."
set_state = {"examined_boiler_clock": true}

; === Gas Restore Responses ===

[sub_resource type="Resource" id="resp_gas_done"]
script = ExtResource("3")
condition = "gas_restored"
title = "Gas Shutoff Valve"
text = "The valve is open. Gas feeds steadily through the mains. The boiler pilot holds. You can hear the pipes warming — small ticks and pops as metal expands through the walls and ceiling."

[sub_resource type="Resource" id="resp_gas_not_relit"]
script = ExtResource("3")
condition = "NOT basement_relight"
title = "Gas Shutoff Valve"
text = "You can feel a large valve handle in the dark. Heavy iron, cold. You cannot read the markings. You need light first."

[sub_resource type="Resource" id="resp_gas_default"]
script = ExtResource("3")
condition = ""
title = "Gas Shutoff Valve"
text = "A heavy iron shutoff valve on the gas feed line. The handle is stiff but not seized. You brace your weight and turn it. Metal groans. Then a hiss — faint, steady, pressurized. The mains still hold. You cross to the pilot assembly and hold your last match to the jet. It catches. The boiler shudders once and settles into a low, workmanlike rumble. Through the ceiling, you hear pipes answer — ticking, expanding, carrying heat for the first time in a century."
set_state = {"gas_restored": true, "basement_lights_awake": true, "bad_air_active": false}
play_sfx = "res://assets/audio/sfx/ambient/pl_ambient_machine_02.ogg"

; === Pipe Observation ===

[sub_resource type="Resource" id="resp_pipes_restored"]
script = ExtResource("3")
condition = "gas_restored"
title = "Ceiling Pipes"
text = "The pipes tick and pop overhead as they warm. The sound travels through the walls — you can hear the house responding floor by floor. Heating infrastructure, doing what it was built to do."

[sub_resource type="Resource" id="resp_pipes_default"]
script = ExtResource("3")
condition = ""
title = "Ceiling Pipes"
text = "Pipes run across the ceiling and into the walls in every direction. Cast-iron mains splitting into copper branches — a heating network designed to reach every room. Cold now, but the joints are sound. If the boiler ran, these pipes would carry heat to the entire house."

; === Walking Cane Responses ===

[sub_resource type="Resource" id="resp_cane_taken"]
script = ExtResource("3")
condition = "walking_stick_phase"
title = "Walking Cane"
text = "The caretaker's cane. Already in your hand. Ash wood and iron — the grip is worn to the shape of his palm."

[sub_resource type="Resource" id="resp_cane_not_ready"]
script = ExtResource("3")
condition = "NOT gas_restored"
title = "Walking Cane"
text = "A walking cane propped against the workbench, near the logbook. Ash wood with an iron-shod tip. You have more urgent work down here than collecting personal effects."

[sub_resource type="Resource" id="resp_cane_default"]
script = ExtResource("3")
condition = ""
title = "Walking Cane"
text = "A walking cane propped against the workbench, ash wood with an iron-shod tip worn smooth by years of service corridors. The caretaker's. He walked this house end to end every day and knew every stair by feel. The brand is gone. The house is lit. This is a better tool for what comes next — steadier, deliberate. You take it."
set_state = {"walking_stick_phase": true, "current_light_tool": "walking_stick"}
gives_item = "walking_cane"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

; === Interactables ===

[sub_resource type="Resource" id="inter_log"]
script = ExtResource("2")
id = "maintenance_log"
type = "note"
position = Vector3(-2.5, 1, -3)
collision_size = Vector3(1.5, 1.5, 1.5)
responses = Array[Resource]([SubResource("resp_log_default")])
thread_responses = {"child": [SubResource("resp_log_captive")], "adult": [SubResource("resp_log_mourning")], "elder": [SubResource("resp_log_sovereign")], "captive": [SubResource("resp_log_captive")], "mourning": [SubResource("resp_log_mourning")], "sovereign": [SubResource("resp_log_sovereign")]}

[sub_resource type="Resource" id="inter_boiler"]
script = ExtResource("2")
id = "boiler_observation"
type = "observation"
position = Vector3(0, 1.5, 3.5)
wall = "north"
collision_size = Vector3(2.0, 2.0, 1.5)
responses = Array[Resource]([SubResource("resp_boiler_restored"), SubResource("resp_boiler_default")])
thread_responses = {"child": [SubResource("resp_boiler_captive")], "adult": [SubResource("resp_boiler_mourning")], "elder": [SubResource("resp_boiler_sovereign")], "captive": [SubResource("resp_boiler_captive")], "mourning": [SubResource("resp_boiler_mourning")], "sovereign": [SubResource("resp_boiler_sovereign")]}

[sub_resource type="Resource" id="inter_clock"]
