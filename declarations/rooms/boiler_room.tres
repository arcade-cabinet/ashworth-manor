; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_boiler_room": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Boiler Room"

[sub_resource type="Resource" id="act_entry_sfx"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/pl_ambient_machine_02.ogg"

[sub_resource type="Resource" id="act_entry_text"]
script = ExtResource("7")
show_text = "Iron and coal dust. A service room built for function — the boiler at the far wall, pipes running in every direction overhead, a workbench with tools still laid out. The house's heating plant. Cold now, but intact."

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_boiler_room"
once = true
trigger_id = "boiler_room_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name"), SubResource("act_entry_sfx"), SubResource("act_entry_text")])

; === Conditional Event: Gas Restore Sconce Wake ===

[sub_resource type="Resource" id="act_sconce_east_wake"]
script = ExtResource("7")
light_change = {"boiler_sconce_east": {"energy": 1.8, "duration": 3.0}}

[sub_resource type="Resource" id="act_sconce_west_wake"]
script = ExtResource("7")
light_change = {"boiler_sconce_west": {"energy": 1.8, "duration": 3.0}}
delay_seconds = 1.0

[sub_resource type="Resource" id="act_boiler_glow_raise"]
script = ExtResource("7")
light_change = {"boiler_glow": {"energy": 2.0, "duration": 2.0}}

[sub_resource type="Resource" id="act_sconce_wake_text"]
script = ExtResource("7")
show_text = "Gas reaches the wall sconces. One by one, they catch — small blue flames steadying into amber. The boiler room fills with working light for the first time since you arrived. The basement is no longer hostile. It is a service floor again."
delay_seconds = 2.0

[sub_resource type="Resource" id="cond_gas_sconce_wake"]
script = ExtResource("10")
event_id = "boiler_gas_sconce_wake"
condition = "gas_restored"
once = true
actions = Array[Resource]([SubResource("act_boiler_glow_raise"), SubResource("act_sconce_east_wake"), SubResource("act_sconce_west_wake"), SubResource("act_sconce_wake_text")])

; === Ambient: Pipe sound ===

[sub_resource type="Resource" id="act_pipe_tick"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/pipe_rattle.ogg"

[sub_resource type="Resource" id="ambient_pipe_cold"]
script = ExtResource("8")
event_id = "pipe_cold_rattle"
interval_min = 15.0
interval_max = 30.0
condition = "NOT gas_restored"
actions = Array[Resource]([SubResource("act_pipe_tick")])

[sub_resource type="Resource" id="act_pipe_warm"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/pl_ambient_machine_02.ogg"

[sub_resource type="Resource" id="ambient_pipe_warm"]
script = ExtResource("8")
event_id = "pipe_warm_tick"
interval_min = 25.0
interval_max = 45.0
condition = "gas_restored"
actions = Array[Resource]([SubResource("act_pipe_warm")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "boiler_room"
room_name = "Boiler Room"
floor_name = "basement"
environment_preset = "basement"
dimensions = Vector3(6, 4, 8)
is_exterior = false
wall_north = PackedStringArray("wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "doorway:boiler_room_to_storage_basement", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Insufficient Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_basement.wav"
reverb_bus = "Dungeon"
footstep_surface = "metal_grate"
spawn_position = Vector3(-2, 0, 0)
spawn_rotation_y = 90.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_storage")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_boiler_core")])
interactables = Array[Resource]([SubResource("inter_log"), SubResource("inter_boiler"), SubResource("inter_clock"), SubResource("inter_gas_restore"), SubResource("inter_pipes"), SubResource("inter_cane")])
lights = Array[Resource]([SubResource("light_boiler"), SubResource("light_panel"), SubResource("light_sconce_east"), SubResource("light_sconce_west")])
props = Array[Resource]([SubResource("prop_boiler"), SubResource("prop_pipes_ceiling"), SubResource("prop_pipe_mid"), SubResource("prop_pipe_curve"), SubResource("prop_valve"), SubResource("prop_machinery_l"), SubResource("prop_machinery_r"), SubResource("prop_machinery_back"), SubResource("prop_electrical_box"), SubResource("prop_electrical_aux"), SubResource("prop_workbench"), SubResource("prop_toolbox"), SubResource("prop_wrench_1"), SubResource("prop_wrench_2"), SubResource("prop_hammer"), SubResource("prop_barrel_1"), SubResource("prop_barrel_2"), SubResource("prop_jerrycan"), SubResource("prop_sconce_east"), SubResource("prop_sconce_west"), SubResource("prop_walking_cane")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_pipe_cold"), SubResource("ambient_pipe_warm")])
conditional_events = Array[Resource]([SubResource("cond_gas_sconce_wake")])
flashbacks = Array[Resource]([])
