collision_size = Vector3(1.0, 1.0, 0.5)
responses = Array[Resource]([SubResource("resp_clock_default")])

[sub_resource type="Resource" id="inter_gas_restore"]
script = ExtResource("2")
id = "gas_restore"
type = "switch"
position = Vector3(2.5, 1.2, 3.5)
wall = "north"
collision_size = Vector3(1.5, 1.5, 1.0)
responses = Array[Resource]([SubResource("resp_gas_done"), SubResource("resp_gas_not_relit"), SubResource("resp_gas_default")])

[sub_resource type="Resource" id="inter_pipes"]
script = ExtResource("2")
id = "boiler_pipes"
type = "observation"
position = Vector3(0, 2.5, 0)
collision_size = Vector3(3.0, 1.0, 3.0)
responses = Array[Resource]([SubResource("resp_pipes_restored"), SubResource("resp_pipes_default")])

[sub_resource type="Resource" id="inter_cane"]
script = ExtResource("2")
id = "walking_cane"
type = "item"
position = Vector3(-1.8, 0.9, -3.0)
collision_size = Vector3(1.0, 1.5, 1.0)
responses = Array[Resource]([SubResource("resp_cane_taken"), SubResource("resp_cane_not_ready"), SubResource("resp_cane_default")])

