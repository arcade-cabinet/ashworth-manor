[resource]
script = ExtResource("1")
room_id = "front_steps"
room_name = "Front Steps"
floor_name = "grounds"
environment_preset = "forecourt_lamplit"
dimensions = Vector3(26, 10, 12)
is_exterior = true
spatial_class = "threshold_room"
exposure_faces = PackedStringArray("south", "east", "west", "roof")
outlook_zones = {"north": "front_door_threshold", "south": "ceremonial_drive_return", "east": "side_path_gate_east", "west": "side_path_gate_west", "roof": "open_sky"}
window_view_mode = "facade_view"
wall_north = PackedStringArray()
wall_south = PackedStringArray()
wall_east = PackedStringArray()
wall_west = PackedStringArray()
ambient_loop = "res://assets/audio/loops/Moonlight Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_exploration.wav"
reverb_bus = "OpenAir"
footstep_surface = "gravel"
spawn_position = Vector3(0, 0, -4.8)
spawn_rotation_y = 180.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_from_drive"), SubResource("anchor_entry_front_door")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_front_door"), SubResource("anchor_focus_forecourt")])
interactables = Array[Resource]([SubResource("inter_front_door"), SubResource("inter_front_lamp"), SubResource("inter_service_gate"), SubResource("inter_garden_gate")])
lights = Array[Resource]([SubResource("light_moonlight"), SubResource("light_doorway_glow"), SubResource("light_lamp_left"), SubResource("light_lamp_right")])
props = Array[Resource]([SubResource("prop_forecourt_steps_shell"), SubResource("prop_statue_plinth_left"), SubResource("prop_statue_left"), SubResource("prop_statue_plinth_right"), SubResource("prop_statue_right"), SubResource("prop_mansion_facade_shell"), SubResource("prop_front_steps_entry_portico"), SubResource("prop_facade_door"), SubResource("prop_facade_lamp_left"), SubResource("prop_facade_lamp_right"), SubResource("prop_service_boundary_wall"), SubResource("prop_service_gate_inner_pillar"), SubResource("prop_service_gate"), SubResource("prop_service_gate_outer_pillar"), SubResource("prop_service_fence_stub"), SubResource("prop_service_hedge_stub"), SubResource("prop_garden_boundary_wall"), SubResource("prop_garden_gate_inner_pillar"), SubResource("prop_garden_gate"), SubResource("prop_garden_gate_outer_pillar"), SubResource("prop_garden_fence_stub"), SubResource("prop_garden_hedge_stub")])
on_entry = Array[Resource]([])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
