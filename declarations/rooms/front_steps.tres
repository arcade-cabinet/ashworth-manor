[sub_resource type="Resource" id="resp_door"]
script = ExtResource("3")
condition = ""
title = "Front Door"
text = "The front door is shut fast against the weather. No light slips under it. The brass key from your valise is the only civil answer the house is likely to give."

[sub_resource type="Resource" id="resp_lamp"]
script = ExtResource("3")
condition = ""
title = "Forecourt Lamp"
text = "The lamp glass is sooty and old, yet the flame holds with stubborn steadiness. Wealth here was meant to be seen before it was heard."

[sub_resource type="Resource" id="resp_service_gate"]
script = ExtResource("3")
condition = ""
title = "Service-Side Gate"
text = "A locked iron gate bars the west path. The metalwork is plainer than the front approach, practical rather than ceremonial. Whatever lies that way was never meant to receive callers first."

[sub_resource type="Resource" id="resp_garden_gate"]
script = ExtResource("3")
condition = ""
title = "Garden-Side Gate"
text = "The east gate is finer in its patterning but no less shut. Beyond it, hedge and darkness swallow what should be the gentler side of the estate."

