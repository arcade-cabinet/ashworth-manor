[sub_resource type="Resource" id="resp_ascent"]
script = ExtResource("3")
condition = ""
title = "Upper Drive"
text = "The drive widens just enough to become ceremonial. Statues flank the ascent, and the hedges part only where the manor wants the eye to travel: up the shallow rise, toward the lamps and the front door."

[sub_resource type="Resource" id="resp_statue"]
script = ExtResource("3")
condition = ""
title = "Weathered Statue"
text = "The stone figure is soft with rain and frost, its face long since surrendered to weather. It does not decorate the drive so much as witness it."

