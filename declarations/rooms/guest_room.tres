[gd_resource type="Resource" script_class="RoomDeclaration" format=3]

[ext_resource type="Script" path="res://engine/declarations/room_declaration.gd" id="1"]
[ext_resource type="Script" path="res://engine/declarations/interactable_decl.gd" id="2"]
[ext_resource type="Script" path="res://engine/declarations/response_decl.gd" id="3"]
[ext_resource type="Script" path="res://engine/declarations/light_decl.gd" id="4"]
[ext_resource type="Script" path="res://engine/declarations/prop_decl.gd" id="5"]
[ext_resource type="Script" path="res://engine/declarations/trigger_decl.gd" id="6"]
[ext_resource type="Script" path="res://engine/declarations/action_decl.gd" id="7"]

; === Guest Ledger Responses ===

[sub_resource type="Resource" id="resp_ledger_default"]
script = ExtResource("3")
condition = ""
title = "Guest Ledger"
text = "A leather guest book. Most entries are perfunctory: 'Lovely stay, splendid hospitality.' The last entry is from Helena Pierce, November 3rd, 1891: 'Arrived for research on spiritual phenomena. Lord Ashworth most accommodating. The house is remarkable.' She never wrote a departure entry."
set_state = {"read_guest_ledger": true}

[sub_resource type="Resource" id="resp_ledger_captive"]
script = ExtResource("3")
condition = ""
title = "Guest Ledger"
text = "Helena Pierce arrived November 3rd. Her entry: 'There is no attic invalid. There is a sealed wall. I heard a child speaking from behind it while the servants pretended not to hear a thing. Lord Ashworth says the arrangement is temporary. The plaster dates say otherwise.' Helena understood the architecture before she understood the haunting. The last page of the ledger has been torn out."
set_state = {"read_guest_ledger": true}

[sub_resource type="Resource" id="resp_ledger_mourning"]
script = ExtResource("3")
condition = ""
title = "Guest Ledger"
text = "Helena Pierce arrived November 3rd. Her entry: 'The Ashworths are a family in mourning. I see it in everything -- the way Lady Ashworth stares at the ceiling, the way Lord Ashworth avoids the upper floors. They asked me to help their daughter. I do not think they mean medically.' She came to help. She could not. Another person who tried and failed to reach Elizabeth."
set_state = {"read_guest_ledger": true}

[sub_resource type="Resource" id="resp_ledger_sovereign"]
script = ExtResource("3")
condition = ""
title = "Guest Ledger"
text = "Helena Pierce arrived November 3rd. Her entry: 'Something extraordinary is happening in this house. The girl has abilities I have only read about in folklore. She moved a teacup across the table without touching it. Lord Ashworth calls it dangerous. I call it remarkable.' Helena was not afraid. She was fascinated. Elizabeth let her watch. Showed her things. The guest ledger was their correspondence -- Helena asked questions in ink, and the answers appeared on the next page in a child's handwriting."
set_state = {"read_guest_ledger": true}

; ADULT ledger: Helena met an adult Elizabeth
[sub_resource type="Resource" id="resp_ledger_adult"]
script = ExtResource("3")
condition = ""
title = "Guest Ledger"
text = "Helena Pierce arrived November 3rd. Her entry: 'I was told to expect a child. What I found was a young woman of perhaps twenty-three -- quiet, composed, entirely lucid. She asked me about London. She asked about the Royal Academy exhibition. She has been reading newspapers that someone leaves outside her door. Lord Ashworth still calls her \"the girl.\" She is not a girl. She is a prisoner.'\n\nHelena was the only outsider who saw the truth. The last page of the ledger has been torn out."
set_state = {"read_guest_ledger": true}

; === Bed Observation ===

[sub_resource type="Resource" id="resp_bed_default"]
script = ExtResource("3")
condition = ""
title = "Guest Bed"
text = "The bed is made but not pristine. The pillow still holds an impression. Helena slept here for seven weeks before she vanished. Her valise is open at the foot of the bed -- half unpacked, as if she planned to stay longer."

[sub_resource type="Resource" id="resp_photo_truth"]
script = ExtResource("3")
condition = "knows_full_truth"
title = "Photograph"
text = "Helena Pierce. She came for a weekend and the house kept her. The smile in the photograph belongs to someone who still believed haunted houses were subjects to be studied instead of mouths that close."
set_state = {"examined_helena_photo": true}

[sub_resource type="Resource" id="resp_photo_default"]
script = ExtResource("3")
condition = ""
title = "Photograph"
text = "A woman in traveling clothes, smiling at the camera with the confidence of someone who expects to return home and tell a story about all this. Helena Pierce before Ashworth Manor corrected that assumption."
set_state = {"examined_helena_photo": true}

[sub_resource type="Resource" id="resp_luggage_default"]
script = ExtResource("3")
condition = ""
title = "Luggage"
text = "Packed and nearly closed. One clasp is still open. Helena was preparing to leave, or pretending to. The folds inside are neat until the top layer, where everything becomes hurried and uncertain."

[sub_resource type="Resource" id="resp_lamp_default"]
script = ExtResource("3")
condition = ""
title = "Lamp"
text = "A dry oil lamp on the desk. The wick was trimmed for one more night and never lit. Helena wrote by moonlight after this. Or she stopped writing entirely."

; === Interactables ===

[sub_resource type="Resource" id="inter_ledger"]
script = ExtResource("2")
id = "guest_ledger"
type = "note"
position = Vector3(-3.5, 0.9, -3)
collision_size = Vector3(1.5, 1.5, 1.5)
responses = Array[Resource]([SubResource("resp_ledger_default")])
thread_responses = {"child": [SubResource("resp_ledger_captive")], "adult": [SubResource("resp_ledger_adult")], "elder": [SubResource("resp_ledger_sovereign")], "captive": [SubResource("resp_ledger_captive")], "mourning": [SubResource("resp_ledger_mourning")], "sovereign": [SubResource("resp_ledger_sovereign")]}

[sub_resource type="Resource" id="inter_bed"]
script = ExtResource("2")
id = "guest_bed"
type = "observation"
position = Vector3(2, 0.8, 0)
collision_size = Vector3(2.0, 1.0, 2.0)
responses = Array[Resource]([SubResource("resp_bed_default")])

[sub_resource type="Resource" id="inter_photo"]
script = ExtResource("2")
id = "helena_photo"
type = "photo"
position = Vector3(-3.5, 1.6, 0)
wall = "west"
collision_size = Vector3(0.8, 0.8, 0.4)
substrate_prop_kind = "picture_frame_blank_004"
responses = Array[Resource]([SubResource("resp_photo_truth"), SubResource("resp_photo_default")])

[sub_resource type="Resource" id="inter_luggage"]
script = ExtResource("2")
id = "guest_luggage"
type = "observation"
position = Vector3(3.0, 0.3, 2.0)
collision_size = Vector3(1.0, 0.8, 0.8)
model = "res://assets/upper_floor/guest_room/luggage_mp_1.glb"
responses = Array[Resource]([SubResource("resp_luggage_default")])

[sub_resource type="Resource" id="inter_lamp"]
script = ExtResource("2")
id = "guest_lamp"
type = "observation"
position = Vector3(3.0, 0.8, 0.0)
collision_size = Vector3(0.8, 0.8, 0.8)
model = "res://assets/upper_floor/guest_room/lamp_mx_3_off.glb"
responses = Array[Resource]([SubResource("resp_lamp_default")])

