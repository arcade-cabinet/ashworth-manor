; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_guest_room": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Guest Room"

[sub_resource type="Resource" id="act_entry_text"]
script = ExtResource("7")
show_text = "Someone tried to keep this room ready for departure long after departure stopped being possible."

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_guest_room"
once = true
trigger_id = "guest_room_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name"), SubResource("act_entry_text")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "guest_room"
room_name = "Guest Room"
floor_name = "upper_floor"
environment_preset = "upper_floor"
dimensions = Vector3(8, 2.4, 8)
is_exterior = false
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "doorway:guest_room_to_upper_hallway", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Lost in Polaroids Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_upper.wav"
reverb_bus = "Room"
footstep_surface = "wood_parquet"
spawn_position = Vector3(0, 0, -3)
spawn_rotation_y = 0.0
interactables = Array[Resource]([SubResource("inter_ledger"), SubResource("inter_bed"), SubResource("inter_photo"), SubResource("inter_luggage"), SubResource("inter_lamp")])
lights = Array[Resource]([SubResource("light_window"), SubResource("light_candle")])
props = Array[Resource]([SubResource("prop_bed"), SubResource("prop_desk"), SubResource("prop_luggage"), SubResource("prop_lamp"), SubResource("prop_photo"), SubResource("prop_bottle"), SubResource("prop_soap"), SubResource("prop_candle_holder"), SubResource("prop_candle"), SubResource("prop_rug"), SubResource("prop_chair"), SubResource("prop_openbook"), SubResource("prop_window_ray")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
