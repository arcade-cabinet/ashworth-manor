; === Entry Trigger Actions ===

[sub_resource type="Resource" id="act_set_visited"]
script = ExtResource("7")
set_state = {"visited_front_gate": true, "game_started": true}

[sub_resource type="Resource" id="act_first_entry_captive_text"]
script = ExtResource("7")
show_text = ""

[sub_resource type="Resource" id="act_first_entry_mourning_text"]
script = ExtResource("7")
show_text = ""

[sub_resource type="Resource" id="act_first_entry_sovereign_text"]
script = ExtResource("7")
show_text = ""

[sub_resource type="Resource" id="act_first_entry_gate_creak"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/gate_creak.ogg"

[sub_resource type="Resource" id="act_first_entry_sway"]
script = ExtResource("7")
camera_shake = 0.03

[sub_resource type="Resource" id="act_show_title"]
script = ExtResource("7")
show_room_name = "Ashworth Manor"

[sub_resource type="Resource" id="trig_first_entry_captive"]
script = ExtResource("6")
condition = "NOT visited_front_gate AND macro_thread == captive"
once = true
trigger_id = "front_gate_first_entry_captive"
actions = Array[Resource]([SubResource("act_first_entry_captive_text"), SubResource("act_first_entry_gate_creak"), SubResource("act_first_entry_sway")])

[sub_resource type="Resource" id="trig_first_entry_mourning"]
script = ExtResource("6")
condition = "NOT visited_front_gate AND macro_thread == mourning"
once = true
trigger_id = "front_gate_first_entry_mourning"
actions = Array[Resource]([SubResource("act_first_entry_mourning_text"), SubResource("act_first_entry_gate_creak")])

[sub_resource type="Resource" id="trig_first_entry_sovereign"]
script = ExtResource("6")
condition = "NOT visited_front_gate AND macro_thread == sovereign"
once = true
trigger_id = "front_gate_first_entry_sovereign"
actions = Array[Resource]([SubResource("act_first_entry_sovereign_text"), SubResource("act_first_entry_gate_creak"), SubResource("act_first_entry_sway")])

; === Entry Trigger ===

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_front_gate"
once = true
trigger_id = "front_gate_first_entry"
actions = Array[Resource]([SubResource("act_set_visited"), SubResource("act_show_title")])

; === Ambient Events ===

[sub_resource type="Resource" id="act_gate_creak"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/gate_creak.ogg"

[sub_resource type="Resource" id="ambient_gate_creak"]
script = ExtResource("8")
event_id = "gate_creak_ambient"
interval_min = 15.0
interval_max = 30.0
condition = ""
actions = Array[Resource]([SubResource("act_gate_creak")])

[sub_resource type="Resource" id="act_wind_gust_sfx"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/wind_gust.ogg"

[sub_resource type="Resource" id="act_wind_gust_shake"]
script = ExtResource("7")
camera_shake = 0.03

[sub_resource type="Resource" id="ambient_wind_gust"]
script = ExtResource("8")
event_id = "wind_gust"
interval_min = 20.0
interval_max = 40.0
condition = ""
actions = Array[Resource]([SubResource("act_wind_gust_sfx"), SubResource("act_wind_gust_shake")])

; === Conditional Event: Post-Attic Return ===

[sub_resource type="Resource" id="act_post_attic_flag"]
script = ExtResource("7")
set_state = {"front_gate_post_attic_triggered": true}

[sub_resource type="Resource" id="act_post_attic_light"]
script = ExtResource("7")
light_change = {"gate_lamp_light": {"energy": 4.0, "duration": 3.0}}

[sub_resource type="Resource" id="act_post_attic_whisper"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/horror/whisper_wind.ogg"

[sub_resource type="Resource" id="act_post_attic_text"]
script = ExtResource("7")
show_text = "The gate lamp burns brighter as you approach. As if greeting you. Or warning you."

[sub_resource type="Resource" id="act_threshold_ack_flag"]
script = ExtResource("7")
set_state = {"front_gate_threshold_acknowledged": true}

[sub_resource type="Resource" id="act_threshold_ack_light"]
script = ExtResource("7")
light_change = {"gate_lamp_light": {"energy": 3.4, "duration": 1.2}}

[sub_resource type="Resource" id="act_threshold_ack_sfx"]
script = ExtResource("7")
play_sfx = "gate_creak"

[sub_resource type="Resource" id="act_threshold_ack_sway"]
script = ExtResource("7")
camera_shake = 0.02

[sub_resource type="Resource" id="cond_threshold_ack"]
script = ExtResource("9")
event_id = "front_gate_threshold_ack"
condition = "front_gate_valise_opened AND NOT front_gate_threshold_acknowledged"
once = true
actions = Array[Resource]([SubResource("act_threshold_ack_flag"), SubResource("act_threshold_ack_light"), SubResource("act_threshold_ack_sfx"), SubResource("act_threshold_ack_sway")])

[sub_resource type="Resource" id="cond_post_attic"]
script = ExtResource("9")
event_id = "front_gate_post_attic"
condition = "elizabeth_aware AND NOT front_gate_post_attic_triggered"
once = true
actions = Array[Resource]([SubResource("act_post_attic_flag"), SubResource("act_post_attic_light"), SubResource("act_post_attic_whisper"), SubResource("act_post_attic_text")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "front_gate"
room_name = "Front Gate"
floor_name = "grounds"
environment_preset = "grounds"
dimensions = Vector3(34, 6, 24)
is_exterior = true
spatial_class = "exterior_ground"
exposure_faces = PackedStringArray("north", "south", "east", "west", "roof")
outlook_zones = {"north": "ceremonial_drive_continuation", "south": "village_road_twilight", "east": "tree_line_boundary", "west": "tree_line_boundary", "roof": "open_sky"}
window_view_mode = "distant_backdrop"
wall_north = PackedStringArray()
wall_south = PackedStringArray()
wall_east = PackedStringArray()
wall_west = PackedStringArray()
ambient_loop = "res://assets/audio/loops/Moonlight Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_exploration.wav"
reverb_bus = "OpenAir"
footstep_surface = "gravel"
spawn_position = Vector3(0.7, 0, -7.2)
spawn_rotation_y = 180.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_opening"), SubResource("anchor_entry_drive")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_mansion"), SubResource("anchor_focus_gate_sign")])
interactables = Array[Resource]([SubResource("inter_gate_sign_new_game"), SubResource("inter_gate_sign_load_game"), SubResource("inter_gate_sign_settings"), SubResource("inter_gate_plaque"), SubResource("inter_gate_luggage"), SubResource("inter_gate_bench"), SubResource("inter_iron_gate"), SubResource("inter_gate_lamp")])
lights = Array[Resource]([SubResource("light_moonlight"), SubResource("light_gate_lamp"), SubResource("light_village_lamp_near"), SubResource("light_village_lamp_far")])
props = Array[Resource]([SubResource("prop_gate_pillar_l"), SubResource("prop_gate_pillar_r"), SubResource("prop_gate_center"), SubResource("prop_boundary_wall"), SubResource("prop_boundary_corner"), SubResource("prop_fence"), SubResource("prop_fence_r"), SubResource("prop_road_wall_left"), SubResource("prop_road_wall_right"), SubResource("prop_main_road"), SubResource("prop_outward_road"), SubResource("prop_hedge_left_gate"), SubResource("prop_hedge_left_mid_gate"), SubResource("prop_hedge_left_near"), SubResource("prop_hedge_right_gate"), SubResource("prop_hedge_right_mid_gate"), SubResource("prop_hedge_right_near"), SubResource("prop_moon_disc"), SubResource("prop_front_gate_starfield")])
mount_slots = Array[Resource]([SubResource("mount_slot_gate_sign_anchor"), SubResource("mount_slot_gate_lamp_anchor")])
mount_payloads = Array[Resource]([SubResource("mount_payload_gate_menu_sign"), SubResource("mount_payload_gate_lamp_off")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_gate_creak"), SubResource("ambient_wind_gust")])
conditional_events = Array[Resource]([SubResource("cond_post_attic")])
flashbacks = Array[Resource]([])
