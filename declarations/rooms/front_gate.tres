[gd_resource type="Resource" script_class="RoomDeclaration" format=3]

[ext_resource type="Script" path="res://engine/declarations/room_declaration.gd" id="1"]
[ext_resource type="Script" path="res://engine/declarations/interactable_decl.gd" id="2"]
[ext_resource type="Script" path="res://engine/declarations/response_decl.gd" id="3"]
[ext_resource type="Script" path="res://engine/declarations/light_decl.gd" id="4"]
[ext_resource type="Script" path="res://engine/declarations/prop_decl.gd" id="5"]
[ext_resource type="Script" path="res://engine/declarations/trigger_decl.gd" id="6"]
[ext_resource type="Script" path="res://engine/declarations/action_decl.gd" id="7"]
[ext_resource type="Script" path="res://engine/declarations/ambient_event_decl.gd" id="8"]
[ext_resource type="Script" path="res://engine/declarations/conditional_event_decl.gd" id="9"]

; === Interactable Responses ===

[sub_resource type="Resource" id="resp_plaque_truth"]
script = ExtResource("3")
condition = "knows_full_truth"
title = "Ashworth Manor"
text = "'Abandon memory, all ye who enter.' They meant it literally. They tried to make the world forget Elizabeth existed."
set_state = {"examined_gate_plaque": true}

[sub_resource type="Resource" id="resp_plaque_default"]
script = ExtResource("3")
condition = ""
title = "Ashworth Manor"
text = "ASHWORTH MANOR — Est. 1847. The iron lettering is green with verdigris. Below, in smaller script barely legible: 'Abandon memory, all ye who enter.'"
set_state = {"examined_gate_plaque": true}

[sub_resource type="Resource" id="resp_luggage_ledger"]
script = ExtResource("3")
condition = "read_guest_ledger"
title = "Abandoned Suitcase"
text = "Helena Pierce's suitcase. She arrived November 3rd, 1891. Her departure date was left blank. Now you know why — she never left the house alive."
set_state = {"found_helena_luggage": true}

[sub_resource type="Resource" id="resp_luggage_default"]
script = ExtResource("3")
condition = ""
title = "Abandoned Suitcase"
text = "A leather traveling case, clasps still fastened. Packed but never carried beyond the gate. The luggage tag reads: 'H. Pierce — London.' The ink has run in the rain."
set_state = {"found_helena_luggage": true}

[sub_resource type="Resource" id="resp_bench_truth"]
script = ExtResource("3")
condition = "knows_full_truth"
title = "Stone Bench"
text = "The children sat here the night they fled. Charles, Margaret, William. They looked back once. None of them ever returned."

[sub_resource type="Resource" id="resp_bench_default"]
script = ExtResource("3")
condition = ""
title = "Stone Bench"
text = "Cold stone. Snow has settled in the seat — undisturbed for decades. Someone sat here once, looking at the house, deciding whether to go in."

[sub_resource type="Resource" id="resp_gate_aware"]
script = ExtResource("3")
condition = "elizabeth_aware"
title = "The Gate"
text = "The gate hangs open like a mouth. You notice now: the iron bars are bent outward. Whatever left this house was stronger than iron."
set_state = {"examined_iron_gate": true}

[sub_resource type="Resource" id="resp_gate_default"]
script = ExtResource("3")
condition = ""
title = "The Gate"
text = "Iron bars, rusted open. The lock is broken — not from outside. Someone burst through from within. The hinges scream when the wind catches them."
set_state = {"examined_iron_gate": true}

[sub_resource type="Resource" id="resp_lamp_aware"]
script = ExtResource("3")
condition = "elizabeth_aware"
title = "Gas Lamp"
text = "The lamp pulses in rhythm. You realize you've been breathing in sync with it. Since when?"

[sub_resource type="Resource" id="resp_lamp_default"]
script = ExtResource("3")
condition = ""
title = "Gas Lamp"
text = "Still lit. After over a century, the gas lamp by the gate still burns. The flame doesn't flicker like fire — it pulses, like breathing."

; === Interactables ===

[sub_resource type="Resource" id="inter_gate_plaque"]
script = ExtResource("2")
id = "gate_plaque"
type = "note"
position = Vector3(-2, 1.5, -10)
wall = "south"
collision_size = Vector3(1.5, 1.5, 1.5)
responses = Array[Resource]([SubResource("resp_plaque_truth"), SubResource("resp_plaque_default")])

[sub_resource type="Resource" id="inter_gate_luggage"]
script = ExtResource("2")
id = "gate_luggage"
type = "observation"
position = Vector3(4, 0.3, -7)
collision_size = Vector3(1.5, 1.0, 1.0)
model = "res://assets/grounds/front_gate/luggage_mp_1.glb"
responses = Array[Resource]([SubResource("resp_luggage_ledger"), SubResource("resp_luggage_default")])

[sub_resource type="Resource" id="inter_gate_bench"]
script = ExtResource("2")
id = "gate_bench"
type = "observation"
position = Vector3(5, 0.5, -5)
collision_size = Vector3(2.0, 1.0, 1.0)
model = "res://assets/grounds/front_gate/bench_mx_1.glb"
responses = Array[Resource]([SubResource("resp_bench_truth"), SubResource("resp_bench_default")])

[sub_resource type="Resource" id="inter_iron_gate"]
script = ExtResource("2")
id = "iron_gate"
type = "observation"
position = Vector3(0, 1.5, -10)
collision_size = Vector3(3.0, 3.0, 1.0)
model = "res://assets/grounds/front_gate/iron_gate.glb"
responses = Array[Resource]([SubResource("resp_gate_aware"), SubResource("resp_gate_default")])

[sub_resource type="Resource" id="inter_gate_lamp"]
script = ExtResource("2")
id = "gate_lamp"
type = "observation"
position = Vector3(-4, 2.5, -10)
collision_size = Vector3(1.0, 2.0, 1.0)
model = "res://assets/grounds/front_gate/lamp_mx_1_b_on.glb"
responses = Array[Resource]([SubResource("resp_lamp_aware"), SubResource("resp_lamp_default")])

; === Lights ===

[sub_resource type="Resource" id="light_moonlight"]
script = ExtResource("4")
id = "moonlight"
type = "directional"
position = Vector3(0, 0, 0)
color = Color(0.6, 0.65, 0.85, 1)
energy = 1.5
range = 0.0
shadows = true
flickering = false

[sub_resource type="Resource" id="light_gate_lamp"]
script = ExtResource("4")
id = "gate_lamp_light"
type = "omni"
position = Vector3(-4, 3, -10)
color = Color(1.0, 0.85, 0.5, 1)
energy = 2.5
range = 10.0
shadows = false
flickering = true
flicker_pattern = "gas"

