; === Interactable Responses ===

[sub_resource type="Resource" id="resp_plaque_truth"]
script = ExtResource("3")
condition = "knows_full_truth"
title = "Ashworth Manor"
text = "'Abandon memory, all ye who enter.' They meant it literally. They tried to make the world forget Elizabeth existed."
set_state = {"examined_gate_plaque": true}

[sub_resource type="Resource" id="resp_plaque_default"]
script = ExtResource("3")
condition = ""
title = "Ashworth Manor"
text = "ASHWORTH MANOR -- Est. 1847. The brass has gone dark with weather, but the lettering is still exact. It reads like an estate marker, not a welcome."
set_state = {"examined_gate_plaque": true}

[sub_resource type="Resource" id="resp_plaque_captive"]
script = ExtResource("3")
condition = ""
title = "Ashworth Manor"
text = "ASHWORTH MANOR -- Est. 1847. The plaque hangs like a warning plate on a cell door. 'Abandon memory, all ye who enter.' Not invitation. Instruction. This is a place built to keep truths locked up until they stop sounding human."
set_state = {"examined_gate_plaque": true}

[sub_resource type="Resource" id="resp_plaque_mourning"]
script = ExtResource("3")
condition = ""
title = "Ashworth Manor"
text = "ASHWORTH MANOR -- Est. 1847. Verdigris has softened every letter, as if even the metal has been grieving. 'Abandon memory, all ye who enter.' The house does not threaten. It laments."
set_state = {"examined_gate_plaque": true}

[sub_resource type="Resource" id="resp_plaque_sovereign"]
script = ExtResource("3")
condition = ""
title = "Ashworth Manor"
text = "ASHWORTH MANOR -- Est. 1847. The green-black iron seems damp though no rain falls. 'Abandon memory, all ye who enter.' The plaque reads less like a motto than a command from the thing that now speaks through the estate."
set_state = {"examined_gate_plaque": true}

[sub_resource type="Resource" id="resp_luggage_ledger"]
script = ExtResource("3")
condition = "read_guest_ledger"
title = "Travel Valise"
text = "Your valise, left neatly beneath the sign by the departing driver. The packet is inside, along with the key and a few small necessities."
set_state = {"front_gate_valise_opened": true}

[sub_resource type="Resource" id="resp_luggage_default"]
script = ExtResource("3")
condition = ""
title = "Travel Valise"
text = "A leather travelling valise with the dust of the station still on it. The driver has left it beneath the sign, close enough to your hand that ignoring it would be a decision."
set_state = {"front_gate_valise_opened": true}

[sub_resource type="Resource" id="resp_bench_truth"]
script = ExtResource("3")
condition = "knows_full_truth"
title = "Stone Bench"
text = "The children sat here the night they fled. Charles, Margaret, William. They looked back once. None of them ever returned."

[sub_resource type="Resource" id="resp_bench_default"]
script = ExtResource("3")
condition = ""
title = "Stone Bench"
text = "Cold stone. Snow has settled in the seat -- undisturbed for decades. Someone sat here once, looking at the house, deciding whether to go in."

[sub_resource type="Resource" id="resp_gate_aware"]
script = ExtResource("3")
condition = "elizabeth_aware"
title = "The Gate"
text = "The gate hangs open like a mouth. You notice now: the iron bars are bent outward. Whatever left this house was stronger than iron."
set_state = {"examined_iron_gate": true}

[sub_resource type="Resource" id="resp_gate_default"]
script = ExtResource("3")
condition = ""
title = "The Gate"
text = "The gate stands open on tired hinges. The lock hasp has been forced from the stone at some point -- whether by weather, by hand, or simply by time is impossible to say now. Nobody has come to close it."
set_state = {"examined_iron_gate": true}

[sub_resource type="Resource" id="resp_gate_captive"]
script = ExtResource("3")
condition = ""
title = "The Gate"
text = "The broken lock tells the story plainly: something imprisoned here pushed against the bars until iron gave way. The gate is not an entrance feature. It is evidence."
set_state = {"examined_iron_gate": true}

[sub_resource type="Resource" id="resp_gate_mourning"]
script = ExtResource("3")
condition = ""
title = "The Gate"
text = "The gate has been left open too long. Not flung wide in triumph. Left. Forgotten in the confusion after something terrible no one could undo. Even the hinges sound tired."
set_state = {"examined_iron_gate": true}

[sub_resource type="Resource" id="resp_gate_sovereign"]
script = ExtResource("3")
condition = ""
title = "The Gate"
text = "The bars bow outward as though the house exhaled through them. The iron did not fail from neglect. It yielded to a force that had already decided this threshold belonged to it."
set_state = {"examined_iron_gate": true}

[sub_resource type="Resource" id="resp_lamp_aware"]
script = ExtResource("3")
condition = "elizabeth_aware"
title = "Gas Lamp"
text = "The lamp pulses in rhythm. You realize you've been breathing in sync with it. Since when?"

[sub_resource type="Resource" id="resp_lamp_default"]
script = ExtResource("3")
condition = ""
title = "Gas Lamp"
text = "One gate lamp still burns. The brass is streaked by weather, the glass clouded with soot, but the flame itself is steady enough to prove the place was maintained until recently."

[sub_resource type="Resource" id="resp_lamp_captive"]
script = ExtResource("3")
condition = ""
title = "Gas Lamp"
text = "The lamp keeps watch like a gaoler who never sleeps. Its pulse is too steady to be gas pressure and too patient to be weather. Something at the gate is keeping vigil."

[sub_resource type="Resource" id="resp_lamp_mourning"]
script = ExtResource("3")
condition = ""
title = "Gas Lamp"
text = "The old lamp burns with the weak persistence of a memorial candle. Not bright enough to guide, only enough to remember. It feels less like illumination than mourning made visible."

[sub_resource type="Resource" id="resp_lamp_sovereign"]
script = ExtResource("3")
condition = ""
title = "Gas Lamp"
text = "The flame breathes. Not metaphorically. Deliberately. The pressure rises and falls in a rhythm too intimate to ignore, as if the house has lungs and this is one of its visible breaths."

