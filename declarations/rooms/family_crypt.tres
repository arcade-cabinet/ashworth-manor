[gd_resource type="Resource" script_class="RoomDeclaration" format=3]

[ext_resource type="Script" path="res://engine/declarations/room_declaration.gd" id="1"]
[ext_resource type="Script" path="res://engine/declarations/interactable_decl.gd" id="2"]
[ext_resource type="Script" path="res://engine/declarations/response_decl.gd" id="3"]
[ext_resource type="Script" path="res://engine/declarations/light_decl.gd" id="4"]
[ext_resource type="Script" path="res://engine/declarations/prop_decl.gd" id="5"]
[ext_resource type="Script" path="res://engine/declarations/trigger_decl.gd" id="6"]
[ext_resource type="Script" path="res://engine/declarations/action_decl.gd" id="7"]

; === Crypt Graves Responses ===

[sub_resource type="Resource" id="resp_graves_default"]
script = ExtResource("3")
condition = ""
title = "Ashworth Graves"
text = "Stone markers for the Ashworth family. Edmund, Victoria, four children. But only four markers for five children. Elizabeth has no grave. No marker. No record that she lived or died. She was erased from the family even in death."
set_state = {"examined_crypt_graves": true}

[sub_resource type="Resource" id="resp_graves_captive"]
script = ExtResource("3")
condition = ""
title = "Ashworth Graves"
text = "Four children's graves. Five children lived. The missing grave is the loudest absence in the crypt. No stone for Elizabeth because a prisoner does not get a headstone. You do not bury what you have locked away. You do not memorialize what you have tried to erase. The empty space between the fourth and fifth markers is exactly the width of a child's grave."
set_state = {"examined_crypt_graves": true}

[sub_resource type="Resource" id="resp_graves_mourning"]
script = ExtResource("3")
condition = ""
title = "Ashworth Graves"
text = "Four children's graves. The missing fifth marker has been replaced with something else -- a small stone, smooth, river-washed, placed at ground level. No name carved on it. But a lily grows from a crack beside it. White. Fresh. Alive. Victoria planted it. The grave they could not give Elizabeth in stone, Victoria gave her in flower. It has bloomed every year since."
set_state = {"examined_crypt_graves": true}

[sub_resource type="Resource" id="resp_graves_sovereign"]
script = ExtResource("3")
condition = ""
title = "Ashworth Graves"
text = "Four children's graves. The missing fifth space is not empty. Something is growing from the soil -- not a plant, not a flower. Roots. Thick, dark roots that spread from the empty grave into the stone of the crypt itself. They crack the mortar between the floor stones. They climb the walls. The roots are the house. Elizabeth extended herself into the crypt, into the ground, into the foundations. She does not need a grave. She IS the ground."
set_state = {"examined_crypt_graves": true}

; === Flagstone (Diamond #4 A-path) ===

[sub_resource type="Resource" id="resp_flagstone_default"]
script = ExtResource("3")
condition = ""
title = "Loose Flagstone"
text = "One flagstone near Victoria's grave is loose. It rocks when you step on it. Something is beneath it -- a hollow space. A small gap visible at the edge. This was hidden deliberately."

; === Interactables ===

[sub_resource type="Resource" id="inter_graves"]
script = ExtResource("2")
id = "crypt_graves"
type = "observation"
position = Vector3(0, 0.5, 0)
collision_size = Vector3(3.0, 1.0, 3.0)
responses = Array[Resource]([SubResource("resp_graves_default")])
thread_responses = {"captive": [SubResource("resp_graves_captive")], "mourning": [SubResource("resp_graves_mourning")], "sovereign": [SubResource("resp_graves_sovereign")]}

[sub_resource type="Resource" id="inter_flagstone"]
script = ExtResource("2")
id = "crypt_flagstone"
type = "observation"
position = Vector3(-2, 0.1, 2)
collision_size = Vector3(1.0, 0.5, 1.0)
responses = Array[Resource]([SubResource("resp_flagstone_default")])

; === Lights ===

[sub_resource type="Resource" id="light_moonlight"]
script = ExtResource("4")
id = "crypt_moonlight"
type = "omni"
position = Vector3(0, 2, 0)
color = Color(0.5, 0.6, 0.9, 1)
energy = 0.6
range = 6.0
shadows = true
flickering = false

; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_family_crypt": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Family Crypt"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_family_crypt"
once = true
trigger_id = "crypt_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "family_crypt"
room_name = "Family Crypt"
floor_name = "grounds"
environment_preset = "grounds"
dimensions = Vector3(8, 3, 10)
is_exterior = true
wall_texture = "wall6_texture"
floor_texture = "floor2_texture"
ceiling_texture = ""
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Empty Hope Loop2.ogg"
tension_loop = "res://assets/audio/tension/tension_exploration.wav"
reverb_bus = "StoneCorridor"
footstep_surface = "stone"
spawn_position = Vector3(0, 0, -4)
spawn_rotation_y = 0.0
interactables = Array[Resource]([SubResource("inter_graves"), SubResource("inter_flagstone")])
lights = Array[Resource]([SubResource("light_moonlight")])
props = Array[Resource]([])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
