[sub_resource type="Resource" id="anchor_entry_gate"]
script = ExtResource("8")
anchor_id = "entry_gate"
anchor_type = "entry"
position = Vector3(0.0, 0.0, -3.15)
rotation_y = 0.0
target_anchor_id = "focus_blank_grave"
tags = PackedStringArray("critical_path", "elder_route")

[sub_resource type="Resource" id="anchor_focus_blank_grave"]
script = ExtResource("8")
anchor_id = "focus_blank_grave"
anchor_type = "focal"
position = Vector3(1.55, 0.72, 1.25)
rotation_y = 0.0
tags = PackedStringArray("critical_path", "burial_truth")

; === Crypt Graves Responses ===

[sub_resource type="Resource" id="resp_graves_default"]
script = ExtResource("3")
condition = ""
title = "Ashworth Graves"
text = "Stone markers for the Ashworth family. Edmund, Victoria, four children. But only four markers for five children. Elizabeth has no grave. No marker. No record that she lived or died. She was erased from the family even in death."
set_state = {"examined_crypt_graves": true}

[sub_resource type="Resource" id="resp_graves_captive"]
script = ExtResource("3")
condition = ""
title = "Ashworth Graves"
text = "Four children's graves. Five children lived. The missing grave is the loudest absence in the crypt. No stone for Elizabeth because a prisoner does not get a headstone. You do not bury what you have locked away. You do not memorialize what you have tried to erase. The empty space between the fourth and fifth markers is exactly the width of a child's grave."
set_state = {"examined_crypt_graves": true}

[sub_resource type="Resource" id="resp_graves_mourning"]
script = ExtResource("3")
condition = ""
title = "Ashworth Graves"
text = "Four children's graves. The missing fifth marker has been replaced with something else -- a small stone, smooth, river-washed, placed at ground level. No name carved on it. But a lily grows from a crack beside it. White. Fresh. Alive. Victoria planted it. The grave they could not give Elizabeth in stone, Victoria gave her in flower. It has bloomed every year since."
set_state = {"examined_crypt_graves": true}

[sub_resource type="Resource" id="resp_graves_sovereign"]
script = ExtResource("3")
condition = ""
title = "Ashworth Graves"
text = "Four children's graves. The fifth place has been altered over and over: fresh mortar under old stone, layers of candle wax, dates scratched and recut until the surface turned smooth. No single memorial would hold. Someone kept trying to prepare a grave for Elizabeth as the years went on and she kept outliving every version of it."
set_state = {"examined_crypt_graves": true}

; === Flagstone (Diamond #4 A-path) ===

[sub_resource type="Resource" id="resp_flagstone_default"]
script = ExtResource("3")
condition = ""
title = "Loose Flagstone"
text = "One flagstone near Victoria's grave is loose. It rocks when you step on it. Something is beneath it -- a hollow space. A small gap visible at the edge. This was hidden deliberately."

[sub_resource type="Resource" id="resp_note_default"]
script = ExtResource("3")
condition = ""
title = "Lady Ashworth's Note"
text = "I hid the locket key here because I could not bear to keep it in the house where she would hear it turn in the lock. If there is mercy left in God, let it fall first on Elizabeth and only then on the rest of us.\n\nThe paper is damp and half-rotted, but the hand is Victoria's."
set_state = {"found_crypt_note": true}

[sub_resource type="Resource" id="resp_bones_default"]
script = ExtResource("3")
condition = ""
title = "Scattered Bones"
text = "Bones lie outside the graves instead of within them. The crypt gate was locked. No animal did this. Something with purpose crossed the threshold and disturbed what should have remained sealed."

[sub_resource type="Resource" id="resp_gate_latch_done"]
script = ExtResource("3")
condition = "crypt_gate_unlocked"
title = "Gate Latch"
text = "The inner latch hangs loose where you dragged it free. The crypt gate can no longer pretend to be sealed."

[sub_resource type="Resource" id="resp_gate_latch_with_hook"]
script = ExtResource("3")
condition = "HAS lantern_hook"
title = "Gate Latch"
text = "The latch is mounted just beyond the bars, too far for a hand but not for the iron hook. You catch it, drag it upward, and feel the old weight give with a wet metallic crack. Whatever was kept shut here was being kept shut from the wrong side."
set_state = {"crypt_gate_unlocked": true}

[sub_resource type="Resource" id="resp_gate_latch_default"]
script = ExtResource("3")
condition = ""
title = "Gate Latch"
text = "An inner latch sits beyond the bars where the family could work it from within. It is too far to reach bare-handed. Someone expected service tools, not mourners."

[sub_resource type="Resource" id="resp_music_box_wound"]
script = ExtResource("3")
condition = "elder_music_box_wound"
title = "Elizabeth's Music Box"
text = "The melody lingers against the crypt stones long after the mechanism should have spent itself. The box sits open beside the grave, as if it had been waiting for witness rather than rescue."

[sub_resource type="Resource" id="resp_music_box_need_gate"]
script = ExtResource("3")
condition = "NOT crypt_gate_unlocked"
title = "Elizabeth's Music Box"
text = "Something glints beyond the old gate, tucked into the recessed shelf beside the blank grave. You can see brass fittings, but the crypt still holds them at a distance."

[sub_resource type="Resource" id="resp_music_box_no_key"]
script = ExtResource("3")
condition = "NOT has_music_box_winding_key"
title = "Elizabeth's Music Box"
text = "The box is here at last, wrapped in blackened velvet beside the grave that never held her. The keyhole is empty. You still need the little brass key from your valise."

[sub_resource type="Resource" id="resp_music_box_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Music Box"
text = "The brass winding key turns without resistance, as if the mechanism has been waiting in readiness all these years. The tune that failed in the attic completes itself here in the crypt.\n\nElizabeth Ashworth did not vanish young. She lived on into old age while the house, the cellar, and the family records kept trying to settle her into death. The crypt became another room of maintenance. Another place someone kept in readiness for a burial that never answered the truth.\n\nThe final notes do not plead. They accuse. They hold every year the family tried to close around her and failed.\n\nWhen the melody ends, the crypt sounds larger, emptier, and honest for the first time."
set_state = {"elder_music_box_wound": true, "elder_route_complete": true}
play_sfx = "res://assets/audio/sfx/music_box/music_box_melody_01.ogg"

; === Interactables ===

[sub_resource type="Resource" id="inter_graves"]
script = ExtResource("2")
id = "crypt_graves"
type = "observation"
position = Vector3(0, 0.5, 0)
collision_size = Vector3(3.0, 1.0, 3.0)
responses = Array[Resource]([SubResource("resp_graves_default")])
thread_responses = {"child": [SubResource("resp_graves_captive")], "adult": [SubResource("resp_graves_mourning")], "elder": [SubResource("resp_graves_sovereign")], "captive": [SubResource("resp_graves_captive")], "mourning": [SubResource("resp_graves_mourning")], "sovereign": [SubResource("resp_graves_sovereign")]}

