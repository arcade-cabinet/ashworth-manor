; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "family_crypt"
room_name = "Family Crypt"
floor_name = "grounds"
environment_preset = "crypt_candle"
dimensions = Vector3(8, 3, 10)
is_exterior = true
spatial_class = "exterior_ground"
exposure_faces = PackedStringArray("north", "south", "east", "west")
window_view_mode = "local_outlook"
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Empty Hope Loop2.ogg"
tension_loop = "res://assets/audio/tension/tension_exploration.wav"
reverb_bus = "StoneCorridor"
footstep_surface = "stone"
spawn_position = Vector3(0, 0, -3.1)
spawn_rotation_y = 0.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_gate")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_blank_grave")])
interactables = Array[Resource]([SubResource("inter_graves"), SubResource("inter_flagstone"), SubResource("inter_note"), SubResource("inter_bones"), SubResource("inter_gate_latch"), SubResource("inter_music_box")])
lights = Array[Resource]([SubResource("light_grave_candle"), SubResource("light_gate_candle"), SubResource("light_grave_bounce"), SubResource("light_side_candle_w"), SubResource("light_side_candle_e")])
props = Array[Resource]([SubResource("prop_gate"), SubResource("prop_gate_column_l"), SubResource("prop_gate_column_r"), SubResource("prop_wall_n"), SubResource("prop_wall_w"), SubResource("prop_wall_e"), SubResource("prop_fence_w"), SubResource("prop_fence_e"), SubResource("prop_grave_edmund"), SubResource("prop_grave_victoria"), SubResource("prop_grave_blank"), SubResource("prop_debris_l"), SubResource("prop_debris_r"), SubResource("prop_bottle"), SubResource("prop_scattered_bones"), SubResource("prop_grave_candle_holder"), SubResource("prop_grave_candle"), SubResource("prop_gate_candle_holder"), SubResource("prop_gate_candle"), SubResource("prop_side_candle_holder_w"), SubResource("prop_side_candle_w"), SubResource("prop_side_candle_holder_e"), SubResource("prop_side_candle_e"), SubResource("prop_music_box_cloth")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
