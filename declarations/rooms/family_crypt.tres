; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "family_crypt"
room_name = "Family Crypt"
floor_name = "grounds"
environment_preset = "grounds"
dimensions = Vector3(8, 3, 10)
is_exterior = true
wall_texture = "wall6_texture"
floor_texture = "floor2_texture"
ceiling_texture = ""
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Empty Hope Loop2.ogg"
tension_loop = "res://assets/audio/tension/tension_exploration.wav"
reverb_bus = "StoneCorridor"
footstep_surface = "stone"
spawn_position = Vector3(0, 0, -4)
spawn_rotation_y = 0.0
interactables = Array[Resource]([SubResource("inter_graves"), SubResource("inter_flagstone"), SubResource("inter_note"), SubResource("inter_bones")])
lights = Array[Resource]([SubResource("light_moonlight"), SubResource("light_grave_candle")])
props = Array[Resource]([SubResource("prop_gate"), SubResource("prop_gate_column_l"), SubResource("prop_gate_column_r"), SubResource("prop_wall_n"), SubResource("prop_wall_w"), SubResource("prop_wall_e"), SubResource("prop_fence_w"), SubResource("prop_fence_e"), SubResource("prop_grave_edmund"), SubResource("prop_grave_victoria"), SubResource("prop_grave_blank"), SubResource("prop_debris_l"), SubResource("prop_debris_r"), SubResource("prop_bottle"), SubResource("prop_scattered_bones"), SubResource("prop_grave_candle_holder"), SubResource("prop_grave_candle")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
