[sub_resource type="Resource" id="anchor_entry_stairwell"]
script = ExtResource("11")
anchor_id = "entry_stairwell"
anchor_type = "entry"
position = Vector3(0.0, 0.0, -4.8)
rotation_y = 0.0
target_anchor_id = "focus_doll_corner"
tags = PackedStringArray("critical_path", "attic")

[sub_resource type="Resource" id="anchor_focus_doll_corner"]
script = ExtResource("11")
anchor_id = "focus_doll_corner"
anchor_type = "focal"
position = Vector3(-2.0, 1.0, 4.0)
rotation_y = 0.0
tags = PackedStringArray("critical_path", "doll")

; === Elizabeth Portrait Responses ===

[sub_resource type="Resource" id="resp_portrait_truth"]
script = ExtResource("3")
condition = "knows_full_truth"
title = "Elizabeth's Portrait"
text = "Elizabeth Ashworth, age seven. Painted the year before they locked her away. She looks directly at you. Not at the painter -- at YOU. Across a century. She knew someone would come."
set_state = {"examined_elizabeth_portrait": true}

[sub_resource type="Resource" id="resp_portrait_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Portrait"
text = "A small portrait propped against the wall. A girl of six or seven with dark eyes too large for her face. She looks directly at the viewer. The paint is still bright -- no yellowing, no cracking. As if it were painted yesterday."
set_state = {"examined_elizabeth_portrait": true}

; Portrait thread variants
[sub_resource type="Resource" id="resp_portrait_captive"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Portrait"
text = "A small portrait propped against the wall. Elizabeth, age seven. Her hands are at her sides but her fingers are curled -- not relaxed, tense. As if she is gripping something invisible. Or as if someone told her to hold still and she is obeying only because she has to. The frame has scratch marks on the inside. She tried to get out of the painting too."
set_state = {"examined_elizabeth_portrait": true}

[sub_resource type="Resource" id="resp_portrait_mourning"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Portrait"
text = "A small portrait propped against the wall. Elizabeth, age seven. She is smiling in this one -- a real smile, gap-toothed and guileless. Before everything. Before the attic, before the lock, before she stopped being a child. Someone placed a dried white lily at the base of the frame. Victoria. She visited this portrait when she could not visit her daughter."
set_state = {"examined_elizabeth_portrait": true}

[sub_resource type="Resource" id="resp_portrait_sovereign"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Portrait"
text = "A small portrait propped against the wall. Elizabeth, age seven. Her eyes are wrong for a child -- too steady, too focused, too aware. The painter captured something the family preferred not to see. She was already different. Already watching. Already understanding things a seven-year-old should not understand. The portrait does not age because she does not let it."
set_state = {"examined_elizabeth_portrait": true}

; === Doll Responses (A-path active, B-path static) ===

[sub_resource type="Resource" id="resp_doll_letter"]
script = ExtResource("3")
condition = "read_elizabeth_letter"
title = "Porcelain Doll"
text = "The letter said Elizabeth talked to this doll. You pick it up carefully. Something shifts inside -- a small weight, metallic. You turn the doll over. A seam in the porcelain back. You press it. The hidden key drops into your hand."
set_state = {"found_hidden_key_doll": true}
gives_item = "hidden_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="resp_doll_default"]
script = ExtResource("3")
condition = ""
title = "Porcelain Doll"
text = "A porcelain doll in a white dress, seated on a child's chair. The painted eyes are wide and unblinking. The porcelain is cold. One hand is extended as if reaching for something. The dress has tiny embroidered flowers. Someone made this with care."

; Doll thread variants
[sub_resource type="Resource" id="resp_doll_captive"]
script = ExtResource("3")
condition = ""
title = "Porcelain Doll"
text = "A porcelain doll in a white dress. She sits in a child's chair facing the locked door. Waiting. Her painted eyes are fixed on the exit. The porcelain is cold but the chair beneath her is warm -- body warmth, as if someone was just sitting here. The doll is a vessel. Elizabeth was bound into it. The book described how. The key to undo it is somewhere inside."

[sub_resource type="Resource" id="resp_doll_mourning"]
script = ExtResource("3")
condition = ""
title = "Porcelain Doll"
text = "A porcelain doll in a white dress. She sits in a child's chair by the window. Positioned to see the garden below, the trees, the sky -- the world Elizabeth could not reach. The doll's painted cheeks have two faint trails where something wet ran down the porcelain. Not paint. Not water. Elizabeth held this doll and wept into it. It kept her tears."

[sub_resource type="Resource" id="resp_doll_sovereign"]
script = ExtResource("3")
condition = ""
title = "Porcelain Doll"
text = "A porcelain doll in a white dress. She sits in a child's chair in the center of the room, facing you. Not the door. Not the window. You. She knew you would come from that direction. The doll is a decoy. A distraction. Elizabeth let everyone think she was bound in the doll because it was easier than explaining what she had actually become. The real vessel is all around you."

; === Elizabeth Letter Responses ===

[sub_resource type="Resource" id="resp_letter_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Letter"
text = "A folded letter in a child's trunk, tucked between layers of clothing too small for an adult. The paper is thin, the ink faded but legible. Addressed to 'Mama.' Never sent. Never read."
set_state = {"read_elizabeth_letter": true, "elizabeth_aware": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

; Letter thread variants -- the actual text comes from MacroThread.elizabeth_letter_text
; These set the same flags but frame the discovery differently
[sub_resource type="Resource" id="resp_letter_captive"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Letter"
text = "A folded letter shoved into a crack in the floorboards. Hidden -- not in the trunk, not with her things, but in the structure of the room itself. As if she knew they would search her belongings. She hid this letter the way a prisoner hides a message: in the walls of her cell. Addressed to 'Mama.' The first line: 'I can hear you crying through the floor.'"
set_state = {"read_elizabeth_letter": true, "elizabeth_aware": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

[sub_resource type="Resource" id="resp_letter_mourning"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Letter"
text = "A folded letter resting on the pillow of a small cot. Placed there deliberately, as if she expected someone to come and find it eventually. The paper is soft from being folded and unfolded many times -- she read her own letter to her mother, over and over, knowing it would never be sent. Addressed to 'Mama.' The first line: 'I found your mourning dress in the trunk today.'"
set_state = {"read_elizabeth_letter": true, "elizabeth_aware": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

[sub_resource type="Resource" id="resp_letter_sovereign"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Letter"
text = "A folded letter sitting on top of the trunk, in plain sight, as if placed there moments ago. The paper is pristine -- no dust, no yellowing, no aging. She preserved it. She wanted you to read it. This is not a hidden message. This is a prepared statement. Addressed to 'Mama.' The first line: 'I want to explain something and I do not know if words are enough.'"
set_state = {"read_elizabeth_letter": true, "elizabeth_aware": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

; === Mask Responses (B-path active, A-path static) ===

[sub_resource type="Resource" id="resp_mask_default"]
script = ExtResource("3")
condition = ""
title = "Ritual Mask"
text = "A wooden mask hanging on the wall. Carved features -- not human, not animal. Something between. The eye holes are too large, the mouth too wide. It looks like it was made to see more and speak louder than a human face can."

[sub_resource type="Resource" id="resp_window_default"]
script = ExtResource("3")
condition = ""
title = "Attic Window"
text = "The window looks down across the rear grounds. Bare hedges, dead beds, the garden wall. One pale lily still stands against the winter. Elizabeth must have watched that single living thing the way prisoners watch a keyhole."

[sub_resource type="Resource" id="resp_trunk_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Trunk"
text = "A child's trunk with carefully folded clothes inside. A nightgown. A ribbon. A drawing of a family with four children holding hands. The paper is creased from being opened and refolded until the corners went soft."

; === Interactables ===

[sub_resource type="Resource" id="inter_portrait"]
script = ExtResource("2")
id = "elizabeth_portrait"
type = "painting"
position = Vector3(-6, 2, 0)
wall = "west"
collision_size = Vector3(1.5, 1.5, 1.5)
model = "res://assets/shared/decor/picture_blank.glb"
responses = Array[Resource]([SubResource("resp_portrait_truth"), SubResource("resp_portrait_default")])
thread_responses = {"captive": [SubResource("resp_portrait_captive")], "mourning": [SubResource("resp_portrait_mourning")], "sovereign": [SubResource("resp_portrait_sovereign")]}

