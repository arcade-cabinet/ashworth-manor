; === Elizabeth Portrait Responses ===

[sub_resource type="Resource" id="resp_portrait_truth"]
script = ExtResource("3")
condition = "knows_full_truth"
title = "Elizabeth's Portrait"
text = "Elizabeth Ashworth, age seven. Painted the year before they locked her away. She looks directly at you. Not at the painter -- at YOU. Across a century. She knew someone would come."
set_state = {"examined_elizabeth_portrait": true}

[sub_resource type="Resource" id="resp_portrait_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Portrait"
text = "A small portrait propped against the wall. A girl of six or seven with dark eyes too large for her face. She looks directly at the viewer. The paint is still bright -- no yellowing, no cracking. As if it were painted yesterday."
set_state = {"examined_elizabeth_portrait": true}

; Portrait thread variants
[sub_resource type="Resource" id="resp_portrait_captive"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Portrait"
text = "A small portrait propped against the wall. Elizabeth, age seven. Damp has started to lift the canvas at the corners, but the child remains untouched -- held in the same year forever. Someone hid the frame behind attic clutter instead of burning it. The portrait was not destroyed. It was put away when the wall beside it was sealed."
set_state = {"examined_elizabeth_portrait": true}

[sub_resource type="Resource" id="resp_portrait_mourning"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Portrait"
text = "A small portrait propped against the wall. Elizabeth, age seven. She is smiling in this one -- a real smile, gap-toothed and guileless. Before everything. Before the attic, before the lock, before she stopped being a child. Someone placed a dried white lily at the base of the frame. Victoria. She visited this portrait when she could not visit her daughter."
set_state = {"examined_elizabeth_portrait": true}

[sub_resource type="Resource" id="resp_portrait_sovereign"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Portrait"
text = "A small portrait propped against the wall. Elizabeth, age seven. Her eyes are wrong for a child -- too steady, too focused, too aware. The painter captured something the family preferred not to see. She was already different. Already watching. Already understanding things a seven-year-old should not understand. The portrait does not age because she does not let it."
set_state = {"examined_elizabeth_portrait": true}

; ADULT portrait: a self-portrait of adult Elizabeth
[sub_resource type="Resource" id="resp_portrait_adult"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Portrait"
text = "Not a childhood portrait. A self-portrait. The technique is amateur but practiced -- the work of someone who taught herself over years. The face is a woman of twenty-three: sharp cheekbones, dark eyes steady with intelligence, hair pinned up in an adult arrangement. She painted herself as the woman she became, using paints she acquired from the household supplies over more than a decade. The canvas is the back of a landscape painting she pried from its frame."
set_state = {"examined_elizabeth_portrait": true}

; === Doll Responses (A-path active, B-path static) ===

[sub_resource type="Resource" id="resp_doll_letter"]
script = ExtResource("3")
condition = "read_elizabeth_letter"
title = "Porcelain Doll"
text = "The letter said Elizabeth talked to this doll. You pick it up carefully. Something shifts inside -- a small weight, metallic. You turn the doll over. A seam in the porcelain back. You press it. The hidden key drops into your hand."
set_state = {"found_hidden_key_doll": true}
gives_item = "hidden_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="resp_doll_default"]
script = ExtResource("3")
condition = ""
title = "Porcelain Doll"
text = "A porcelain doll in a white dress, seated on a child's chair. The painted eyes are wide and unblinking. The porcelain is cold. One hand is extended as if reaching for something. The dress has tiny embroidered flowers. Someone made this with care."

; Doll thread variants
[sub_resource type="Resource" id="resp_doll_captive"]
script = ExtResource("3")
condition = ""
title = "Porcelain Doll"
text = "A porcelain doll in a white dress. One porcelain cheek is worn clean where a thumb stroked it over and over. This was not a vessel. It was comfort. The seam in the back is too neat to be accidental. Someone trusted the doll more than any lock in this house."

[sub_resource type="Resource" id="resp_doll_mourning"]
script = ExtResource("3")
condition = ""
title = "Porcelain Doll"
text = "A porcelain doll in a white dress. She sits in a child's chair by the window. Positioned to see the garden below, the trees, the sky -- the world Elizabeth could not reach. The doll's painted cheeks have two faint trails where something wet ran down the porcelain. Not paint. Not water. Elizabeth held this doll and wept into it. It kept her tears."

[sub_resource type="Resource" id="resp_doll_sovereign"]
script = ExtResource("3")
condition = ""
title = "Porcelain Doll"
text = "A porcelain doll in a white dress. She sits in a child's chair in the center of the room, facing you. Not the door. Not the window. You. She knew you would come from that direction. The doll is a decoy. A distraction. Elizabeth let everyone think she was bound in the doll because it was easier than explaining what she had actually become. The real vessel is all around you."

; === Elizabeth Letter Responses ===

[sub_resource type="Resource" id="resp_letter_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Letter"
text = "A folded letter in a child's trunk, tucked between layers of clothing too small for an adult. The paper is thin, the ink faded but legible. Addressed to 'Mama.' Never sent. Never read."
set_state = {"read_elizabeth_letter": true, "elizabeth_aware": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

; Letter thread variants -- the actual text comes from MacroThread.elizabeth_letter_text
; These set the same flags but frame the discovery differently
[sub_resource type="Resource" id="resp_letter_captive"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Letter"
text = "A folded letter tucked between the trunk lid and its lining, where only a child packing her own things would think to hide it. The handwriting is young and careful. Addressed to 'Mama.' The first line: 'I heard them hammering on the wall again today.'"
set_state = {"read_elizabeth_letter": true, "elizabeth_aware": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

[sub_resource type="Resource" id="resp_letter_mourning"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Letter"
text = "A folded letter resting on the pillow of a small cot. Placed there deliberately, as if she expected someone to come and find it eventually. The paper is soft from being folded and unfolded many times -- she read her own letter to her mother, over and over, knowing it would never be sent. Addressed to 'Mama.' The first line: 'I found your mourning dress in the trunk today.'"
set_state = {"read_elizabeth_letter": true, "elizabeth_aware": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

[sub_resource type="Resource" id="resp_letter_sovereign"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Letter"
text = "A folded letter sitting on top of the trunk, in plain sight, as if placed there moments ago. The paper is pristine -- no dust, no yellowing, no aging. She preserved it. She wanted you to read it. This is not a hidden message. This is a prepared statement. Addressed to 'Mama.' The first line: 'I want to explain something and I do not know if words are enough.'"
set_state = {"read_elizabeth_letter": true, "elizabeth_aware": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

; ADULT letter: written by a confident adult woman
[sub_resource type="Resource" id="resp_letter_adult"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Letter"
text = "A folded letter on the desk -- not hidden, not tucked away, placed with the confidence of someone who intends it to be read. The handwriting is mature, the vocabulary precise, the tone of someone who has had fifteen years to compose exactly what she wants to say.\n\n'Dear Mama, I am twenty-three today. No one has remembered, though I doubt anyone has forgotten. I have read every book in the library twice. I have learned to paint from the illustrations in the encyclopaedia. I corrected Father's Latin through the door last Tuesday and he did not come back for three days.\n\nI am not the child you locked away. I am the woman you made.'"
set_state = {"read_elizabeth_letter": true, "elizabeth_aware": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

; === Mask Responses (B-path active, A-path static) ===

[sub_resource type="Resource" id="resp_mask_default"]
script = ExtResource("3")
condition = ""
title = "Ritual Mask"
text = "A wooden mask hanging on the wall. Carved features -- not human, not animal. Something between. The eye holes are too large, the mouth too wide. It looks like it was made to see more and speak louder than a human face can."

[sub_resource type="Resource" id="resp_window_default"]
script = ExtResource("3")
condition = ""
title = "Attic Window"
text = "The window looks down across the rear grounds. Bare hedges, dead beds, the garden wall. One pale lily still stands against the winter. Elizabeth must have watched that single living thing the way prisoners watch a keyhole."

[sub_resource type="Resource" id="resp_trunk_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Trunk"
text = "A child's trunk with carefully folded clothes inside. A nightgown. A ribbon. A drawing of a family with four children holding hands. The paper is creased from being opened and refolded until the corners went soft."

; ADULT trunk: childhood on top, adult underneath
[sub_resource type="Resource" id="resp_trunk_adult"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Trunk"
text = "Childhood clothes on top, neatly folded -- a nightgown, a pinafore, a ribbon. But beneath them, something unexpected: adult garments, hemmed and re-hemmed from the same childhood fabric. A skirt let out to its full length. A bodice with the seams moved three times as her body changed. Needlework progressing from clumsy to expert across fifteen years of alterations. She outgrew everything they gave her and remade what she had. The trunk is a record of a body that grew up while the world pretended it had not."

[sub_resource type="Resource" id="resp_trunk_captive"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Trunk"
text = "A child's trunk packed as if for a journey that never happened. Beneath the folded clothes lies a ribbon whitened by plaster dust and a scrap of paper with pencil marks at regular intervals, as if someone measured a wall from the inside. Childhood on top. Evidence underneath. The trunk kept both."

; === Attic Music Box Responses (Adult Route Resolution) ===

[sub_resource type="Resource" id="resp_music_box_wound"]
script = ExtResource("3")
condition = "attic_music_box_wound"
title = "Elizabeth's Music Box"
text = "The music box plays on. The melody is simple, a waltz for a girl who grew into a woman in this room. The lid stays open. You have nothing left to do here."

[sub_resource type="Resource" id="resp_music_box_no_key"]
script = ExtResource("3")
condition = "NOT has_music_box_winding_key"
title = "Elizabeth's Music Box"
text = "A music box on the writing desk. The mechanism is wound down, the lid closed. A small keyhole waits on the front. You need the key."

[sub_resource type="Resource" id="resp_music_box_no_lantern"]
script = ExtResource("3")
condition = "NOT lantern_hook_phase"
title = "Elizabeth's Music Box"
text = "A shape on the writing desk -- you can feel the brass fittings in the dark. A music box. But you cannot see the keyhole properly. You need better light, something that reaches."

[sub_resource type="Resource" id="resp_music_box_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Music Box"
text = "The brass winding key fits perfectly. You turn it. The mechanism engages with a precision that defies decades of silence.\n\nThe lid opens on its own. The melody is a waltz -- not a nursery tune, not a lullaby, but music for a woman at a dance she was never allowed to attend.\n\nElizabeth Ashworth lived twenty-three years in this room. She taught herself to paint, to write, to think. She outgrew her clothes and remade them. She outgrew her family's lies and could not remake those.\n\nThe music box was her eighteenth birthday gift. The only acknowledgment that she was no longer a child. She kept it wound for five more years, playing it alone in the dark, dancing by herself on the rough boards.\n\nThe melody ends. The mechanism clicks. The house is quiet."
set_state = {"attic_music_box_wound": true, "adult_route_complete": true}
play_sfx = "res://assets/audio/sfx/music_box/music_box_melody_01.ogg"

[sub_resource type="Resource" id="resp_music_box_elder_done"]
script = ExtResource("3")
condition = "elder_attic_redirected"
title = "Elizabeth's Music Box"
text = "The attic box answers with one dry click and nothing more. Whatever truth it could once hold has been moved below. The silence under the floorboards feels older than the attic."

[sub_resource type="Resource" id="resp_music_box_elder"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Music Box"
text = "The brass winding key fits, but the attic does not take the melody. One phrase begins and drags down through the boards beneath your feet, as if the house is carrying the waltz away from you into stone. The attic kept the memory of the music box. It did not keep the box itself. Whatever still answers the tune is below."
set_state = {"elder_attic_redirected": true}
play_sfx = "res://assets/audio/sfx/music_box/music_box_melody_01.ogg"

[sub_resource type="Resource" id="resp_music_box_child_done"]
script = ExtResource("3")
condition = "child_attic_redirected"
title = "Elizabeth's Music Box"
text = "The attic box answers with the same short phrase and then falls quiet. It is only an echo. The real melody is trapped behind the west wall."

[sub_resource type="Resource" id="resp_music_box_child"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Music Box"
text = "The brass winding key catches, but the melody never belongs to the attic. One thin phrase leaks sideways through the rafters and seems to answer from the west wall instead, close as a child humming behind plaster. The attic kept a decoy where the family could point. The room they hid kept the real music."
set_state = {"child_attic_redirected": true}
play_sfx = "res://assets/audio/sfx/music_box/music_box_melody_01.ogg"

[sub_resource type="Resource" id="resp_seam_done"]
script = ExtResource("3")
condition = "child_hidden_room_revealed"
title = "Plastered Seam"
text = "The lath hangs broken where you dragged it down. Beyond the splintered plaster the hidden room lies open, no longer pretending to be part of the wall."

[sub_resource type="Resource" id="resp_seam_no_redirect"]
script = ExtResource("3")
condition = "NOT child_attic_redirected"
title = "Plastered Seam"
text = "At first it looks like ordinary attic damage. Then the dust settles and a straight vertical seam appears in the west wall before vanishing back into the plaster."

[sub_resource type="Resource" id="resp_seam_no_hook"]
script = ExtResource("3")
condition = "NOT lantern_hook_phase"
title = "Plastered Seam"
text = "Now that you have heard the false melody you can see the seam clearly. The wall was plastered over a doorframe. You need reach and leverage to tear it open."

[sub_resource type="Resource" id="resp_seam_default"]
script = ExtResource("3")
condition = ""
title = "Plastered Seam"
text = "You set the lantern hook into the seam and pull. Plaster cracks in a long line, then lath tears free with a muffled snap. Dust pours over your sleeves. Behind the wall is not masonry but a narrow doorframe, boarded and then forgotten. A child's room was built here and then erased."
set_state = {"child_hidden_room_revealed": true, "hidden_door_unlocked": true}
play_sfx = "res://assets/audio/sfx/impact/pl_impact_wood_04.ogg"

