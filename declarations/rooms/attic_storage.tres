[sub_resource type="Resource" id="prop_writing_desk"]
script = ExtResource("5")
id = "writing_desk"
model = "res://assets/shared/furniture/drawers.glb"
position = Vector3(-3.0, 0, 2.0)
scale = 0.7

; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_attic_storage": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Attic Storage"

[sub_resource type="Resource" id="act_tension"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_04_dark.wav"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_attic_storage"
once = true
trigger_id = "attic_storage_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name"), SubResource("act_tension")])

; === Ambient: Scratching ===

[sub_resource type="Resource" id="act_scratch"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/horror/whisper_distant.ogg"

[sub_resource type="Resource" id="ambient_scratch"]
script = ExtResource("8")
event_id = "attic_whisper"
interval_min = 15.0
interval_max = 35.0
condition = ""
actions = Array[Resource]([SubResource("act_scratch")])

; === Flashback ===

[sub_resource type="Resource" id="flashback_elizabeth"]
script = ExtResource("10")
flashback_id = "attic_elizabeth_flashback"
condition = "read_elizabeth_letter"
once = true
model = "res://assets/horror/models/bloodwraith.glb"
model_position = Vector3(-2, 0, 4)
model_scale = 0.5
duration = 6.0
fade_amount = 0.9
stinger_sfx = "res://assets/audio/sfx/stinger/pl_horror_stinger_07_reveal.wav"
camera_shake = 0.15

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "attic_storage"
room_name = "Attic Storage"
floor_name = "attic"
environment_preset = "attic"
dimensions = Vector3(14, 4, 12)
is_exterior = false
wall_texture = "wall7_texture"
floor_texture = "floor1_texture"
ceiling_texture = "ceiling2_texture"
wall_north = PackedStringArray("wall", "wall", "wall", "wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "doorway:attic_storage_to_attic_stairs", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "doorway:attic_storage_to_hidden_chamber", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Lonely Nightmare Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_attic.wav"
reverb_bus = "WoodenHall"
footstep_surface = "rough_wood"
spawn_position = Vector3(0, 0, -5)
spawn_rotation_y = 0.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_stairwell")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_doll_corner")])
interactables = Array[Resource]([SubResource("inter_portrait"), SubResource("inter_doll"), SubResource("inter_letter"), SubResource("inter_mask"), SubResource("inter_window"), SubResource("inter_trunk"), SubResource("inter_music_box"), SubResource("inter_seam")])
lights = Array[Resource]([SubResource("light_window"), SubResource("light_candle"), SubResource("light_desk_candle"), SubResource("light_desk_bounce")])
props = Array[Resource]([SubResource("prop_trunk"), SubResource("prop_chair"), SubResource("prop_cot"), SubResource("prop_mattress"), SubResource("prop_bucket"), SubResource("prop_soap"), SubResource("prop_dead_lamp"), SubResource("prop_mask"), SubResource("prop_mining"), SubResource("prop_bat"), SubResource("prop_candle"), SubResource("prop_desk_candle_holder"), SubResource("prop_desk_candle"), SubResource("prop_picture_frame"), SubResource("prop_book"), SubResource("prop_page_a"), SubResource("prop_page_b"), SubResource("prop_writing_desk")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_scratch")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([SubResource("flashback_elizabeth")])
