; === Scratched Portrait Responses ===

[sub_resource type="Resource" id="resp_portrait_dark"]
script = ExtResource("3")
condition = "bad_air_active AND NOT basement_relight"
title = "Scratched Portrait"
text = "You cannot make it out. The dark is absolute and the air stings your eyes."

[sub_resource type="Resource" id="resp_portrait_default"]
script = ExtResource("3")
condition = ""
title = "Scratched Portrait"
text = "A portrait shoved behind crates in the basement. Lord Ashworth's face has been scratched out with something sharp -- the canvas torn in long, deliberate strokes. Someone hated this image enough to destroy it but could not bring themselves to burn it."
set_state = {"examined_scratched_portrait": true}

[sub_resource type="Resource" id="resp_portrait_captive"]
script = ExtResource("3")
condition = ""
title = "Scratched Portrait"
text = "Lord Ashworth's portrait, hidden in the basement. His face is destroyed -- deep scratches through the canvas, the kind made by fingernails dragged in fury. The rest of the painting is untouched. Only the face. Only the jailer. Someone wanted to erase the man who held the keys."
set_state = {"examined_scratched_portrait": true}

[sub_resource type="Resource" id="resp_portrait_mourning"]
script = ExtResource("3")
condition = ""
title = "Scratched Portrait"
text = "Lord Ashworth's portrait, abandoned in the basement. The scratches across his face are not angry -- they are careful. Someone drew tears down his cheeks with a pin. Added lines of age. Made him look as tired and sad as he must have felt. Victoria did this. Not to destroy him but to make the portrait honest."
set_state = {"examined_scratched_portrait": true}

[sub_resource type="Resource" id="resp_portrait_sovereign"]
script = ExtResource("3")
condition = ""
title = "Scratched Portrait"
text = "Lord Ashworth's portrait, stored in the basement. The scratches across the face form a pattern -- not random damage but deliberate marks. They look like the symbols from the ritual circle upstairs. Elizabeth scratched her own markings into her father's face. She did not erase him. She claimed him. Even the portrait belongs to the house now."
set_state = {"examined_scratched_portrait": true}

; === Cage Observation ===

[sub_resource type="Resource" id="resp_cage_dark"]
script = ExtResource("3")
condition = "bad_air_active AND NOT basement_relight"
title = "Iron Cage"
text = "Metal under your fingers. Bars. A cage of some kind. You pull your hand back."

[sub_resource type="Resource" id="resp_cage_default"]
script = ExtResource("3")
condition = ""
title = "Iron Cage"
text = "An animal cage, large enough for a dog. Empty. The door hangs open. The lock is rusted shut in the open position. Whatever was kept here was released -- or escaped."

[sub_resource type="Resource" id="resp_stack_dark"]
script = ExtResource("3")
condition = "bad_air_active AND NOT basement_relight"
title = "Concealed Stack"
text = "Crates stacked against the wall. You can feel the arrangement is deliberate but the dark gives you nothing else."

[sub_resource type="Resource" id="resp_stack_default"]
script = ExtResource("3")
condition = ""
title = "Concealed Stack"
text = "The crates here are stacked too deliberately for storage. They hide the wall rather than use it. When you press near the back, the wood gives a little and the stone behind it answers hollow. This corner was arranged to conceal movement, not clutter."
set_state = {"noticed_service_route": true}

[sub_resource type="Resource" id="resp_mattress_dark"]
script = ExtResource("3")
condition = "bad_air_active AND NOT basement_relight"
title = "Old Mattress"
text = "Fabric under your knees where you fell. A mattress. Beside it, the stub of a candle in a holder -- cold."

[sub_resource type="Resource" id="resp_mattress_default"]
script = ExtResource("3")
condition = ""
title = "Old Mattress"
text = "A mattress laid directly on the basement stone, close to the cage and farther from the stairs than anyone sleeping here would want. Someone stayed down here for many nights in a row. Not a guest. A servant, a guard, or someone who needed to watch this room without being seen."

; === Improvised Relight Responses ===

[sub_resource type="Resource" id="resp_relight_done"]
script = ExtResource("3")
condition = "basement_relight"
title = "Dead Lamp"
text = "The candle holds -- barely. Its light reaches a few feet in every direction. Enough to see by. Not enough to feel safe. The lamp itself is dry and useless. The matches are almost gone."

[sub_resource type="Resource" id="resp_relight_default"]
script = ExtResource("3")
condition = ""
title = "Dead Lamp"
text = "An oil lamp on a crate, dry and cold. But beside it -- a tin of household matches, the kind servants kept where the family would not think to look. You strike one against the tin. It catches on the third try. You shield the flame with your palm, cross to the mattress, and touch it to the candle stub in the holder. It takes. The dark pulls back a handspan."
set_state = {"basement_relight": true}
play_sfx = "res://assets/audio/sfx/ambient/pl_ambient_fire_01.ogg"

; === Interactables ===

[sub_resource type="Resource" id="inter_portrait"]
