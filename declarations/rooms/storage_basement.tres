; === Entry Trigger: Forced Fall ===

[sub_resource type="Resource" id="act_fall_visited"]
script = ExtResource("7")
set_state = {"storage_basement_fall_landing_pending": false, "visited_storage_basement": true, "bad_air_active": true}

[sub_resource type="Resource" id="act_fall_show_name"]
script = ExtResource("7")
show_room_name = "Storage Basement"

[sub_resource type="Resource" id="act_fall_shake"]
script = ExtResource("7")
camera_shake = 0.35

[sub_resource type="Resource" id="act_fall_impact"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/impact/pl_impact_soft_02.ogg"

[sub_resource type="Resource" id="act_fall_text"]
script = ExtResource("7")
show_text = "You strike old oily rags hard enough to lose the breath in your chest. Above, the hatch answers with wood and iron. The brand is gone. The air below tastes of coal gas, lamp oil, and stone that has forgotten daylight."

[sub_resource type="Resource" id="trig_fall_entry"]
script = ExtResource("6")
condition = "storage_basement_fall_landing_pending AND NOT visited_storage_basement"
once = true
trigger_id = "storage_basement_forced_fall_entry"
actions = Array[Resource]([SubResource("act_fall_visited"), SubResource("act_fall_show_name"), SubResource("act_fall_shake"), SubResource("act_fall_impact"), SubResource("act_fall_text")])

; === Entry Trigger: Normal First Visit ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_storage_basement": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Storage Basement"

[sub_resource type="Resource" id="act_entry_text"]
script = ExtResource("7")
show_text = "Stone, dust, and bad light. Whatever the house could not admit upstairs, it pushed down here and stacked against the walls."

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_storage_basement AND NOT storage_basement_fall_landing_pending"
once = true
trigger_id = "storage_basement_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name"), SubResource("act_entry_text")])

; === Conditional Event: Relight Candle Wake ===

[sub_resource type="Resource" id="act_relight_candle"]
script = ExtResource("7")
light_change = {"basement_mattress_candle": {"energy": 1.45, "duration": 2.0}, "basement_mattress_bounce": {"energy": 0.42, "duration": 2.0}}

[sub_resource type="Resource" id="cond_relight"]
script = ExtResource("10")
event_id = "basement_relight_candle"
condition = "basement_relight"
once = true
actions = Array[Resource]([SubResource("act_relight_candle")])

; === Ambient Event: Bad Air (Dark — pre-relight) ===

[sub_resource type="Resource" id="act_air_dark"]
script = ExtResource("7")
show_text = "Your lungs seize. The air down here tastes of coal gas and something older -- a sweetness that belongs to stone left too long without daylight."
play_sfx = "res://assets/audio/sfx/echoes/breath_howling.mp3"

[sub_resource type="Resource" id="ambient_bad_air_dark"]
script = ExtResource("9")
event_id = "bad_air_dark"
interval_min = 8.0
interval_max = 15.0
condition = "bad_air_active AND NOT basement_relight"
actions = Array[Resource]([SubResource("act_air_dark")])

; === Ambient Event: Bad Air (Lit — post-relight, pre-gas) ===

[sub_resource type="Resource" id="act_air_lit"]
script = ExtResource("7")
show_text = "The candle flame leans sideways without any draft you can feel. The air is still wrong. Thinner than upstairs. Your body knows it even when your eyes have adjusted."

[sub_resource type="Resource" id="ambient_bad_air_lit"]
script = ExtResource("9")
event_id = "bad_air_lit"
interval_min = 20.0
interval_max = 40.0
condition = "bad_air_active AND basement_relight AND NOT gas_restored"
actions = Array[Resource]([SubResource("act_air_lit")])

; === Conditional Event: Gas Restore Sconce Wake ===

[sub_resource type="Resource" id="act_storage_sconce_stairs_wake"]
script = ExtResource("7")
light_change = {"storage_sconce_stairs": {"energy": 1.8, "duration": 3.0}}

[sub_resource type="Resource" id="act_storage_sconce_cage_wake"]
script = ExtResource("7")
light_change = {"storage_sconce_cage": {"energy": 1.8, "duration": 3.0}}
delay_seconds = 1.5

[sub_resource type="Resource" id="cond_gas_sconce_wake"]
script = ExtResource("10")
event_id = "storage_gas_sconce_wake"
condition = "gas_restored"
once = true
actions = Array[Resource]([SubResource("act_storage_sconce_stairs_wake"), SubResource("act_storage_sconce_cage_wake")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "storage_basement"
room_name = "Storage Basement"
floor_name = "basement"
environment_preset = "basement"
dimensions = Vector3(8, 3, 8)
is_exterior = false
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "doorway:storage_basement_to_boiler_room", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Echoes at Dusk Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_basement.wav"
reverb_bus = "StoneCorridor"
footstep_surface = "stone"
spawn_position = Vector3(0, 0, -1.4)
spawn_rotation_y = 180.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_stairs")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_service_stack")])
interactables = Array[Resource]([SubResource("inter_portrait"), SubResource("inter_cage"), SubResource("inter_stack"), SubResource("inter_mattress"), SubResource("inter_relight")])
lights = Array[Resource]([SubResource("light_bulb"), SubResource("light_mattress_candle"), SubResource("light_mattress_bounce"), SubResource("light_sconce_stairs"), SubResource("light_sconce_cage")])
props = Array[Resource]([SubResource("prop_shelf_left"), SubResource("prop_shelf_right"), SubResource("prop_crate_1"), SubResource("prop_crate_2"), SubResource("prop_crate_3"), SubResource("prop_crate_4"), SubResource("prop_crate_5"), SubResource("prop_crates_barrels"), SubResource("prop_cage"), SubResource("prop_ladder"), SubResource("prop_mattress"), SubResource("prop_bucket"), SubResource("prop_dead_lamp"), SubResource("prop_debris"), SubResource("prop_hidden_service_stack"), SubResource("prop_mattress_candle_holder"), SubResource("prop_mattress_candle"), SubResource("prop_match_tin")])
mount_slots = Array[Resource]([SubResource("mount_slot_storage_sconce_stairs"), SubResource("mount_slot_storage_sconce_cage")])
mount_payloads = Array[Resource]([SubResource("mount_payload_storage_sconce_stairs"), SubResource("mount_payload_storage_sconce_cage")])
on_entry = Array[Resource]([SubResource("trig_fall_entry"), SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_bad_air_dark"), SubResource("ambient_bad_air_lit")])
conditional_events = Array[Resource]([SubResource("cond_relight"), SubResource("cond_gas_sconce_wake")])
flashbacks = Array[Resource]([])
