[gd_resource type="Resource" script_class="RoomDeclaration" format=3]

[ext_resource type="Script" path="res://engine/declarations/room_declaration.gd" id="1"]
[ext_resource type="Script" path="res://engine/declarations/interactable_decl.gd" id="2"]
[ext_resource type="Script" path="res://engine/declarations/response_decl.gd" id="3"]
[ext_resource type="Script" path="res://engine/declarations/light_decl.gd" id="4"]
[ext_resource type="Script" path="res://engine/declarations/prop_decl.gd" id="5"]
[ext_resource type="Script" path="res://engine/declarations/trigger_decl.gd" id="6"]
[ext_resource type="Script" path="res://engine/declarations/action_decl.gd" id="7"]

; === Children Painting Responses ===

[sub_resource type="Resource" id="resp_children_default"]
script = ExtResource("3")
condition = ""
title = "Children's Portrait"
text = "Five children posed on the garden lawn. The eldest stands tall. The youngest sits on a blanket. But there are only four faces visible. The fifth child -- second from right -- has been painted over. A smear of dark pigment where a face should be."
set_state = {"examined_children_painting": true}

[sub_resource type="Resource" id="resp_children_captive"]
script = ExtResource("3")
condition = ""
title = "Children's Portrait"
text = "Five children on the garden lawn. Four faces. The fifth has been painted over -- but poorly. Beneath the dark pigment, if you look closely, you can see the outline of a small face. Dark eyes. A serious expression. She was there. They painted her out. As if erasing her face could undo what they had done to her."
set_state = {"examined_children_painting": true}

[sub_resource type="Resource" id="resp_children_mourning"]
script = ExtResource("3")
condition = ""
title = "Children's Portrait"
text = "Five children on the garden lawn. The four visible faces are smiling. The fifth space is dark -- painted over with care, not in anger but in sorrow. Someone took their time with the brush. Covering the face gently, the way you pull a blanket over a sleeping child. They could not bear to see her and they could not bear to forget her."
set_state = {"examined_children_painting": true}

[sub_resource type="Resource" id="resp_children_sovereign"]
script = ExtResource("3")
condition = ""
title = "Children's Portrait"
text = "Five children on the garden lawn. Four faces smiling. The fifth child's face is not painted over. It is MOVED. Look at the composition -- there is a gap second from right where a child should stand. But in the far background, barely visible, a small figure stands at the attic window. She is in the painting. She moved herself to where she wanted to be."
set_state = {"examined_children_painting": true}

; === Hallway Poster Responses ===

[sub_resource type="Resource" id="resp_poster_default"]
script = ExtResource("3")
condition = ""
title = "Notice"
text = "A handwritten notice tacked to the wall: 'ATTIC -- CLOSED FOR REPAIRS. DO NOT ENTER.' The paper is yellowed. The ink is faded. No repairs were ever made."
set_state = {"examined_hallway_poster": true}

[sub_resource type="Resource" id="resp_poster_captive"]
script = ExtResource("3")
condition = ""
title = "Notice"
text = "'ATTIC -- CLOSED. NO ENTRY BY ORDER OF LORD ASHWORTH.' The notice is formal, severe. Below it, in smaller letters: 'Any servant found on the attic stairs will be dismissed without reference.' He made imprisonment official. He made looking away a condition of employment."
set_state = {"examined_hallway_poster": true}

[sub_resource type="Resource" id="resp_poster_mourning"]
script = ExtResource("3")
condition = ""
title = "Notice"
text = "'ATTIC -- PLEASE DO NOT DISTURB.' The notice is in Victoria's handwriting. Not a command -- a request. Below it, someone has drawn a small cross in pencil. A memorial marker. The notice was not to keep people out. It was to keep the grief contained."
set_state = {"examined_hallway_poster": true}

[sub_resource type="Resource" id="resp_poster_sovereign"]
script = ExtResource("3")
condition = ""
title = "Notice"
text = "'ATTIC -- DO NOT ENTER.' But the notice has been modified. Additional words in a different hand -- a child's hand: 'I can hear you reading this.' The pencil marks are faint but clear. Elizabeth wrote on the notice from inside the attic. Through the ceiling. Through the floor."
set_state = {"examined_hallway_poster": true}

; === Attic Door (locked, needs key) ===

[sub_resource type="Resource" id="resp_attic_door"]
script = ExtResource("3")
condition = ""
title = "Attic Door"
text = "A heavy oak door at the end of the hallway. The lock is iron, oversized for a domestic door. Scratches surround the keyhole -- someone tried many keys, or one key many times."

; === Interactables ===

[sub_resource type="Resource" id="inter_children"]
script = ExtResource("2")
id = "children_painting"
type = "painting"
position = Vector3(1.5, 2, 4)
wall = "east"
collision_size = Vector3(1.5, 1.5, 1.5)
model = "res://assets/shared/decor/picture_blank.glb"
responses = Array[Resource]([SubResource("resp_children_default")])
thread_responses = {"captive": [SubResource("resp_children_captive")], "mourning": [SubResource("resp_children_mourning")], "sovereign": [SubResource("resp_children_sovereign")]}

[sub_resource type="Resource" id="inter_poster"]
script = ExtResource("2")
id = "hallway_poster"
type = "note"
position = Vector3(-1.5, 1.5, 6)
wall = "west"
collision_size = Vector3(1.5, 1.5, 1.5)
responses = Array[Resource]([SubResource("resp_poster_default")])
thread_responses = {"captive": [SubResource("resp_poster_captive")], "mourning": [SubResource("resp_poster_mourning")], "sovereign": [SubResource("resp_poster_sovereign")]}

[sub_resource type="Resource" id="inter_attic_door"]
script = ExtResource("2")
id = "attic_door"
type = "observation"
position = Vector3(0, 1.2, 7.5)
wall = "north"
collision_size = Vector3(1.5, 2.0, 1.0)
locked = true
key_id = "attic_key"
locked_response_no_key = "The attic door is locked. The iron lock is cold and heavy. You need a key."
locked_response_wrong_key = "This key does not fit the attic lock."
target_room = "attic_stairs"
responses = Array[Resource]([SubResource("resp_attic_door")])

; === Lights ===

[sub_resource type="Resource" id="light_sconce"]
script = ExtResource("4")
id = "hallway_sconce"
type = "omni"
position = Vector3(0, 2, 0)
color = Color(1.0, 0.7, 0.4, 1)
energy = 1.0
range = 8.0
shadows = false
flickering = true
flicker_pattern = "candle"

; === Props ===

[sub_resource type="Resource" id="prop_rug"]
script = ExtResource("5")
id = "hallway_runner"
model = "res://assets/shared/decor/rug0.glb"
position = Vector3(0, 0.01, 0)
scale = 0.5

; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_upper_hallway": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Upper Hallway"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_upper_hallway"
once = true
trigger_id = "upper_hallway_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "upper_hallway"
room_name = "Upper Hallway"
floor_name = "upper_floor"
environment_preset = "upper_floor"
dimensions = Vector3(4, 2.4, 16)
is_exterior = false
wall_texture = "wall1_texture"
floor_texture = "floor1_texture"
ceiling_texture = "ceiling1_texture"
wall_north = PackedStringArray("wall", "doorway:upper_hallway_to_attic_stairs")
wall_south = PackedStringArray("wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "doorway:upper_hallway_to_guest_room", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "doorway:upper_hallway_to_master_bedroom", "wall", "doorway:upper_hallway_to_library", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Keep it up Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_upper.wav"
reverb_bus = "WoodenHall"
footstep_surface = "carpet"
spawn_position = Vector3(0, 0, 0)
spawn_rotation_y = 0.0
interactables = Array[Resource]([SubResource("inter_children"), SubResource("inter_poster"), SubResource("inter_attic_door")])
lights = Array[Resource]([SubResource("light_sconce")])
props = Array[Resource]([SubResource("prop_rug")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
