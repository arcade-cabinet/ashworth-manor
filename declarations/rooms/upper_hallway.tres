model = "res://assets/upper_floor/hallway/poster_cx_11.glb"
responses = Array[Resource]([SubResource("resp_poster_default")])
thread_responses = {"child": [SubResource("resp_poster_captive")], "adult": [SubResource("resp_poster_adult")], "elder": [SubResource("resp_poster_sovereign")], "captive": [SubResource("resp_poster_captive")], "mourning": [SubResource("resp_poster_mourning")], "sovereign": [SubResource("resp_poster_sovereign")]}

[sub_resource type="Resource" id="inter_mask"]
