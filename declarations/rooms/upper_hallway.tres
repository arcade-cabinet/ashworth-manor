; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_upper_hallway": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Upper Hallway"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_upper_hallway"
once = true
trigger_id = "upper_hallway_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name")])

; === Late-Game Rupture Trigger (Stage 8) ===
; Fires when returning to upper hallway after attic visit + walking stick phase
; The house goes dark — Elizabeth's final assertion of presence

[sub_resource type="Resource" id="act_late_darkness"]
script = ExtResource("7")
set_state = {"late_darkness_active": true, "stable_house_light": false}

[sub_resource type="Resource" id="act_late_darkness_sfx"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/horror/whisper_distant.ogg"

[sub_resource type="Resource" id="act_late_darkness_shake"]
script = ExtResource("7")
camera_shake = 0.2

[sub_resource type="Resource" id="act_late_darkness_text"]
script = ExtResource("7")
show_text = "Every light in the house dies at once. Not a flicker, not a fade -- a decision. The hallway is black. From above, through the ceiling, through the attic floor, something breathes. She is done waiting."

[sub_resource type="Resource" id="act_late_dim_sconce_north"]
script = ExtResource("7")
light_change = {"target": "hallway_sconce_north", "energy": 0.0, "duration": 0.5}

[sub_resource type="Resource" id="act_late_dim_sconce_south"]
script = ExtResource("7")
light_change = {"target": "hallway_sconce_south", "energy": 0.0, "duration": 0.5}

[sub_resource type="Resource" id="trig_late_rupture"]
script = ExtResource("6")
condition = "entered_attic AND walking_stick_phase AND NOT late_darkness_active"
once = true
trigger_id = "upper_hallway_late_rupture"
actions = Array[Resource]([SubResource("act_late_darkness"), SubResource("act_late_darkness_sfx"), SubResource("act_late_darkness_shake"), SubResource("act_late_darkness_text"), SubResource("act_late_dim_sconce_north"), SubResource("act_late_dim_sconce_south")])

; === Late-Darkness Conditional Event ===
; Ensures sconces stay dark if player re-enters after rupture

[sub_resource type="Resource" id="act_cond_dim_north"]
script = ExtResource("7")
light_change = {"target": "hallway_sconce_north", "energy": 0.0, "duration": 0.1}

[sub_resource type="Resource" id="act_cond_dim_south"]
script = ExtResource("7")
light_change = {"target": "hallway_sconce_south", "energy": 0.0, "duration": 0.1}

[sub_resource type="Resource" id="cond_late_darkness"]
script = ExtResource("9")
event_id = "upper_hallway_late_darkness"
condition = "late_darkness_active"
once = false
actions = Array[Resource]([SubResource("act_cond_dim_north"), SubResource("act_cond_dim_south")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "upper_hallway"
room_name = "Upper Hallway"
floor_name = "upper_floor"
environment_preset = "upper_floor"
dimensions = Vector3(4, 2.4, 16)
is_exterior = false
wall_north = PackedStringArray("wall", "doorway:upper_hallway_to_attic_stairs")
wall_south = PackedStringArray("wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "doorway:upper_hallway_to_guest_room", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "doorway:upper_hallway_to_master_bedroom", "wall", "doorway:upper_hallway_to_library", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Keep it up Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_upper.wav"
reverb_bus = "WoodenHall"
footstep_surface = "carpet"
spawn_position = Vector3(0, 0, 0)
spawn_rotation_y = 0.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_stairhead")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_hall_axis")])
interactables = Array[Resource]([SubResource("inter_children"), SubResource("inter_poster"), SubResource("inter_mask"), SubResource("inter_attic_door"), SubResource("inter_switch")])
lights = Array[Resource]([SubResource("light_sconce_north"), SubResource("light_sconce_south"), SubResource("light_window")])
props = Array[Resource]([SubResource("prop_rug"), SubResource("prop_children_frame"), SubResource("prop_side_table_south"), SubResource("prop_side_table_north"), SubResource("prop_lamp_lit"), SubResource("prop_lamp_dead"), SubResource("prop_stand"), SubResource("prop_sconce_model_north"), SubResource("prop_sconce_model_south"), SubResource("prop_window"), SubResource("prop_window_ray")])
on_entry = Array[Resource]([SubResource("trig_first_entry"), SubResource("trig_late_rupture")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([SubResource("cond_late_darkness")])
flashbacks = Array[Resource]([])
