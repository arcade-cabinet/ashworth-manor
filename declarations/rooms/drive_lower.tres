[sub_resource type="Resource" id="resp_drive_path"]
script = ExtResource("3")
condition = ""
title = "Ceremonial Drive"
text = "The gravel narrows into a disciplined corridor of clipped hedge and stone. Whoever built Ashworth Manor wanted every arrival to feel like an approach to judgment, not hospitality."

[sub_resource type="Resource" id="resp_drive_hedge"]
script = ExtResource("3")
condition = ""
title = "Clipped Hedge Wall"
text = "The hedge rises shoulder-high and then some, clipped so tightly it feels less like gardening than enclosure. You could be crossing a great estate or merely being funneled toward a decision someone already made."

