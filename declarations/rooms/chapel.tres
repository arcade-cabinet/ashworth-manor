[sub_resource type="Resource" id="anchor_entry_garden"]
script = ExtResource("8")
anchor_id = "entry_garden"
anchor_type = "entry"
position = Vector3(0.0, 0, -2.8)
rotation_y = 0.0
target_anchor_id = "focus_altar"
tags = PackedStringArray("grounds", "garden_return", "critical_path")

[sub_resource type="Resource" id="anchor_focus_altar"]
script = ExtResource("8")
anchor_id = "focus_altar"
anchor_type = "focal"
position = Vector3(0.0, 1.2, 4.25)
rotation_y = 180.0
tags = PackedStringArray("chapel", "altar", "ritual")

; === Baptismal Font Responses ===
; On B-path (Diamond #5), font ALSO yields gate_key via also_gives

[sub_resource type="Resource" id="resp_font_reach"]
script = ExtResource("3")
condition = "examined_baptismal_font"
title = "Baptismal Font"
text = "You reach deeper into the font, past the surface. Your fingers brush the stone bottom and close around something cold and metallic. An iron key rests at the bottom of the holy water. The water that will not freeze also holds a key that will not rust."
set_state = {"found_gate_key_font": true}
gives_item = "gate_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="resp_font_default"]
script = ExtResource("3")
condition = ""
title = "Baptismal Font"
text = "A stone baptismal font. The water inside has not frozen despite the December cold. Clear, still, impossibly clean. Five Ashworth children were baptized here. Elizabeth was the fourth. Your hand breaks the surface and the water is warm. Something glints at the bottom."
set_state = {"examined_baptismal_font": true}
gives_item = "blessed_water"

[sub_resource type="Resource" id="resp_font_captive"]
script = ExtResource("3")
condition = ""
title = "Baptismal Font"
text = "The baptismal font holds unfrozen water. Elizabeth was baptized in this font -- the same water, the same stone, the same words spoken over her head that were spoken over every Ashworth child. But the water did not cleanse what she had. It preserved it. The binding book says holy water can seal a vessel. Her father may have baptized her twice -- once as a child, once as a cage."
set_state = {"examined_baptismal_font": true}
gives_item = "blessed_water"

[sub_resource type="Resource" id="resp_font_mourning"]
script = ExtResource("3")
condition = ""
title = "Baptismal Font"
text = "The baptismal font holds unfrozen water. Victoria brought white lilies here every Sunday -- the caretaker's log says so. She placed them at the font and prayed for Elizabeth. Not for healing. For forgiveness. She asked God to forgive what they had done to their daughter. The flowers are gone but the water remembers. It is warm to the touch."
set_state = {"examined_baptismal_font": true}
gives_item = "blessed_water"

[sub_resource type="Resource" id="resp_font_sovereign"]
script = ExtResource("3")
condition = ""
title = "Baptismal Font"
text = "The baptismal font holds unfrozen water. You lean over it and your reflection looks back -- but it is not your face. For one moment, half a heartbeat, a child's face looks up from the water. Dark eyes. A quiet smile. Then it is your face again. The water is not holy. It is HERS. She is in every liquid in this house -- the wine, the condensation, the pipes, the font. She is the water."
set_state = {"examined_baptismal_font": true}
gives_item = "blessed_water"

; === Altar Observation ===

[sub_resource type="Resource" id="resp_altar_default"]
script = ExtResource("3")
condition = ""
title = "Altar"
text = "A simple stone altar. A Bible lies open to Psalm 130: 'Out of the depths I cry to you, O Lord.' Someone chose this page. Someone wanted God to hear a cry from somewhere deep."

; === Stained Glass Observation ===

[sub_resource type="Resource" id="resp_glass_default"]
script = ExtResource("3")
condition = ""
title = "Stained Glass"
text = "The stained glass window depicts five children in a garden. The fourth child stands slightly apart from the others, hand raised as if waving. Or beckoning. The moonlight passing through the glass casts colored shadows on the floor -- blue, gold, violet. Where the fourth child's image falls, the light is brighter than it should be."

[sub_resource type="Resource" id="resp_pews_default"]
script = ExtResource("3")
condition = ""
title = "Overturned Pews"
text = "The chapel pews were not left to rot in place. They were thrown aside. One lies split along the grain as if something hit it from the side with impossible force. Worship ended here violently."

[sub_resource type="Resource" id="resp_bones_default"]
script = ExtResource("3")
condition = ""
title = "Loose Bones"
text = "Loose bones scattered near the entrance. Small enough to be animal, arranged too deliberately to be accidental. Someone left an offering here after the chapel was stripped bare."

; === Interactables ===

[sub_resource type="Resource" id="inter_font"]
script = ExtResource("2")
id = "baptismal_font"
type = "observation"
position = Vector3(0, 0, -4)
collision_size = Vector3(1.7, 2.0, 1.7)
visual_kind = "chapel_font_still"
default_visual_state = "still"
state_visual_kind_map = {"disturbed": "chapel_font_disturbed", "searched": "chapel_font_searched"}
visual_state_order = PackedStringArray("searched", "disturbed")
visual_state_conditions = {"disturbed": "examined_baptismal_font", "searched": "found_gate_key_font"}
also_gives = "gate_key"
responses = Array[Resource]([SubResource("resp_font_reach"), SubResource("resp_font_default")])
thread_responses = {"captive": [SubResource("resp_font_captive")], "mourning": [SubResource("resp_font_mourning")], "sovereign": [SubResource("resp_font_sovereign")]}

[sub_resource type="Resource" id="inter_altar"]
script = ExtResource("2")
id = "chapel_altar"
type = "observation"
position = Vector3(0, 1, 5)
collision_size = Vector3(2.0, 1.0, 1.0)
responses = Array[Resource]([SubResource("resp_altar_default")])

