; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "chapel"
room_name = "Chapel"
floor_name = "grounds"
environment_preset = "garden_mist"
dimensions = Vector3(8, 6, 12)
is_exterior = false
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Silent Voices Loop2.ogg"
tension_loop = "res://assets/audio/tension/tension_exploration.wav"
reverb_bus = "StoneCorridor"
footstep_surface = "stone"
spawn_position = Vector3(0, 0, -5)
spawn_rotation_y = 0.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_garden")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_altar")])
interactables = Array[Resource]([SubResource("inter_font"), SubResource("inter_altar"), SubResource("inter_glass"), SubResource("inter_pews"), SubResource("inter_bones")])
lights = Array[Resource]([SubResource("light_window"), SubResource("light_altar_candle")])
props = Array[Resource]([SubResource("prop_wall_nw"), SubResource("prop_wall_n"), SubResource("prop_wall_ne"), SubResource("prop_wall_w"), SubResource("prop_wall_e"), SubResource("prop_altar_table"), SubResource("prop_altar_book"), SubResource("prop_pew_left"), SubResource("prop_pew_right"), SubResource("prop_font_bucket"), SubResource("prop_font_bottle"), SubResource("prop_dead_lamp"), SubResource("prop_loose_bones"), SubResource("prop_saint_statue"), SubResource("prop_altar_candle_holder"), SubResource("prop_altar_candle")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
