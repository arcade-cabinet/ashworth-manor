[sub_resource type="Resource" id="anchor_entry_hall"]
script = ExtResource("9")
anchor_id = "entry_hall"
anchor_type = "entry"
position = Vector3(3.1, 0, 0.2)
rotation_y = 254.0
target_anchor_id = "focus_bed_axis"
tags = PackedStringArray("default", "hall")

[sub_resource type="Resource" id="anchor_focus_bed_axis"]
script = ExtResource("9")
anchor_id = "focus_bed_axis"
anchor_type = "focal"
position = Vector3(-1.5, 1.1, -0.2)
rotation_y = 270.0
tags = PackedStringArray("bed", "diary")

; === Diary Responses (shared/default) ===

[sub_resource type="Resource" id="resp_diary_truth"]
script = ExtResource("3")
condition = "knows_full_truth"
title = "Lord Ashworth's Diary"
text = "You know everything now. The diary is just paper and ink. But you read it again anyway. 'I had no choice.' He wrote that seventeen times across six pages. He was trying to convince himself."
set_state = {"read_ashworth_diary": true}

[sub_resource type="Resource" id="resp_diary_default"]
script = ExtResource("3")
condition = ""
title = "Lord Ashworth's Diary"
text = "A leather-bound diary on the nightstand. The entries grow shorter and more agitated through November and December of 1891. The last entry, December 24th, is a single line: 'God forgive me for what I have done tonight.'"
set_state = {"read_ashworth_diary": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_08_subtle.wav"

; CAPTIVE diary: Imprisonment, keys, control
[sub_resource type="Resource" id="resp_diary_captive"]
script = ExtResource("3")
condition = ""
title = "Lord Ashworth's Diary"
text = "The November entries are practical in the worst possible way: plaster invoices, lath measurements, instructions to have a wall finished before Christmas callers arrive. Edmund stops calling Elizabeth 'the girl' and starts calling her 'the room.' December entries shrink to single lines: 'No one must hear her through the wall.' The final entry, December 24th: 'If the room is sealed, perhaps mercy and memory will finally mean the same thing.'"
set_state = {"read_ashworth_diary": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_08_subtle.wav"

; MOURNING diary: Grief, sleepless nights, guilt
[sub_resource type="Resource" id="resp_diary_mourning"]
script = ExtResource("3")
condition = ""
title = "Lord Ashworth's Diary"
text = "The diary lies open on the pillow. He was reading his own words in bed, unable to sleep. The pages are warped from moisture -- not water. Tears. The November entries describe sleepless nights, the sound of crying through the ceiling. December entries: 'Victoria will not speak to me. Cook leaves my meals outside the door. The house grieves and I am the cause.' December 24th: 'I hear her still. I will always hear her.'"
set_state = {"read_ashworth_diary": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_08_subtle.wav"

; SOVEREIGN diary: Fear, the unnatural, she is changing
[sub_resource type="Resource" id="resp_diary_sovereign"]
script = ExtResource("3")
condition = ""
title = "Lord Ashworth's Diary"
text = "The diary is on the floor, thrown there. Pages are torn out -- not carefully removed, ripped in panic. The surviving entries describe increasingly strange observations. November: 'The doors opened by themselves today. All of them. Simultaneously.' December: 'She does not need to touch things anymore. She looks at them and they MOVE.' December 15th: 'The house is hers now. I feel it in the foundations.' December 24th, the last page, written in the margins: 'She is not becoming something. She has BECOME it.'"
set_state = {"read_ashworth_diary": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_08_subtle.wav"

; ADULT diary: Edmund realizes she grew up
[sub_resource type="Resource" id="resp_diary_adult"]
script = ExtResource("3")
condition = ""
title = "Lord Ashworth's Diary"
text = "The diary's language changes across the months. October: 'the girl is quiet today.' November: 'she asked for books -- adult books, philosophy, not fairy tales.' December: 'I cannot pretend any longer. She is not a child. She has not been a child for years. She is taller than Victoria now. She corrected my Latin through the door.'\n\nDecember 24th, the final entry: 'She is older than her mother was when I married her. God forgive me for what I have done tonight.'"
set_state = {"read_ashworth_diary": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_08_subtle.wav"

; === Mirror Responses (shared/default) ===

[sub_resource type="Resource" id="resp_mirror_aware"]
script = ExtResource("3")
condition = "elizabeth_aware"
title = "Vanity Mirror"
text = "The mirror shows the room behind you. But the bed is made in the reflection. The bed in reality is unmade. Two versions of the room. Two truths."
set_state = {"examined_bedroom_mirror": true}

[sub_resource type="Resource" id="resp_mirror_default"]
script = ExtResource("3")
condition = ""
title = "Vanity Mirror"
text = "A vanity mirror framed in dark walnut. The glass is old -- slightly warped, giving your reflection a dreamlike quality. Lady Ashworth sat here every morning. Her hairbrush still rests beside it, strands of grey caught in the bristles."
set_state = {"examined_bedroom_mirror": true}

; CAPTIVE mirror: Trapped, the reflection as prisoner
[sub_resource type="Resource" id="resp_mirror_captive"]
script = ExtResource("3")
condition = ""
title = "Vanity Mirror"
text = "The vanity mirror gives you the room at the wrong height. For a moment the reflected doorknob sits too high, the wardrobe too broad, the chair too far away -- the room as it would have looked to a child standing here and waiting for someone to open the door. Then the scale rights itself. Lady Ashworth used this mirror and still could not bear to look at what the house had done at a child's eye level."
set_state = {"examined_bedroom_mirror": true}

; MOURNING mirror: Aged, sad, time-worn
[sub_resource type="Resource" id="resp_mirror_mourning"]
script = ExtResource("3")
condition = ""
title = "Vanity Mirror"
text = "The vanity mirror is clouded with age. Your reflection is soft, indistinct, as if seen through years of accumulated grief. Lady Ashworth's hairbrush lies beside it with grey hairs still tangled in the bristles. A small photograph is tucked into the frame -- a young girl with dark eyes, smiling. Someone has written on the back: 'Before.' Just that one word."
set_state = {"examined_bedroom_mirror": true}

; SOVEREIGN mirror: The mirror shows what SHE wants you to see
[sub_resource type="Resource" id="resp_mirror_sovereign"]
script = ExtResource("3")
condition = ""
title = "Vanity Mirror"
text = "The vanity mirror is perfectly clear. Impossibly clear for glass this old. Your reflection is sharp, detailed, every pore visible. But behind you, in the reflection, the bedroom door is open. You turn. The door is closed. You look back at the mirror. Open. Something wants you to go through that door. The mirror is not showing what IS. It is showing what should HAPPEN NEXT."
set_state = {"examined_bedroom_mirror": true}

; ADULT mirror: reflection ages to match Elizabeth
[sub_resource type="Resource" id="resp_mirror_adult"]
script = ExtResource("3")
condition = ""
title = "Vanity Mirror"
text = "The vanity mirror is clear but the reflection is wrong. You look -- not older, but the face in the glass has gained years you cannot explain. Dark eyes, steady and adult. For a moment you are looking at someone else entirely. A woman in her twenties, sitting where Lady Ashworth sat, using the same hairbrush. Elizabeth used this mirror. She watched herself grow up in it while the rest of the house refused to notice."
set_state = {"examined_bedroom_mirror": true}

; === Jewelry Box Responses (shared) ===

[sub_resource type="Resource" id="resp_jewelry_key"]
script = ExtResource("3")
condition = "HAS jewelry_key"
title = "Jewelry Box"
text = "The key turns. Inside: Elizabeth's locket. A small oval of tarnished silver. You open it -- two photographs. Elizabeth on the left, barely seven. Victoria on the right, unsmiling. Between them, a lock of dark hair tied with white ribbon."
set_state = {"found_elizabeth_locket": true}
gives_item = "elizabeth_locket"
also_gives = "lock_of_hair"
play_sfx = "res://assets/audio/sfx/inventory/chest_open.ogg"

[sub_resource type="Resource" id="resp_jewelry_locked"]
script = ExtResource("3")
condition = ""
title = "Jewelry Box"
text = "A jewelry box on the vanity. Rosewood, inlaid with mother-of-pearl. Locked. The keyhole is tiny -- this needs a specific key, not a skeleton key. Whatever is inside was meant to stay hidden."

; === Bed Observation ===

[sub_resource type="Resource" id="resp_bed_default"]
script = ExtResource("3")
condition = ""
title = "Master Bed"
text = "The bed is unmade. Sheets twisted, pillow dented. Whoever slept here last did not sleep well. A glass of water on the nightstand is untouched, a skin of dust on its surface."

[sub_resource type="Resource" id="resp_book_default"]
script = ExtResource("3")
condition = ""
title = "Medical Book"
text = "Open to a chapter on childhood afflictions and moral correction. Several passages are underlined twice: isolation, restraint, no recovery documented. Lord Ashworth read medicine the way he read ritual texts: searching for permission."

[sub_resource type="Resource" id="resp_wardrobe_default"]
script = ExtResource("3")
condition = ""
title = "Wardrobe"
text = "Ajar. Formal suits to one side, black dresses to the other. Lady Ashworth's mourning clothes dominate the hanging rail. She did not dress for recovery. She dressed for endurance."

; ADULT wardrobe: adult dress hidden among mourning clothes
[sub_resource type="Resource" id="resp_wardrobe_adult"]
script = ExtResource("3")
condition = ""
title = "Wardrobe"
text = "Ajar. Lady Ashworth's mourning dresses dominate the rail -- but pushed to the very back, a single dress in different proportions. Taller, narrower in the waist, longer in the arm. Cut from the same black fabric as Victoria's clothes but fitted to a younger woman. Someone made this in secret, using what material was available. A daughter's dress, hidden in her mother's wardrobe. Evidence of a body that outgrew its childhood and had no one to acknowledge it."

; ADULT medical book: about adult patients, not children
[sub_resource type="Resource" id="resp_book_adult"]
script = ExtResource("3")
condition = ""
title = "Medical Book"
text = "Not childhood afflictions at all. The underlined passages concern 'prolonged restraint of persons of sound mind' and 'moral responsibility for the indefinite confinement of adult dependents.' Edmund was not searching for a diagnosis. He was searching for permission to keep doing what he was already doing -- to an adult. The marginal note in his hand: 'At what age does duty to protect become imprisonment?'"

[sub_resource type="Resource" id="resp_broken_bottle_default"]
script = ExtResource("3")
condition = ""
title = "Broken Bottle"
text = "Broken glass near the wall and a medicinal smell that survived the century. Laudanum, perhaps. Something to quiet the nerves or bring sleep. It did neither for long."

; === Interactables ===

[sub_resource type="Resource" id="inter_diary"]
script = ExtResource("2")
