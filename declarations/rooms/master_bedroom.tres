interval_min = 25.0
interval_max = 50.0
condition = ""
actions = Array[Resource]([SubResource("act_creak")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "master_bedroom"
room_name = "Master Bedroom"
floor_name = "upper_floor"
environment_preset = "upper_floor"
dimensions = Vector3(10, 2.4, 10)
is_exterior = false
wall_north = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "doorway:master_bedroom_to_upper_hallway", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Lying Down Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_upper.wav"
reverb_bus = "Room"
footstep_surface = "carpet"
spawn_position = Vector3(4, 0, 0)
spawn_rotation_y = 270.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_hall")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_bed_axis")])
interactables = Array[Resource]([SubResource("inter_diary"), SubResource("inter_mirror"), SubResource("inter_jewelry"), SubResource("inter_bed"), SubResource("inter_book"), SubResource("inter_wardrobe"), SubResource("inter_broken_bottle")])
lights = Array[Resource]([SubResource("light_window"), SubResource("light_candle")])
props = Array[Resource]([SubResource("prop_bed"), SubResource("prop_wardrobe"), SubResource("prop_chair"), SubResource("prop_nightstand"), SubResource("prop_rug"), SubResource("prop_lamp"), SubResource("prop_luggage"), SubResource("prop_soap"), SubResource("prop_bottle"), SubResource("prop_broken_bottle"), SubResource("prop_candle_holder_left"), SubResource("prop_candle_holder_right"), SubResource("prop_book0"), SubResource("prop_book1"), SubResource("prop_openbook")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_creak")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
