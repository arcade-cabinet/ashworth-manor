id = "jewelry_box"
type = "box"
position = Vector3(4.5, 0.9, 0.5)
collision_size = Vector3(1.0, 0.5, 0.5)
locked = true
key_id = "jewelry_key"
locked_response_no_key = "The jewelry box is locked. The keyhole is tiny and ornate -- this needs a very specific key."
locked_response_wrong_key = "This key is too large for the jewelry box. You need something smaller, more delicate."
responses = Array[Resource]([SubResource("resp_jewelry_key"), SubResource("resp_jewelry_locked")])

