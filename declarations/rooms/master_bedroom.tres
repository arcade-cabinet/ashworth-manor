responses = Array[Resource]([SubResource("resp_diary_truth"), SubResource("resp_diary_default")])
thread_responses = {"child": [SubResource("resp_diary_captive")], "adult": [SubResource("resp_diary_adult")], "elder": [SubResource("resp_diary_sovereign")], "captive": [SubResource("resp_diary_captive")], "mourning": [SubResource("resp_diary_mourning")], "sovereign": [SubResource("resp_diary_sovereign")]}

