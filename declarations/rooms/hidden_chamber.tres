[sub_resource type="Resource" id="anchor_entry_secret_door"]
script = ExtResource("8")
anchor_id = "entry_secret_door"
anchor_type = "entry"
position = Vector3(0.0, 0.0, -2.2)
rotation_y = 0.0
target_anchor_id = "focus_child_bed"
tags = PackedStringArray("critical_path", "child_route")

[sub_resource type="Resource" id="anchor_focus_child_bed"]
script = ExtResource("8")
anchor_id = "focus_child_bed"
anchor_type = "focal"
position = Vector3(0.9, 0.8, 1.55)
rotation_y = 0.0
tags = PackedStringArray("critical_path", "nursery")

[sub_resource type="Resource" id="resp_music_box_done"]
script = ExtResource("3")
condition = "child_music_box_wound"
title = "Elizabeth's Music Box"
text = "The nursery waltz turns on in its own time now. The room no longer feels hidden. Only witnessed."

[sub_resource type="Resource" id="resp_music_box_no_key"]
script = ExtResource("3")
condition = "NOT has_music_box_winding_key"
title = "Elizabeth's Music Box"
text = "A small music box sits beside the narrow bed, half wrapped in a child's handkerchief. The winding stem is still present, but the key is missing. You need the brass key from the valise."

[sub_resource type="Resource" id="resp_music_box_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Music Box"
text = "The brass key fits as if it has been waiting in your pocket since childhood. You turn it once. The lid lifts.\n\nThe melody is not a ballroom waltz here. It is small and careful, the kind of tune meant for a room where a child was expected to soothe herself and stay quiet.\n\nThis was Elizabeth's room before it was hidden. Not a cell dressed as an attic, not a ritual chamber, but a nursery plastered over when the family decided concealment was kinder than truth.\n\nThe tune carries through the lath and back into the house that forgot her. For the first time, the room answers as a room."
set_state = {"child_music_box_wound": true, "child_route_complete": true, "knows_full_truth": true}
play_sfx = "res://assets/audio/sfx/music_box/music_box_melody_01.ogg"

[sub_resource type="Resource" id="resp_drawings_default"]
script = ExtResource("3")
condition = ""
title = "Wall Drawings"
text = "Charcoal drawings run along the lower plaster where only a child would have worked comfortably: flowers, the front gate, a train, then height marks and careful little plans of the west wall from the inside. She did not draw monsters. She drew exits."

[sub_resource type="Resource" id="resp_bed_default"]
script = ExtResource("3")
condition = ""
title = "Child's Bed"
text = "A narrow bed built into the wall alcove. The mattress stuffing has collapsed, but the bed frame still carries small practical adjustments: a shelf for a candle, a hook for a ribbon, a groove worn where a child tapped a music box against the wood before sleep."

[sub_resource type="Resource" id="resp_marks_default"]
script = ExtResource("3")
condition = ""
title = "Height Marks"
text = "Pencil lines climb the plaster behind the door frame. The first are labeled in Victoria's hand. The later ones were added by Elizabeth herself, the handwriting changing as she learned to make the marks neatly. The line stops abruptly at age seven. The child kept growing, but the household record did not."

[sub_resource type="Resource" id="resp_mirror_default"]
script = ExtResource("3")
condition = ""
title = "Small Mirror"
text = "A small mirror hangs far too low for an adult. In it the room makes sense at once: the bed, the chair, the shelf, the box. This was arranged for a child's reach and then hidden inside the wall when the child herself became inconvenient."

[sub_resource type="Resource" id="inter_music_box"]
script = ExtResource("2")
id = "child_music_box"
type = "observation"
position = Vector3(1.15, 0.82, 1.55)
collision_size = Vector3(0.9, 0.7, 0.9)
model = "res://assets/shared/items/music_box.glb"
responses = Array[Resource]([SubResource("resp_music_box_done"), SubResource("resp_music_box_no_key"), SubResource("resp_music_box_default")])

