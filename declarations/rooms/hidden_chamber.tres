once = true
trigger_id = "chamber_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name"), SubResource("act_entry_text"), SubResource("act_stinger")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "hidden_chamber"
room_name = "Hidden Chamber"
floor_name = "attic"
environment_preset = "attic"
dimensions = Vector3(6, 3, 6)
is_exterior = false
wall_texture = "wall7_texture"
floor_texture = "floor2_texture"
ceiling_texture = "ceiling2_texture"
wall_north = PackedStringArray("wall", "wall", "wall")
wall_south = PackedStringArray("wall", "doorway:hidden_chamber_to_attic_storage", "wall")
wall_east = PackedStringArray("wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/I Can't Go On Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_attic.wav"
reverb_bus = "SmallRoom"
footstep_surface = "rough_wood"
spawn_position = Vector3(0, 0, -2)
spawn_rotation_y = 0.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_secret_door")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_circle")])
interactables = Array[Resource]([SubResource("inter_note"), SubResource("inter_ritual"), SubResource("inter_drawings"), SubResource("inter_mirror"), SubResource("inter_artifact")])
lights = Array[Resource]([SubResource("light_circle"), SubResource("light_candle"), SubResource("light_candle_left")])
props = Array[Resource]([SubResource("prop_doll"), SubResource("prop_artifact"), SubResource("prop_bones"), SubResource("prop_mask_left"), SubResource("prop_mask_right"), SubResource("prop_dead_lamp"), SubResource("prop_bottle"), SubResource("prop_candle_a"), SubResource("prop_candle_b"), SubResource("prop_page_a"), SubResource("prop_page_b"), SubResource("prop_page_c"), SubResource("prop_note_page"), SubResource("prop_mirror_frame")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
