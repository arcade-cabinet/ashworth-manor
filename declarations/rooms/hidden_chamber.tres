[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"found_hidden_chamber": true, "visited_hidden_chamber": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Sealed Room"

[sub_resource type="Resource" id="act_entry_text"]
script = ExtResource("7")
show_text = "The wall gives way to a room the house was expected to forget. The air is dry with plaster dust and old childhood."

[sub_resource type="Resource" id="act_stinger"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_stinger_07_reveal.wav"
camera_shake = 0.08

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT found_hidden_chamber"
once = true
trigger_id = "chamber_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name"), SubResource("act_entry_text"), SubResource("act_stinger")])

[resource]
script = ExtResource("1")
room_id = "hidden_chamber"
room_name = "Sealed Room"
floor_name = "attic"
environment_preset = "attic"
dimensions = Vector3(6, 3, 6)
is_exterior = false
wall_north = PackedStringArray("wall", "wall", "wall")
wall_south = PackedStringArray("wall", "doorway:hidden_chamber_to_attic_storage", "wall")
wall_east = PackedStringArray("wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/I Can't Go On Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_attic.wav"
reverb_bus = "SmallRoom"
footstep_surface = "rough_wood"
spawn_position = Vector3(0, 0, -2)
spawn_rotation_y = 0.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_secret_door")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_child_bed")])
interactables = Array[Resource]([SubResource("inter_music_box"), SubResource("inter_drawings"), SubResource("inter_bed"), SubResource("inter_marks"), SubResource("inter_mirror")])
lights = Array[Resource]([SubResource("light_candle"), SubResource("light_wall_bounce"), SubResource("light_bed_bounce")])
props = Array[Resource]([SubResource("prop_bed"), SubResource("prop_chair"), SubResource("prop_doll"), SubResource("prop_bedside_drawers"), SubResource("prop_music_box_cloth"), SubResource("prop_pages_a"), SubResource("prop_pages_b"), SubResource("prop_dead_lamp"), SubResource("prop_mirror_frame"), SubResource("prop_nursery_candle_holder"), SubResource("prop_nursery_candle")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
