; === Conditional: Binding Book Aftershock ===

[sub_resource type="Resource" id="act_flashback_flag"]
script = ExtResource("7")
set_state = {"library_flashback_triggered": true}

[sub_resource type="Resource" id="act_flashback_rustle"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/paper_rustle.ogg"

[sub_resource type="Resource" id="act_flashback_dim"]
script = ExtResource("7")
light_change = {"library_desk_lamp": {"energy": 0.45, "duration": 1.2}}

[sub_resource type="Resource" id="act_flashback_text"]
script = ExtResource("7")
show_text = "The pages move without wind. Not turning -- recoiling. In the hush that follows, you can almost hear the occultist reading across the desk from Edmund Ashworth, each line of the rite making the room smaller."
delay_seconds = 1.8

[sub_resource type="Resource" id="act_flashback_restore"]
script = ExtResource("7")
light_change = {"library_desk_lamp": {"energy": 1.2, "duration": 2.4}}
delay_seconds = 5.8

[sub_resource type="Resource" id="cond_binding_aftershock"]
script = ExtResource("9")
event_id = "library_binding_aftershock"
condition = "HAS binding_book AND NOT library_flashback_triggered"
once = true
actions = Array[Resource]([SubResource("act_flashback_flag"), SubResource("act_flashback_rustle"), SubResource("act_flashback_dim"), SubResource("act_flashback_text"), SubResource("act_flashback_restore")])

