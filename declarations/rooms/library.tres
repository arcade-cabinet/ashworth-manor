; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_library": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Library"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_library"
once = true
trigger_id = "library_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name")])

; === Ambient: Page rustle ===

[sub_resource type="Resource" id="act_rustle"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/paper_rustle.ogg"

[sub_resource type="Resource" id="ambient_rustle"]
script = ExtResource("8")
event_id = "page_rustle"
interval_min = 20.0
interval_max = 40.0
condition = ""
actions = Array[Resource]([SubResource("act_rustle")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "library"
room_name = "Library"
floor_name = "upper_floor"
environment_preset = "upper_floor"
dimensions = Vector3(8, 2.4, 10)
is_exterior = false
wall_texture = "wall3_texture"
floor_texture = "floor1_texture"
ceiling_texture = "ceiling2_texture"
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "doorway:library_to_upper_hallway", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Value Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_upper.wav"
reverb_bus = "Room"
footstep_surface = "wood_parquet"
spawn_position = Vector3(0, 0, -4)
spawn_rotation_y = 0.0
interactables = Array[Resource]([SubResource("inter_globe"), SubResource("inter_book"), SubResource("inter_tree"), SubResource("inter_gears")])
lights = Array[Resource]([SubResource("light_desk"), SubResource("light_window")])
props = Array[Resource]([SubResource("prop_desk"), SubResource("prop_bookcase_n"), SubResource("prop_bookcase_w"), SubResource("prop_chair"), SubResource("prop_globe_model")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_rustle")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
