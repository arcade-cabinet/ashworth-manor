; === Globe Responses (shared) -- active on A-path, static on B-path ===

[sub_resource type="Resource" id="resp_globe_diary"]
script = ExtResource("3")
condition = "read_ashworth_diary"
title = "Globe"
text = "The diary mentioned the globe. 'The key is inside the globe -- she will never think to look there.' You turn the northern hemisphere. It clicks. A hidden compartment opens. Inside: an iron key."
set_state = {"found_attic_key_globe": true}
gives_item = "attic_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="resp_globe_default"]
script = ExtResource("3")
condition = ""
title = "Globe"
text = "A brass-framed globe on a mahogany stand. The northern hemisphere is slightly askew -- someone twisted it and did not put it back. The seam between the hemispheres is wider than it should be. Is there something inside?"

; Globe thread variants
[sub_resource type="Resource" id="resp_globe_captive"]
script = ExtResource("3")
condition = ""
title = "Globe"
text = "The globe sits on its mahogany stand like a lie about distance. The brass around England is nicked by impatient handling -- not by someone planning escape routes, but by a child tracing all the places she was told existed while men downstairs measured the wall that would swallow her room. The northern hemisphere is twisted slightly out of place, as if someone kept hoping the world would open."

[sub_resource type="Resource" id="resp_globe_captive_diary"]
script = ExtResource("3")
condition = "read_ashworth_diary"
title = "Globe"
text = "The diary told you where he hid it. You set your thumb against the skewed northern hemisphere and turn. The compartment yields with a metallic click. Inside rests the attic key -- one more instrument of her confinement, hidden inside a model of a world she was denied."
set_state = {"found_attic_key_globe": true}
gives_item = "attic_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="resp_globe_mourning"]
script = ExtResource("3")
condition = ""
title = "Globe"
text = "A globe on a mahogany stand. Elizabeth used to spin it and point to where she wanted to travel. Victoria told you that. The globe has not moved since. Dust has settled in the grooves between continents. All those places she will never see."

[sub_resource type="Resource" id="resp_globe_mourning_diary"]
script = ExtResource("3")
condition = "read_ashworth_diary"
title = "Globe"
text = "The diary gives the mechanism away. When you turn the northern hemisphere, the globe opens with a tired click. The attic key rests in the hollow interior, hidden in plain sight inside a promise of travel Elizabeth was never allowed to keep."
set_state = {"found_attic_key_globe": true}
gives_item = "attic_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="resp_globe_sovereign"]
script = ExtResource("3")
condition = ""
title = "Globe"
text = "The globe turns on its own as you enter the room. A quarter rotation, slow, deliberate. It stops with England facing you. Ashworth Manor would be right... there. Under your fingertip. She is showing you where you are. She already knows."
	
[sub_resource type="Resource" id="resp_globe_sovereign_diary"]
script = ExtResource("3")
condition = "read_ashworth_diary"
title = "Globe"
text = "The globe is already turned toward England when you touch it. The diary's instruction leaves no doubt. You twist the northern hemisphere and the hidden compartment releases at once. The attic key lies inside, offered up less like a secret and more like permission."
set_state = {"found_attic_key_globe": true}
gives_item = "attic_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

; ADULT globe: worn by adult hands
[sub_resource type="Resource" id="resp_globe_adult"]
script = ExtResource("3")
condition = ""
title = "Globe"
text = "The brass around England is worn smooth -- not by a child's idle spinning but by years of deliberate tracing. Adult fingertips, pressing the same route over and over: London, the coast, the rail line to the village. Elizabeth mapped her escape on this globe for a decade and a half. The mechanism is stiff from adult hands trying the same twist, year after year."

[sub_resource type="Resource" id="resp_globe_adult_diary"]
script = ExtResource("3")
condition = "read_ashworth_diary"
title = "Globe"
text = "The diary names the globe. You twist the northern hemisphere and it yields -- stiff, as if opened and closed many times by stronger hands than a child's. The attic key rests inside. Elizabeth knew it was here. She was not a child who could not reach it. She was a woman who chose not to take it. The question is why."
set_state = {"found_attic_key_globe": true}
gives_item = "attic_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

; === Binding Book Responses (shared) ===

[sub_resource type="Resource" id="resp_book_truth"]
script = ExtResource("3")
condition = "knows_full_truth"
title = "Rites of Passage"
text = "The book that taught Edmund Ashworth how to bind his daughter. You have read it. You understand now what it means and what it costs. The pages feel heavier than paper should."
set_state = {"examined_binding_book": true}

[sub_resource type="Resource" id="resp_book_default"]
script = ExtResource("3")
condition = ""
title = "Rites of Passage"
text = "A leather-bound volume on the reading lectern. 'Rites of Passage: The Binding and Loosing of Spirits, 1743.' The pages are yellowed, the margins annotated in Edmund Ashworth's hand. Bookmarks at chapters titled 'Containment' and 'The Vessel.'"
set_state = {"examined_binding_book": true}
gives_item = "binding_book"

; ADULT binding book: Edmund's language shifts from girl to woman
[sub_resource type="Resource" id="resp_book_adult"]
script = ExtResource("3")
condition = ""
title = "Rites of Passage"
text = "Edmund's annotations change as the chapters progress. Early margins say 'the girl,' then 'Elizabeth,' then simply 'she.' By the final chapter his hand trembles: 'The woman upstairs has read this book. She found it before I could hide it. She understands what was done to her and she is not a child who can be distracted from understanding.' He stopped annotating after that."
set_state = {"examined_binding_book": true}
gives_item = "binding_book"

; Binding book thread variants
[sub_resource type="Resource" id="resp_book_captive"]
script = ExtResource("3")
condition = ""
title = "Rites of Passage"
text = "The book lies open to chapters on correction, containment, and domestic seclusion. Edmund's annotations begin as theology and end as carpentry notes. 'Seal the aperture.' 'No window line.' 'The room must not present itself as a room.' He was not only locking a child away. He was teaching himself how to erase the fact that the child had ever needed a room at all."
set_state = {"examined_binding_book": true}
gives_item = "binding_book"

[sub_resource type="Resource" id="resp_book_mourning"]
script = ExtResource("3")
condition = ""
title = "Rites of Passage"
text = "The book lies open to the chapter on Consequences. Edmund's annotations here are different -- shaky, blotted, written late at night. 'What have I done? The book said containment, not suffering. It said the vessel would sleep.' A dried flower pressed between the pages -- a white lily. Elizabeth's favorite. He put it here to remind himself she was still his daughter."
set_state = {"examined_binding_book": true}
gives_item = "binding_book"

[sub_resource type="Resource" id="resp_book_sovereign"]
script = ExtResource("3")
condition = ""
title = "Rites of Passage"
text = "The book lies open to the chapter on Awakening. Edmund did not annotate this chapter -- Elizabeth did. Her handwriting is in the margins, neat and precise. 'He thinks this chapter describes a disease. It describes an evolution.' And further down: 'The book is wrong about the vessel. The vessel is not a container. It is a cocoon.' She read the same book and understood it better than he ever did."
set_state = {"examined_binding_book": true}
gives_item = "binding_book"

; === Family Tree Responses (shared) ===

[sub_resource type="Resource" id="resp_tree_diary"]
script = ExtResource("3")
condition = "read_ashworth_diary"
title = "Family Tree"
text = "Five branches for five children. The fourth name -- Elizabeth -- has been scratched out so deeply the paper tore. Someone erased her from the family. The scratches look fresh. Recent. As if this happened after everything else."
set_state = {"examined_family_tree": true}

[sub_resource type="Resource" id="resp_tree_default"]
script = ExtResource("3")
condition = ""
title = "Family Tree"
text = "A framed family tree on the wall. 'The Ashworth Line, 1720-1891.' Five branches descend from Edmund and Victoria. Four names are legible. The fourth has been scratched out -- not with ink, but with something sharp. A nail? A pin? The paper beneath is torn."
set_state = {"examined_family_tree": true}

; ADULT family tree: dates that don't match
[sub_resource type="Resource" id="resp_tree_adult"]
script = ExtResource("3")
condition = ""
title = "Family Tree"
text = "Five branches for five children. The fourth name has been scratched away, but beneath the erasure someone has penciled dates in a precise adult hand: 'b. 1865 — d. ?' The death date is a question mark. Not blank, not falsified -- questioned. Whoever wrote this knew Elizabeth did not die when the family claimed. The handwriting matches the marginalia in the binding book. Elizabeth annotated her own erasure."
set_state = {"examined_family_tree": true}

; Family tree thread variants
[sub_resource type="Resource" id="resp_tree_captive"]
script = ExtResource("3")
condition = ""
title = "Family Tree"
text = "The family tree has five branches. Four names. The fourth has not been crossed out but scraped away until the paper thinned. At the edge of the tear someone penciled a tiny height mark and then rubbed it almost completely out. They were not only erasing Elizabeth from the line. They were erasing the child from the household record."
set_state = {"examined_family_tree": true}

[sub_resource type="Resource" id="resp_tree_mourning"]
script = ExtResource("3")
condition = ""
title = "Family Tree"
text = "The family tree has five branches. Four names. The fourth space is blank -- not scratched out, not erased. Blank. As if the calligrapher was told to leave it empty. As if the parents could not bring themselves to write her name. Below the blank space, someone has drawn a small flower in pencil. A lily. Victoria's hand. She could not write the name but she could not leave it empty either."
set_state = {"examined_family_tree": true}

[sub_resource type="Resource" id="resp_tree_sovereign"]
script = ExtResource("3")
condition = ""
title = "Family Tree"
text = "The family tree has five branches. Four names. The fourth name has been scratched out -- but when you look closer, the scratches form letters. She scratched out her old name and wrote a new one over it. The strokes are too fine to read in this light. But they are deliberate. She renamed herself. She chose to become something the family tree had no category for."
set_state = {"examined_family_tree": true}

; === Gear Mechanism Responses (B-path puzzle) ===

[sub_resource type="Resource" id="resp_gear_default"]
script = ExtResource("3")
condition = ""
title = "Gear Mechanism"
text = "A brass mechanism mounted on the wall beside the clock. Three gear housings sit empty -- the gears themselves are scattered on the desk below. A note pinned to the desk reads: 'The clock knows the combination. Time runs from small to large.'"

[sub_resource type="Resource" id="resp_artifact_default"]
script = ExtResource("3")
condition = ""
title = "Stone Artifact"
text = "A carved object displayed where a collector would place something precious or dangerous. The markings are not decorative. They resemble the notation in the binding book, but older. A precursor. Or a source."

[sub_resource type="Resource" id="resp_shelves_default"]
script = ExtResource("3")
condition = ""
title = "Bookshelves"
text = "Natural philosophy, mechanical engineering, theology, séance manuals, folk rites. Lord Ashworth did not descend into occultism by abandoning reason. He brought reason with him and used it badly."

; ADULT shelves: Elizabeth's reading life
[sub_resource type="Resource" id="resp_shelves_adult"]
script = ExtResource("3")
condition = ""
title = "Bookshelves"
text = "Among the occult volumes, novels and poetry in a different arrangement -- pulled forward, spines cracked from rereading. Marginalia in a woman's confident hand: literary criticism, vocabulary lists, arguments with the authors. Elizabeth read this library systematically over fifteen years. Her annotations are more lucid than Edmund's. She educated herself in her father's prison."

; === Elizabeth's Papers (Adult-route clue engine) ===

[sub_resource type="Resource" id="resp_papers_diary"]
script = ExtResource("3")
condition = "read_ashworth_diary"
title = "Elizabeth's Folio"
text = "You pull the folio free and the pages spill across the desk. Elizabeth's adult handwriting -- the same hand that annotated the binding book, the same hand that questioned her death date on the family tree. Household observations, a half-finished novel about a woman who inherits a ruined estate, drafts of letters never sent. She was writing herself into existence while they pretended she did not exist. The final page is dated December 1891: 'I have decided to stop waiting.'"
set_state = {"found_elizabeth_papers": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_08_subtle.wav"

[sub_resource type="Resource" id="resp_papers_default"]
script = ExtResource("3")
condition = ""
title = "Elizabeth's Folio"
text = "Behind a loose bookcase panel, a leather folio stuffed with loose pages. The handwriting is not Edmund's -- smaller, neater, distinctly feminine. Not a child's scrawl. These are the writings of an educated adult: household observations, fragments of a novel, drafts of unsent letters. Someone lived in this library for years, reading and writing in secret, building an intellectual life that the rest of the house refused to see."
set_state = {"found_elizabeth_papers": true}
play_sfx = "res://assets/audio/sfx/stinger/pl_horror_tension_08_subtle.wav"

