[sub_resource type="Resource" id="anchor_entry_foyer"]
script = ExtResource("9")
anchor_id = "entry_foyer"
anchor_type = "entry"
position = Vector3(3.05, 0, 0.1)
rotation_y = 12.0
target_anchor_id = "focus_hearth"
tags = PackedStringArray("default", "service")

[sub_resource type="Resource" id="anchor_focus_hearth"]
script = ExtResource("9")
anchor_id = "focus_hearth"
anchor_type = "focal"
position = Vector3(0.2, 1.15, -4.0)
rotation_y = 180.0
tags = PackedStringArray("hearth", "puzzle")

; === Cook's Note Responses ===

[sub_resource type="Resource" id="resp_note_default"]
script = ExtResource("3")
condition = ""
title = "Cook's Note"
text = "A note in a rough hand, pinned to the pantry door. 'Gone to market. Back before dark. DO NOT go upstairs. DO NOT answer if she calls.' The last line is underlined twice."
set_state = {"read_cook_note": true}

; Cook's note thread variants
[sub_resource type="Resource" id="resp_note_captive"]
script = ExtResource("3")
condition = ""
title = "Cook's Note"
text = "A note in a rough hand, pinned to the pantry door. 'I cannot stay in this house another night. The rats whisper NAMES. Not squeaking -- whispering. They say Elizabeth. They say it through the walls, through the pipes, through the floor. I locked the cellar but I can still hear them. Whatever is up there, it is not just in the attic anymore. It is in the walls.'"
set_state = {"read_cook_note": true}

[sub_resource type="Resource" id="resp_note_mourning"]
script = ExtResource("3")
condition = ""
title = "Cook's Note"
text = "A note in a rough hand, pinned to the pantry door. 'The house feels sad today. I do not know how else to say it. The walls feel sad. The floors feel sad. The water from the pump tastes like tears. I made soup for the family but no one came to eat. I left a bowl outside the attic door. It was empty in the morning. Someone is eating. Someone is still alive up there.'"
set_state = {"read_cook_note": true}

[sub_resource type="Resource" id="resp_note_sovereign"]
script = ExtResource("3")
condition = ""
title = "Cook's Note"
text = "A note in a rough hand, pinned to the pantry door. 'The kitchen knows when someone is hungry. I am not mad. I have worked kitchens for thirty years and I know what a stove does. This stove lights itself. The kettle fills itself. The pantry rearranges when I am not looking -- putting things I need at the front. It is HER. She is in the house the way heat is in a stove. Not visible. Not separate. Just there.'"
set_state = {"read_cook_note": true}

; === Hearth Responses (Diamond #3 B-path: flagstone key) ===

[sub_resource type="Resource" id="resp_hearth_flagstone"]
script = ExtResource("3")
condition = "examined_hearth_loose"
title = "Kitchen Hearth"
text = "You pry the loose flagstone up with your fingers. Beneath it, in a shallow hollow scraped into the mortar, is a small iron key wrapped in a scrap of linen. The cook hid the spare key exactly where she said she would."
set_state = {"found_cellar_key_hearth": true}
gives_item = "cellar_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="resp_hearth_default"]
script = ExtResource("3")
condition = ""
title = "Kitchen Hearth"
text = "A large stone hearth, cold and dark. Soot stains the mantle. Iron hooks for pots hang empty. The flagstones around the base are uneven -- one is slightly raised, rocking when you step on it."
set_state = {"examined_hearth_loose": true}

[sub_resource type="Resource" id="resp_bucket_rippled"]
script = ExtResource("3")
condition = "examined_kitchen_bucket"
title = "Bucket"
text = "The water shivers before your fingers reach the rim. Not a draft. Not your reflection. Just one slow ring moving across the dark surface, then another, as if something beneath remembered you were here."

[sub_resource type="Resource" id="resp_bucket_default"]
script = ExtResource("3")
condition = ""
title = "Bucket"
text = "A wooden bucket, half-full of water that should have evaporated decades ago. The water is perfectly still. No reflection of the ceiling. Just dark."
set_state = {"examined_kitchen_bucket": true}

; === Service Hatch Responses ===

[sub_resource type="Resource" id="resp_hatch_propped"]
script = ExtResource("3")
condition = "service_hatch_propped"
title = "Service Hatch"
text = "The service hatch stands open. The cane's iron tip wedged it into its stays — firm, deliberate. The service stair below is lit by the basement sconces. You can go below and return at will now."

[sub_resource type="Resource" id="resp_hatch_stick"]
script = ExtResource("3")
condition = "walking_stick_phase AND NOT service_hatch_propped"
title = "Service Hatch"
text = "The service hatch hangs at an angle, the hinges stiff and unreliable. You slide the cane's iron tip under the frame and lever it into its stays. The wood answers like furniture — honest weight, honest grain. The hatch settles and holds. The service stair stands open between the kitchen and the basement. A working route, not a trap."
set_state = {"service_hatch_propped": true}
play_sfx = "res://assets/audio/sfx/impact/pl_impact_wood_04.ogg"

[sub_resource type="Resource" id="resp_hatch_default"]
script = ExtResource("3")
condition = ""
title = "Service Hatch"
text = "The service hatch in the kitchen floor. Still open from your fall. The hinges are stiff and the wood hangs at an angle — one good slam and it would close on its own. The stairs below are dark."

; === Interactables ===

[sub_resource type="Resource" id="inter_hatch"]
script = ExtResource("2")
id = "service_hatch_prop"
type = "switch"
position = Vector3(2.35, 0.2, 3.15)
collision_size = Vector3(1.5, 0.8, 1.5)
responses = Array[Resource]([SubResource("resp_hatch_propped"), SubResource("resp_hatch_stick"), SubResource("resp_hatch_default")])

[sub_resource type="Resource" id="inter_note"]
script = ExtResource("2")
id = "kitchen_note"
type = "note"
position = Vector3(-3.5, 1.5, 4)
wall = "north"
collision_size = Vector3(1.5, 1.5, 1.5)
responses = Array[Resource]([SubResource("resp_note_default")])
thread_responses = {"child": [SubResource("resp_note_captive")], "adult": [SubResource("resp_note_mourning")], "elder": [SubResource("resp_note_sovereign")], "captive": [SubResource("resp_note_captive")], "mourning": [SubResource("resp_note_mourning")], "sovereign": [SubResource("resp_note_sovereign")]}

[sub_resource type="Resource" id="inter_hearth"]
script = ExtResource("2")
id = "kitchen_hearth"
type = "observation"
position = Vector3(0, 0.5, -4.5)
wall = "south"
collision_size = Vector3(2.0, 1.5, 1.0)
responses = Array[Resource]([SubResource("resp_hearth_flagstone"), SubResource("resp_hearth_default")])

[sub_resource type="Resource" id="inter_bucket"]
script = ExtResource("2")
id = "kitchen_bucket"
type = "observation"
position = Vector3(3.0, 0.2, -3.0)
collision_size = Vector3(0.8, 0.8, 0.8)
visual_kind = "kitchen_bucket_still"
default_visual_state = "still"
state_visual_kind_map = {"rippled": "kitchen_bucket_rippled"}
visual_state_order = PackedStringArray("rippled")
visual_state_conditions = {"rippled": "examined_kitchen_bucket"}
responses = Array[Resource]([SubResource("resp_bucket_rippled"), SubResource("resp_bucket_default")])

