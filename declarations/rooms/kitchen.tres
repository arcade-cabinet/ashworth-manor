; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_kitchen": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Kitchen"

[sub_resource type="Resource" id="act_entry_text"]
script = ExtResource("7")
show_text = "Work stopped here without ending. Knives rest where hands dropped them, and the room feels less abandoned than interrupted by something no servant could keep pretending not to hear."

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_kitchen"
once = true
trigger_id = "kitchen_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name"), SubResource("act_entry_text")])

; === Entry Trigger: Service Return ===

[sub_resource type="Resource" id="act_return_state"]
script = ExtResource("7")
set_state = {"stable_house_light": true}

[sub_resource type="Resource" id="act_return_light_hearth"]
script = ExtResource("7")
light_change = {"kitchen_hearth_glow": {"energy": 0.6, "duration": 3.0}}

[sub_resource type="Resource" id="act_return_light_candle"]
script = ExtResource("7")
light_change = {"kitchen_candle_fill": {"energy": 0.8, "duration": 3.0}}
delay_seconds = 1.0

[sub_resource type="Resource" id="act_return_sfx"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/pl_ambient_machine_02.ogg"

[sub_resource type="Resource" id="act_return_text"]
script = ExtResource("7")
show_text = "You climb the service stairs into the kitchen. The air changes at the threshold — coal-dust gives way to cold stone and old grease. Above you, the pipes tick as gas flows for the first time in a century. The house is answering the boiler. Sconces you had not noticed glow faintly along the corridor beyond the doorway. The service world is behind you. The mansion is lit."

[sub_resource type="Resource" id="trig_service_return"]
script = ExtResource("6")
condition = "gas_restored AND NOT stable_house_light"
once = true
trigger_id = "kitchen_service_return"
actions = Array[Resource]([SubResource("act_return_state"), SubResource("act_return_light_hearth"), SubResource("act_return_light_candle"), SubResource("act_return_sfx"), SubResource("act_return_text")])

; === Ambient: Dripping ===

[sub_resource type="Resource" id="act_drip"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/water_drip.ogg"

[sub_resource type="Resource" id="ambient_drip"]
script = ExtResource("8")
event_id = "kitchen_drip"
interval_min = 10.0
interval_max = 25.0
condition = ""
actions = Array[Resource]([SubResource("act_drip")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "kitchen"
room_name = "Kitchen"
floor_name = "ground_floor"
environment_preset = "ground_floor"
dimensions = Vector3(8, 3.0, 10)
is_exterior = false
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "doorway:kitchen_to_foyer", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "window", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Without a Trace Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_ground.wav"
reverb_bus = "StoneCorridor"
footstep_surface = "stone"
spawn_position = Vector3(0.7, 0, 2.6)
spawn_rotation_y = 334.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_foyer")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_hearth")])
interactables = Array[Resource]([SubResource("inter_hatch"), SubResource("inter_note"), SubResource("inter_hearth"), SubResource("inter_bucket")])
lights = Array[Resource]([SubResource("light_hearth"), SubResource("light_window"), SubResource("light_candle_fill")])
props = Array[Resource]([SubResource("prop_table"), SubResource("prop_shelves"), SubResource("prop_candle_holder"), SubResource("prop_board"), SubResource("prop_rolling_pin"), SubResource("prop_dirty_plate"), SubResource("prop_bowl_table"), SubResource("prop_empty_glass"), SubResource("prop_fork"), SubResource("prop_butter_knife"), SubResource("prop_spoon"), SubResource("prop_knife_loose"), SubResource("prop_knife_loose_2"), SubResource("prop_knife_block"), SubResource("prop_soap"), SubResource("prop_pan"), SubResource("prop_clean_plate"), SubResource("prop_bowl_shelf"), SubResource("prop_pickles_jar"), SubResource("prop_jam_jar"), SubResource("prop_glass_water"), SubResource("prop_sickle")])
on_entry = Array[Resource]([SubResource("trig_first_entry"), SubResource("trig_service_return")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_drip")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
