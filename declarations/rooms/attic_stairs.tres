[sub_resource type="Resource" id="act_entered_attic"]
script = ExtResource("7")
set_state = {"visited_attic_stairs": true, "entered_attic": true, "elizabeth_aware": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Attic"

[sub_resource type="Resource" id="act_creak"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/floorboard_creak.ogg"
subtitle_text = "A long creak answers from above."

[sub_resource type="Resource" id="act_shake"]
script = ExtResource("7")
camera_shake = 0.08

[sub_resource type="Resource" id="act_whisper"]
script = ExtResource("7")
show_text = "A whisper slips down the stairwell after the creak, so close it feels spoken beside your ear. Not words. Recognition."

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT entered_attic"
once = true
trigger_id = "attic_first_entry"
actions = Array[Resource]([SubResource("act_entered_attic"), SubResource("act_show_name"), SubResource("act_creak"), SubResource("act_shake"), SubResource("act_whisper")])

[resource]
script = ExtResource("1")
room_id = "attic_stairs"
room_name = "Attic Stairwell"
floor_name = "attic"
environment_preset = "attic"
dimensions = Vector3(4, 4, 6)
is_exterior = false
spatial_class = "threshold_room"
exposure_faces = PackedStringArray("east")
outlook_zones = {"east": "attic_window_moon_view"}
window_view_mode = "local_outlook"
wall_north = PackedStringArray("wall", "doorway:attic_stairs_to_attic_storage")
wall_south = PackedStringArray("wall", "wall")
wall_east = PackedStringArray("wall", "window", "wall")
wall_west = PackedStringArray("wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Silent Voices Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_attic.wav"
reverb_bus = "SmallRoom"
footstep_surface = "rough_wood"
spawn_position = Vector3(1.0, 0, -1.55)
spawn_rotation_y = 148.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_attic_door")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_upper_rise")])
interactables = Array[Resource]([SubResource("inter_debris"), SubResource("inter_wall"), SubResource("inter_lantern_hook")])
lights = Array[Resource]([SubResource("light_window"), SubResource("light_candle"), SubResource("light_lamp_fill")])
props = Array[Resource]([SubResource("prop_gravel"), SubResource("prop_plank_a"), SubResource("prop_plank_b"), SubResource("prop_plank_c"), SubResource("prop_lamp"), SubResource("prop_bucket"), SubResource("prop_mask"), SubResource("prop_page"), SubResource("prop_candle"), SubResource("prop_hook_bracket")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
