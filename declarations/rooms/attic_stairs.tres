[gd_resource type="Resource" script_class="RoomDeclaration" format=3]

[ext_resource type="Script" path="res://engine/declarations/room_declaration.gd" id="1"]
[ext_resource type="Script" path="res://engine/declarations/interactable_decl.gd" id="2"]
[ext_resource type="Script" path="res://engine/declarations/response_decl.gd" id="3"]
[ext_resource type="Script" path="res://engine/declarations/light_decl.gd" id="4"]
[ext_resource type="Script" path="res://engine/declarations/prop_decl.gd" id="5"]
[ext_resource type="Script" path="res://engine/declarations/trigger_decl.gd" id="6"]
[ext_resource type="Script" path="res://engine/declarations/action_decl.gd" id="7"]
[ext_resource type="Script" path="res://engine/declarations/room_anchor_decl.gd" id="8"]

[sub_resource type="Resource" id="anchor_entry_attic_door"]
script = ExtResource("8")
anchor_id = "entry_attic_door"
anchor_type = "entry"
position = Vector3(0.85, 0, -1.3)
rotation_y = 154.0
target_anchor_id = "focus_upper_rise"
tags = PackedStringArray("default", "threshold")

[sub_resource type="Resource" id="anchor_focus_upper_rise"]
script = ExtResource("8")
anchor_id = "focus_upper_rise"
anchor_type = "focal"
position = Vector3(0.0, 2.9, 1.85)
rotation_y = 0.0
tags = PackedStringArray("attic", "vertical")

[sub_resource type="Resource" id="resp_debris_default"]
script = ExtResource("3")
condition = ""
title = "Debris"
text = "Gravel, plaster dust, and splintered wood collect in the stair corners. Your steps disturb the first clean surface in decades. Each print feels like a trespass the house has been waiting to register."

[sub_resource type="Resource" id="resp_wall_default"]
script = ExtResource("3")
condition = ""
title = "Cracked Plaster"
text = "The plaster has split wide enough to show lath beneath. The wood bears long scratches from the far side, four close lines repeated over and over. Not one outburst. Repetition. Persistence."

; === Lantern Hook Responses ===

[sub_resource type="Resource" id="resp_lantern_hook_taken"]
script = ExtResource("3")
condition = "lantern_hook_phase"
title = "Iron Hook"
text = "The bracket is empty. You took the hook and its handle. The stairwell feels darker without it."

[sub_resource type="Resource" id="resp_lantern_hook_no_darkness"]
script = ExtResource("3")
condition = "NOT late_darkness_active"
title = "Service Hook"
text = "An iron hook on a long ash handle, mounted to the wall bracket. For hanging service lanterns in high stairwells. The handle is worn smooth from the caretaker's grip. You have no reason to take it yet."

[sub_resource type="Resource" id="resp_lantern_hook_default"]
script = ExtResource("3")
condition = ""
title = "Service Hook"
text = "An iron hook on a long ash handle, mounted to the wall bracket. The house lights are dead. You need reach, not warmth. You take the hook from its bracket. The ash handle is steady in your hand -- steadier than the cane, longer than the brand. Built for pulling things down from where they were hidden."
set_state = {"lantern_hook_phase": true, "current_light_tool": "lantern_hook"}
gives_item = "lantern_hook"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="inter_debris"]
script = ExtResource("2")
id = "stairwell_debris"
type = "observation"
position = Vector3(0, 0.2, 0)
collision_size = Vector3(1.5, 0.6, 1.5)
responses = Array[Resource]([SubResource("resp_debris_default")])

[sub_resource type="Resource" id="inter_wall"]
script = ExtResource("2")
id = "stairwell_wall"
type = "observation"
position = Vector3(-1.5, 1.5, 2)
wall = "west"
collision_size = Vector3(1.0, 1.2, 0.5)
responses = Array[Resource]([SubResource("resp_wall_default")])

[sub_resource type="Resource" id="inter_lantern_hook"]
script = ExtResource("2")
id = "lantern_hook"
type = "switch"
position = Vector3(-1.2, 1.8, -0.6)
wall = "west"
collision_size = Vector3(0.8, 1.0, 0.5)
responses = Array[Resource]([SubResource("resp_lantern_hook_taken"), SubResource("resp_lantern_hook_no_darkness"), SubResource("resp_lantern_hook_default")])

