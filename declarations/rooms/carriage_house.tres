; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited"]
script = ExtResource("7")
set_state = {"visited_carriage_house": true}

[sub_resource type="Resource" id="act_show_name"]
script = ExtResource("7")
show_room_name = "Carriage House"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_carriage_house"
once = true
trigger_id = "carriage_house_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_show_name")])

; === Ambient: Creaking wood ===

[sub_resource type="Resource" id="act_creak"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/wood_creak.ogg"

[sub_resource type="Resource" id="ambient_creak"]
script = ExtResource("8")
event_id = "carriage_creak"
interval_min = 20.0
interval_max = 45.0
condition = ""
actions = Array[Resource]([SubResource("act_creak")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "carriage_house"
room_name = "Carriage House"
floor_name = "grounds"
environment_preset = "garden_mist"
dimensions = Vector3(8, 4, 6)
is_exterior = true
wall_north = PackedStringArray()
wall_south = PackedStringArray()
wall_east = PackedStringArray()
wall_west = PackedStringArray()
ambient_loop = "res://assets/audio/loops/Echoes at Dusk Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_exploration.wav"
reverb_bus = "WoodenHall"
footstep_surface = "rough_wood"
spawn_position = Vector3(0, 0, 0)
spawn_rotation_y = 0.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_secret_panel")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_groom_nook")])
interactables = Array[Resource]([SubResource("inter_portrait"), SubResource("inter_mattress"), SubResource("inter_tools")])
lights = Array[Resource]([SubResource("light_window"), SubResource("light_candle")])
props = Array[Resource]([SubResource("prop_shed_a"), SubResource("prop_shed_b"), SubResource("prop_shed_c"), SubResource("prop_shed_d"), SubResource("prop_mattress"), SubResource("prop_board_1"), SubResource("prop_board_2"), SubResource("prop_shovel"), SubResource("prop_luggage"), SubResource("prop_dead_lamp"), SubResource("prop_portrait_frame"), SubResource("prop_candle"), SubResource("prop_page"), SubResource("prop_chair")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([SubResource("ambient_creak")])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
