; === Portrait Responses (Diamond #3 A-path: cellar key behind frame) ===

[sub_resource type="Resource" id="resp_portrait_key"]
script = ExtResource("3")
condition = "read_wine_note"
title = "Carriage House Portrait"
text = "You lift the portrait from the wall. Behind the frame, taped to the backing, is a small iron key. The wine note was right -- 'the key is with the portrait.' Someone moved it here from the main house, away from prying eyes."
set_state = {"found_cellar_key_portrait": true}
gives_item = "cellar_key"
play_sfx = "res://assets/audio/sfx/inventory/key_find.ogg"

[sub_resource type="Resource" id="resp_portrait_default"]
script = ExtResource("3")
condition = ""
title = "Carriage House Portrait"
text = "A portrait leaning against the wall, face out. Victoria Ashworth, painted in her wedding dress. It is a duplicate -- the original hangs in the master bedroom. Why is a copy here, in the carriage house? The frame is heavier than it looks. Something is taped to the back."

; Portrait thread variants
[sub_resource type="Resource" id="resp_portrait_captive"]
script = ExtResource("3")
condition = ""
title = "Carriage House Portrait"
text = "Victoria Ashworth's portrait, exiled to the carriage house. Her expression in this copy is different from the original -- harder, more determined. As if the painter caught her on a day when she was deciding something. The frame has been moved recently. Dust outlines on the wall show it was turned around and then turned back."

[sub_resource type="Resource" id="resp_portrait_mourning"]
script = ExtResource("3")
condition = ""
title = "Carriage House Portrait"
text = "Victoria's portrait, stored here after she died. Edmund could not look at her face anymore. Not guilt -- grief. The portrait shows her young, before Elizabeth, before the binding, before the house became what it became. She looks happy. The paint has water damage. Rain through the carriage house roof. Even the paintings are weeping."

[sub_resource type="Resource" id="resp_portrait_sovereign"]
script = ExtResource("3")
condition = ""
title = "Carriage House Portrait"
text = "Victoria's portrait. The eyes follow you. Not the old 'Mona Lisa' trick of painted perspective. These eyes actually move. Slowly, deliberately, tracking you as you walk. Elizabeth is in everything. She can see through painted eyes. This portrait was not stored here. It was PLACED here, watching the entrance. A sentry."

; === Mattress / Sleeping Quarters ===

[sub_resource type="Resource" id="resp_mattress_default"]
script = ExtResource("3")
condition = ""
title = "Straw Mattress"
text = "A straw mattress on the floor with a threadbare blanket. The groom slept here. The blanket is pulled aside as if he left in a hurry and never came back. A small prayer card sits on a tin plate beside it. He knew something was wrong with the house."

; === Carriage Tools ===

[sub_resource type="Resource" id="resp_tools_default"]
script = ExtResource("3")
condition = ""
title = "Carriage Tools"
text = "Whips, harnesses, horseshoes. The tools of a working carriage house, untouched for years. A leather bag holds grooming brushes still caked with horsehair. The Ashworths dismissed the staff one by one. The groom was the last to go."

; === Interactables ===

[sub_resource type="Resource" id="inter_portrait"]
script = ExtResource("2")
id = "carriage_portrait"
type = "painting"
position = Vector3(0, 1.5, 2.5)
wall = "north"
collision_size = Vector3(1.5, 2.0, 1.0)
substrate_prop_kind = "picture_frame_blank_006"
responses = Array[Resource]([SubResource("resp_portrait_key"), SubResource("resp_portrait_default")])
thread_responses = {"captive": [SubResource("resp_portrait_key"), SubResource("resp_portrait_captive")], "mourning": [SubResource("resp_portrait_key"), SubResource("resp_portrait_mourning")], "sovereign": [SubResource("resp_portrait_key"), SubResource("resp_portrait_sovereign")]}

