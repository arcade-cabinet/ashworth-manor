[sub_resource type="Resource" id="act_entry_text"]
script = ExtResource("7")
show_text = "The weight of the house presses down. Stone, earth, old bottles, old lies. You are far enough below the manor now that daylight feels theoretical."

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_wine_cellar"
once = true
trigger_id = "wine_cellar_first_entry"
actions = Array[Resource]([SubResource("act_visited"), SubResource("act_reached_deepest"), SubResource("act_show_name"), SubResource("act_entry_sfx"), SubResource("act_entry_text")])

; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "wine_cellar"
room_name = "Wine Cellar"
floor_name = "deep_basement"
environment_preset = "deep_basement"
dimensions = Vector3(8, 3, 10)
is_exterior = false
wall_north = PackedStringArray("wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Empty Hope Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_deep.wav"
reverb_bus = "Dungeon"
footstep_surface = "stone"
spawn_position = Vector3(0, 0, 0)
spawn_rotation_y = 0.0
interactables = Array[Resource]([SubResource("inter_box"), SubResource("inter_note"), SubResource("inter_racks"), SubResource("inter_footprints"), SubResource("inter_barrel_passage")])
lights = Array[Resource]([SubResource("light_candle"), SubResource("light_box_candle")])
props = Array[Resource]([SubResource("prop_rack_left"), SubResource("prop_rack_right"), SubResource("prop_bottles_left"), SubResource("prop_bottles_right"), SubResource("prop_box"), SubResource("prop_barrel_1"), SubResource("prop_barrel_2"), SubResource("prop_lamp"), SubResource("prop_bricks_l"), SubResource("prop_bricks_r"), SubResource("prop_plank"), SubResource("prop_loose_bottle"), SubResource("prop_box_candle"), SubResource("prop_bottle_cluster_a"), SubResource("prop_bottle_cluster_b")])
on_entry = Array[Resource]([SubResource("trig_first_entry")])
on_exit = Array[Resource]([])
ambient_events = Array[Resource]([])
conditional_events = Array[Resource]([])
flashbacks = Array[Resource]([])
