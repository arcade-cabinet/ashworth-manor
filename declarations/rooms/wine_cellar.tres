[gd_resource type="Resource" script_class="RoomDeclaration" format=3]

[ext_resource type="Script" path="res://engine/declarations/room_declaration.gd" id="1"]
[ext_resource type="Script" path="res://engine/declarations/interactable_decl.gd" id="2"]
[ext_resource type="Script" path="res://engine/declarations/response_decl.gd" id="3"]
[ext_resource type="Script" path="res://engine/declarations/light_decl.gd" id="4"]
[ext_resource type="Script" path="res://engine/declarations/prop_decl.gd" id="5"]
[ext_resource type="Script" path="res://engine/declarations/trigger_decl.gd" id="6"]
[ext_resource type="Script" path="res://engine/declarations/action_decl.gd" id="7"]

; === Wine Box Responses (Diamond #3 A-path) ===

[sub_resource type="Resource" id="resp_box_key"]
script = ExtResource("3")
condition = "HAS cellar_key"
title = "Wine Box"
text = "The key turns in the small brass lock. Inside the wine box, wrapped in velvet: Lady Ashworth's confession. A letter in her hand, sealed with wax. She hid the truth with the wine because wine keeps secrets."
set_state = {"opened_wine_box": true}
gives_item = "mothers_confession"
play_sfx = "res://assets/audio/sfx/inventory/chest_open.ogg"

[sub_resource type="Resource" id="resp_box_default"]
script = ExtResource("3")
condition = ""
title = "Wine Box"
text = "A wooden wine box on the lowest shelf. Unlike the bottles, it has a brass lock. Someone put something valuable inside and wanted it to stay hidden among the vintages. The lock is small but sturdy."

; Wine box thread variants (what the confession says)
[sub_resource type="Resource" id="resp_box_captive"]
script = ExtResource("3")
condition = ""
title = "Wine Box"
text = "A locked wine box on the lowest shelf. The brass lock is cold. Someone scratched initials into the wood: V.A. Victoria Ashworth. She hid something here -- far from her husband, far from the attic, in the deepest part of the house. Whatever is inside, she did not want Edmund to find it."

[sub_resource type="Resource" id="resp_box_mourning"]
script = ExtResource("3")
condition = ""
title = "Wine Box"
text = "A locked wine box on the lowest shelf. The wood is stained with something that is not wine -- watermarks, round, the size of teardrops. Victoria came here to cry where no one could hear her. She hid something in the box and wept over it. The truth she could not speak aloud, preserved in wood and brass."

[sub_resource type="Resource" id="resp_box_sovereign"]
script = ExtResource("3")
condition = ""
title = "Wine Box"
text = "A locked wine box on the lowest shelf. The brass has been polished by repetition, not affection. Dust lies everywhere else, but here the shelf is ringed with old wipe marks and the wood is worn where the same careful hand opened and closed the box across too many winters. This cellar did not keep vintages. It kept routine for a truth that had grown old in the dark."

; === Wine Note ===

[sub_resource type="Resource" id="resp_note_default"]
script = ExtResource("3")
condition = ""
title = "Wine Note"
text = "A note tucked between bottles: 'The 1889 is for the Christmas dinner. The box on the bottom shelf is NOT wine -- do not open. V.A.' Victoria left instructions. She wanted someone to find this. Eventually."
set_state = {"read_wine_note": true}

[sub_resource type="Resource" id="resp_racks_default"]
script = ExtResource("3")
condition = ""
title = "Wine Racks"
text = "Rows of bottles sleeping in dust. Most have not been touched in decades, but several slots sit empty and clean. Whatever was taken from these racks was removed long after the house died."

[sub_resource type="Resource" id="resp_footprints_default"]
script = ExtResource("3")
condition = ""
title = "Footprints"
text = "Dusty prints lead in from the basement stairs and stop at the stone wall. No return prints. No second trail. Whoever came this way did not leave by any route you can see."

[sub_resource type="Resource" id="resp_footprints_sovereign"]
script = ExtResource("3")
condition = ""
title = "Footprints"
text = "The prints are not one visit. They overlap in the same narrow path, heel inside heel, until the dust records routine instead of trespass. Someone came down here again and again, always to the same wall, as if the cellar were part of a burial duty the rest of the house was made to forget."

[sub_resource type="Resource" id="resp_barrel_passage_early"]
script = ExtResource("3")
condition = "NOT elder_attic_redirected"
title = "Barrel Stack"
text = "The barrels are wedged too tightly against the rear wall for storage alone, but whatever is wrong with the arrangement refuses to declare itself. The cellar keeps its own counsel."

[sub_resource type="Resource" id="resp_barrel_passage_no_hook"]
script = ExtResource("3")
condition = "elder_attic_redirected AND NOT HAS lantern_hook"
title = "Barrel Stack"
text = "Now that the attic has sent you back down, the disguise is obvious: one barrel sits on hidden rollers and the iron ring is worn bright. A draught reaches through the mortar behind it. You need reach enough to catch the ring and pull the stack aside."

[sub_resource type="Resource" id="resp_barrel_passage_default"]
script = ExtResource("3")
condition = ""
title = "Barrel Stack"
text = "The lantern hook catches the bright iron ring. The barrel groans backward on hidden rollers, opening a seam in the stone wide enough for a person to slip through sideways. Cold air moves out of the dark beyond, carrying the smell of wet mortar and old memorial flowers."
set_state = {"elder_cellar_bypass_opened": true}

; === Interactables ===

[sub_resource type="Resource" id="inter_box"]
script = ExtResource("2")
id = "wine_box"
type = "box"
position = Vector3(-3.5, 0.3, 0)
collision_size = Vector3(1.5, 1.0, 1.0)
locked = true
key_id = "cellar_key"
locked_response_no_key = "The wine box is locked with a small brass lock. You need a key."
locked_response_wrong_key = "This key does not fit the wine box lock."
responses = Array[Resource]([SubResource("resp_box_key"), SubResource("resp_box_default")])
thread_responses = {"child": [SubResource("resp_box_key"), SubResource("resp_box_captive")], "adult": [SubResource("resp_box_key"), SubResource("resp_box_mourning")], "elder": [SubResource("resp_box_key"), SubResource("resp_box_sovereign")], "captive": [SubResource("resp_box_key"), SubResource("resp_box_captive")], "mourning": [SubResource("resp_box_key"), SubResource("resp_box_mourning")], "sovereign": [SubResource("resp_box_key"), SubResource("resp_box_sovereign")]}

[sub_resource type="Resource" id="inter_note"]
script = ExtResource("2")
id = "wine_note"
type = "note"
position = Vector3(-3.5, 1.2, 2)
collision_size = Vector3(1.0, 0.5, 0.5)
responses = Array[Resource]([SubResource("resp_note_default")])

[sub_resource type="Resource" id="inter_racks"]
script = ExtResource("2")
id = "wine_racks"
type = "observation"
position = Vector3(-3.3, 1.0, 0.0)
collision_size = Vector3(1.5, 2.0, 2.0)
responses = Array[Resource]([SubResource("resp_racks_default")])

[sub_resource type="Resource" id="inter_footprints"]
script = ExtResource("2")
id = "wine_footprints"
type = "observation"
position = Vector3(0.0, 0.1, 3.0)
collision_size = Vector3(2.0, 0.5, 1.5)
responses = Array[Resource]([SubResource("resp_footprints_default")])
thread_responses = {"elder": [SubResource("resp_footprints_sovereign")], "sovereign": [SubResource("resp_footprints_sovereign")]}

[sub_resource type="Resource" id="inter_barrel_passage"]
script = ExtResource("2")
id = "cellar_barrel_passage"
type = "observation"
position = Vector3(2.65, 0.9, -2.35)
collision_size = Vector3(1.6, 1.4, 1.2)
thread_active = PackedStringArray("elder", "sovereign")
responses = Array[Resource]([SubResource("resp_barrel_passage_early"), SubResource("resp_barrel_passage_no_hook"), SubResource("resp_barrel_passage_default")])

; === Lights ===

[sub_resource type="Resource" id="light_candle"]
