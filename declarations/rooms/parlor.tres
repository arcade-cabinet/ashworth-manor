[sub_resource type="Resource" id="act_music_auto_sfx"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/music_box/music_box_melody.ogg"

[sub_resource type="Resource" id="act_music_auto_dim"]
script = ExtResource("7")
light_change = {"parlor_fireplace_light": {"energy": 0.5, "duration": 3.0}}

[sub_resource type="Resource" id="act_music_auto_restore"]
script = ExtResource("7")
delay_seconds = 5.0
light_change = {"parlor_fireplace_light": {"energy": 1.5, "duration": 3.0}}

[sub_resource type="Resource" id="act_music_auto_shake"]
script = ExtResource("7")
camera_shake = 0.05

[sub_resource type="Resource" id="cond_music_box"]
script = ExtResource("9")
event_id = "music_box_auto_play"
condition = "parlor_fire_lit AND elizabeth_aware AND visited_attic_storage AND NOT music_box_auto_triggered"
once = true
actions = Array[Resource]([SubResource("act_music_auto_flag"), SubResource("act_music_auto_sfx"), SubResource("act_music_auto_dim"), SubResource("act_music_auto_restore"), SubResource("act_music_auto_shake")])

