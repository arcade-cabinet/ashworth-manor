; === Entry Trigger ===

[sub_resource type="Resource" id="act_visited_parlor"]
script = ExtResource("7")
set_state = {"visited_parlor": true}

[sub_resource type="Resource" id="act_show_parlor"]
script = ExtResource("7")
show_room_name = "Parlor"

[sub_resource type="Resource" id="act_fire_crackle"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/fire_crackle_low.ogg"

[sub_resource type="Resource" id="trig_first_entry"]
script = ExtResource("6")
condition = "NOT visited_parlor"
once = true
trigger_id = "parlor_first_entry"
actions = Array[Resource]([SubResource("act_visited_parlor"), SubResource("act_show_parlor")])

; === Ambient Events ===

[sub_resource type="Resource" id="act_fire_settle"]
script = ExtResource("7")
play_sfx = "res://assets/audio/sfx/ambient/fire_settle.ogg"

[sub_resource type="Resource" id="ambient_fire"]
script = ExtResource("8")
event_id = "fire_settle"
interval_min = 20.0
interval_max = 45.0
condition = "parlor_fire_lit"
actions = Array[Resource]([SubResource("act_fire_settle")])

; === Conditional: Music Box Auto-Play ===

[sub_resource type="Resource" id="act_music_auto_flag"]
script = ExtResource("7")
