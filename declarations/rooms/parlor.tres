; === Main Resource ===

[resource]
script = ExtResource("1")
room_id = "parlor"
room_name = "Parlor"
floor_name = "ground_floor"
environment_preset = "ground_floor"
dimensions = Vector3(10, 2.4, 10)
is_exterior = false
wall_north = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_south = PackedStringArray("wall", "wall", "doorway:parlor_to_foyer", "wall", "wall")
wall_east = PackedStringArray("wall", "wall", "wall", "wall", "wall")
wall_west = PackedStringArray("wall", "wall", "wall", "wall", "wall")
ambient_loop = "res://assets/audio/loops/Comfort Loop1.ogg"
tension_loop = "res://assets/audio/tension/tension_ground.wav"
reverb_bus = "Room"
footstep_surface = "wood_parquet"
spawn_position = Vector3(0, 0, -4)
spawn_rotation_y = 0.0
entry_anchors = Array[Resource]([SubResource("anchor_entry_foyer")])
focal_anchors = Array[Resource]([SubResource("anchor_focus_fireplace")])
interactables = Array[Resource]([SubResource("inter_portrait"), SubResource("inter_diary"), SubResource("inter_music_box"), SubResource("inter_fireplace"), SubResource("inter_tea")])
lights = Array[Resource]([SubResource("light_fireplace"), SubResource("light_candle_l"), SubResource("light_candle_r")])
props = Array[Resource]([SubResource("prop_fireplace"), SubResource("prop_settee_left"), SubResource("prop_settee_right"), SubResource("prop_rug"), SubResource("prop_portrait_frame"), SubResource("prop_side_table_left"), SubResource("prop_side_table_right"), SubResource("prop_writing_desk"), SubResource("prop_candle_holder_l"), SubResource("prop_candle_holder_r"), SubResource("prop_stool"), SubResource("prop_dead_lamp")])
