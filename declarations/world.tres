; === Game Phases ===

[sub_resource type="Resource" id="phase_exploration"]
script = ExtResource("4")
phase_id = "exploration"
phase_name = "Exploration"
description = "Player explores the manor, finding clues. Elizabeth is dormant."
tension_volume = 0.0
flicker_intensity = 1.0

[sub_resource type="Resource" id="phase_discovery"]
script = ExtResource("4")
phase_id = "discovery"
phase_name = "Discovery"
description = "Player has found enough clues. Elizabeth begins watching. Tension layer activates."
tension_volume = 0.3
flicker_intensity = 1.2

[sub_resource type="Resource" id="phase_horror"]
script = ExtResource("4")
phase_id = "horror"
phase_name = "Horror"
description = "Player enters attic area. Elizabeth is active. Full horror atmosphere."
tension_volume = 0.7
flicker_intensity = 1.8

[sub_resource type="Resource" id="phase_resolution"]
script = ExtResource("4")
phase_id = "resolution"
phase_name = "Resolution"
description = "Player has the full truth. Final choices ahead. Eerie calm."
tension_volume = 0.5
flicker_intensity = 1.0

; === Phase Transitions ===

[sub_resource type="Resource" id="pt_explore_to_discovery"]
script = ExtResource("5")
from_phase = "exploration"
to_phase = "discovery"
trigger_condition = "discovery_count >= 3"

[sub_resource type="Resource" id="pt_discovery_to_horror"]
script = ExtResource("5")
from_phase = "discovery"
to_phase = "horror"
trigger_condition = "VISITED attic_storage"

[sub_resource type="Resource" id="pt_horror_to_resolution"]
script = ExtResource("5")
from_phase = "horror"
to_phase = "resolution"
trigger_condition = "knows_full_truth"

[sub_resource type="Resource" id="pt_resolution_to_exploration"]
script = ExtResource("5")
from_phase = "resolution"
to_phase = "exploration"
trigger_condition = ""

; === Elizabeth Presence States ===

[sub_resource type="Resource" id="eliz_dormant"]
script = ExtResource("6")
state_id = "dormant"
shadow_frequency = 0.0
flicker_multiplier = 1.0
whisper_sfx_interval = 0.0
whisper_sfx = ""
mirror_delay = 0.0
affected_types = PackedStringArray()

[sub_resource type="Resource" id="eliz_watching"]
script = ExtResource("6")
state_id = "watching"
shadow_frequency = 45.0
flicker_multiplier = 1.3
whisper_sfx_interval = 60.0
whisper_sfx = "res://assets/audio/sfx/horror/whisper_wind.ogg"
mirror_delay = 0.0
affected_types = PackedStringArray("mirror")

[sub_resource type="Resource" id="eliz_active"]
script = ExtResource("6")
state_id = "active"
shadow_frequency = 20.0
flicker_multiplier = 1.8
whisper_sfx_interval = 30.0
whisper_sfx = "res://assets/audio/sfx/horror/whisper_close.ogg"
mirror_delay = 0.3
affected_types = PackedStringArray("mirror", "music_box", "painting")

[sub_resource type="Resource" id="eliz_confrontation"]
script = ExtResource("6")
state_id = "confrontation"
shadow_frequency = 10.0
flicker_multiplier = 2.5
whisper_sfx_interval = 15.0
whisper_sfx = "res://assets/audio/sfx/horror/whisper_urgent.ogg"
mirror_delay = 0.5
affected_types = PackedStringArray("mirror", "music_box", "painting", "note", "photo")

; === Elizabeth Transitions ===

[sub_resource type="Resource" id="et_dormant_to_watching"]
script = ExtResource("7")
from_state = "dormant"
to_state = "watching"
trigger_condition = "discovery_count >= 3"

[sub_resource type="Resource" id="et_watching_to_active"]
script = ExtResource("7")
from_state = "watching"
to_state = "active"
trigger_condition = "elizabeth_aware"

[sub_resource type="Resource" id="et_active_to_confrontation"]
script = ExtResource("7")
from_state = "active"
to_state = "confrontation"
trigger_condition = "knows_full_truth"

; === Player Config ===

[sub_resource type="Resource" id="player_config"]
script = ExtResource("8")
camera_fov = 70.0
camera_height = 1.7
pitch_limit = 45.0
move_speed = 3.0
stop_distance = 0.3
touch_sensitivity = 0.003
tap_threshold = 15.0
tap_time_threshold = 0.3

; === Accessibility ===

[sub_resource type="Resource" id="accessibility_config"]
script = ExtResource("9")
base_font_size = 16
font_scale = 1.0
camera_shake_enabled = true
camera_shake_scale = 1.0
subtitle_mode = true
high_contrast_mode = false

; === Main Resource ===

[resource]
script = ExtResource("1")
starting_room = "front_gate"
starting_position = Vector3(0, 0, -8)
starting_rotation_y = 180.0
rooms = Array[Resource]([SubResource("room_front_gate"), SubResource("room_foyer"), SubResource("room_parlor"), SubResource("room_dining_room"), SubResource("room_kitchen"), SubResource("room_upper_hallway"), SubResource("room_master_bedroom"), SubResource("room_library"), SubResource("room_guest_room"), SubResource("room_storage_basement"), SubResource("room_boiler_room"), SubResource("room_wine_cellar"), SubResource("room_attic_stairs"), SubResource("room_attic_storage"), SubResource("room_hidden_chamber"), SubResource("room_garden"), SubResource("room_chapel"), SubResource("room_greenhouse"), SubResource("room_carriage_house"), SubResource("room_family_crypt")])
connections = Array[Resource]([SubResource("conn_front_gate_to_foyer"), SubResource("conn_foyer_to_front_gate"), SubResource("conn_front_gate_to_garden"), SubResource("conn_garden_to_front_gate"), SubResource("conn_front_gate_to_carriage_house"), SubResource("conn_carriage_house_to_front_gate"), SubResource("conn_foyer_to_parlor"), SubResource("conn_parlor_to_foyer"), SubResource("conn_foyer_to_dining_room"), SubResource("conn_dining_room_to_foyer"), SubResource("conn_foyer_to_kitchen"), SubResource("conn_kitchen_to_foyer"), SubResource("conn_foyer_to_upper_hallway"), SubResource("conn_upper_hallway_to_foyer"), SubResource("conn_upper_hallway_to_master_bedroom"), SubResource("conn_master_bedroom_to_upper_hallway"), SubResource("conn_upper_hallway_to_library"), SubResource("conn_library_to_upper_hallway"), SubResource("conn_upper_hallway_to_guest_room"), SubResource("conn_guest_room_to_upper_hallway"), SubResource("conn_upper_hallway_to_attic_stairs"), SubResource("conn_attic_stairs_to_upper_hallway"), SubResource("conn_attic_stairs_to_attic_storage"), SubResource("conn_attic_storage_to_attic_stairs"), SubResource("conn_attic_storage_to_hidden_chamber"), SubResource("conn_hidden_chamber_to_attic_storage"), SubResource("conn_kitchen_to_storage_basement"), SubResource("conn_storage_basement_to_kitchen"), SubResource("conn_storage_basement_to_boiler_room"), SubResource("conn_boiler_room_to_storage_basement"), SubResource("conn_storage_basement_to_wine_cellar"), SubResource("conn_wine_cellar_to_storage_basement"), SubResource("conn_garden_to_chapel"), SubResource("conn_chapel_to_garden"), SubResource("conn_garden_to_greenhouse"), SubResource("conn_greenhouse_to_garden"), SubResource("conn_garden_to_family_crypt"), SubResource("conn_family_crypt_to_garden")])
area_environments = {}
macro_threads = Array[Resource]([])
junctions = Array[Resource]([])
prng_seed = 0
