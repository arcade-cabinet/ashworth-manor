; === Game Phases ===

[sub_resource type="Resource" id="phase_exploration"]
script = ExtResource("4")
phase_id = "exploration"
phase_name = "Exploration"
description = "Player explores the manor, finding clues. Elizabeth is dormant."
tension_volume = 0.0
flicker_intensity = 1.0

[sub_resource type="Resource" id="phase_discovery"]
script = ExtResource("4")
phase_id = "discovery"
phase_name = "Discovery"
description = "Player has found enough clues. Elizabeth begins watching. Tension layer activates."
tension_volume = 0.3
flicker_intensity = 1.2

[sub_resource type="Resource" id="phase_horror"]
script = ExtResource("4")
phase_id = "horror"
phase_name = "Horror"
description = "Player enters attic area. Elizabeth is active. Full horror atmosphere."
tension_volume = 0.7
flicker_intensity = 1.8

[sub_resource type="Resource" id="phase_resolution"]
script = ExtResource("4")
phase_id = "resolution"
phase_name = "Resolution"
description = "Player has the full truth. Final choices ahead. Eerie calm."
tension_volume = 0.5
flicker_intensity = 1.0

; === Phase Transitions ===

[sub_resource type="Resource" id="pt_explore_to_discovery"]
script = ExtResource("5")
from_phase = "exploration"
to_phase = "discovery"
trigger_condition = "discovery_count >= 3"

[sub_resource type="Resource" id="pt_discovery_to_horror"]
script = ExtResource("5")
from_phase = "discovery"
to_phase = "horror"
trigger_condition = "VISITED attic_storage"

[sub_resource type="Resource" id="pt_horror_to_resolution"]
script = ExtResource("5")
from_phase = "horror"
to_phase = "resolution"
trigger_condition = "knows_full_truth"

[sub_resource type="Resource" id="pt_resolution_to_exploration"]
script = ExtResource("5")
from_phase = "resolution"
to_phase = "exploration"
trigger_condition = ""

