[resource]
script = ExtResource("1")
ending_id = "freedom"
trigger_condition = "counter_ritual_complete AND macro_thread == captive"
trigger_room = "hidden_chamber"
text_sequence = PackedStringArray("The binding circle cracks. Light pours through the floor.", "Elizabeth stands before you -- not a ghost, not a wraith. A girl.", "She looks at you with eyes that finally see daylight.", "The house exhales. A century of held breath released.", "'Thank you,' she whispers. And she is gone.")
