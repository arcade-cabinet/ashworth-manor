[gd_resource type="Resource" script_class="EndingDecl" format=3]

[ext_resource type="Script" path="res://engine/declarations/ending_decl.gd" id="1"]

[resource]
script = ExtResource("1")
ending_id = "forgiveness"
trigger_condition = "counter_ritual_complete AND macro_thread == mourning"
trigger_room = "hidden_chamber"
text_sequence = PackedStringArray("The candles gutter and die. In the darkness, a warmth.", "Elizabeth kneels beside the ritual circle. She is weeping.", "Not from pain. From relief. Someone finally understood.", "The drawings on the walls fade. The house lets go of its grief.", "'I forgive them,' she says. 'I forgive myself.'")
timing = [3.0, 4.0, 3.0, 4.0, 5.0]
stinger_sfx = "res://assets/audio/sfx/stinger/pl_horror_stinger_10_final.wav"
