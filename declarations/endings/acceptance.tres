text_sequence = PackedStringArray("The ritual circle doesn't break. It transforms.", "Elizabeth rises. She is not freed. She is acknowledged.", "The house settles around her -- not a prison, but a home.", "She chose this. You understand now. This was always her house.", "'Now you know,' she says. And the house is at peace.")
