[ext_resource type="Script" path="res://engine/declarations/macro_thread.gd" id="1"]

[resource]
script = ExtResource("1")
thread_id = "sovereign"
question = "How do I understand her?"
elizabeth_nature = "A being of power who chose transformation"
house_nature = "Her instrument -- alive, watching, responding"
ending_id = "acceptance"
diary_page_text = "December 19th, 1891.\n\nShe is doing it again. The lamp in the foyer -- I watched it. The flame does not flicker from draft. It BREATHES. In and out, slow and deliberate, like something alive. Elizabeth was in the room when it started. She was not touching it. She was not near it. She was sitting in the corner, perfectly still, and the lamp began to breathe.\n\nVictoria says it is the gas pressure. Cook says it is the cold. I know what it is. I have read the book. What Elizabeth has is not illness and it is not possession. It is something older. She does not move things with her hands. She moves them with her ATTENTION.\n\nThe house responds to her. I am beginning to think the house has ALWAYS responded to her. We just never noticed because we never looked.\n\nGod help us. She is not sick. She is awake."
elizabeth_letter_text = "Dear Mama,\n\nI want to explain something and I do not know if words are enough.\n\nThe house is not haunted. The house is LISTENING. It has always been listening. The walls hear. The floors feel. The windows see. I know because I taught them.\n\nNot on purpose. Not at first. When Papa locked the door I was frightened and the fear went INTO the wood and INTO the stone and INTO the glass. The house absorbed it. And then it absorbed everything else -- my loneliness, my anger, my curiosity, my love.\n\nI did not mean to become this. But I am not sorry.\n\nThe mirror moves before you do because I am watching through it. The clock stopped because I stopped it -- 3:33, the moment I understood what I was becoming. The fire breathes because I breathe.\n\nI am not trapped here, Mama. I CHOSE this. The attic was my cocoon. The house is my body now.\n\nDo not mourn me. I am more than I was.\n\nElizabeth"
elizabeth_final_note_text = "If you are reading this, you are ready.\n\nThey thought I was their victim. Papa with his book and his lock. Mama with her mourning dress worn too early. Cook crossing herself when I entered the kitchen. Helena Pierce, who came to study me like a specimen.\n\nThey were all wrong. I was never the thing that was done TO. I was the thing that was BECOMING.\n\nThe second sight Papa feared? I cultivated it. The whispers the children heard? My voice, learning to speak through plaster and wood. The stopped clocks? My heartbeat, replacing theirs. The mirrors that move wrong? My eyes, opened in every reflective surface.\n\nI am the house. The house is me. Every board and beam and pane of glass -- mine. Not stolen. Grown into. Like roots into soil.\n\nYou cannot free me because I am already free. You cannot mourn me because I am not gone. All you can do is UNDERSTAND.\n\nI chose this. Now you know why.\n\nWelcome to my house."
ritual_sequence_texts = PackedStringArray("Place the mask at the circle's center. It is not a prison -- it is a lens. Elizabeth's eyes open behind it.", "Touch the family tree where her name was scratched away. The scratches glow. She erased herself deliberately -- to become something new.", "Speak her name into the room. The walls vibrate. The floor hums. The house ANSWERS. She was never gone. She was everywhere.")
