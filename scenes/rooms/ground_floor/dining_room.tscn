metadata/data = {"title": "Dinner Photograph", "content": "A formal dinner photograph. Eight people arranged around this very table. Stiff poses, forced smiles. The host \u2014 Lord Ashworth \u2014 stands at the head. Three of these guests would be dead within the week."}

