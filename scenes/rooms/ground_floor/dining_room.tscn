metadata/data = {"title": "Pushed Chair", "content": "One chair pushed back from the table at a sharp angle. The plate in front of it is untouched. The wine glass is overturned \u2014 a dark stain has soaked into the wood. Someone left this seat in a hurry. Or was pulled from it."}

