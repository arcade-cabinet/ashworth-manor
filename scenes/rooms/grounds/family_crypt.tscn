collision_layer = 4
collision_mask = 0
metadata/id = "crypt_note"
metadata/type = "note"
metadata/data = {"title": "Crypt Inscription", "content": "Carved above the unmarked sarcophagus: 'Here lies no one. She was never here. She was never anywhere.' The family's final lie."}

[node name="CollisionShape" type="CollisionShape3D" parent="Interactables/crypt_note"]
