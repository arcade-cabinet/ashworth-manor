collision_mask = 0
metadata/id = "crypt_graves"
metadata/type = "observation"
metadata/data = {"title": "Family Graves", "content": "Stone sarcophagi. Lord Edmund Ashworth, d. 1892. Lady Victoria Ashworth, d. 1892. Helena Pierce — no dates. And one small sarcophagus, unmarked. Elizabeth's. Empty."}

[node name="CollisionShape" type="CollisionShape3D" parent="Interactables/crypt_graves"]
shape = SubResource("BoxShape3D_i01")

[node name="crypt_note" type="Area3D" parent="Interactables"]
