collision_layer = 4
collision_mask = 0
metadata/id = "boiler_pipes"
metadata/type = "observation"
metadata/data = {"title": "Ceiling Pipes", "content": "A labyrinth of pipes runs across the ceiling. They shouldn't carry anything — the boiler is dead. But one pipe vibrates. Faintly. As if something moves through it."}

