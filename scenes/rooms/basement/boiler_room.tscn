metadata/type = "clock"
metadata/data = {"title": "Boiler Room Clock", "content": "Another clock frozen at 3:33. This one is mounted above the boiler. The glass is cracked from heat but the hands are locked in place. Whatever stopped time, it reached even here.", "on_read_flags": "examined_boiler_clock"}

