metadata/id = "boiler_observation"
metadata/type = "observation"
metadata/data = {"title": "The Boiler", "content": "Cast iron, riveted, enormous. The furnace door hangs open. Inside: cold ash. But the metal is warm. Not hot — warm. Body temperature."}

[node name="CollisionShape" type="CollisionShape3D" parent="Interactables/boiler_observation"]
