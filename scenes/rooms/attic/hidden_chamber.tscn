collision_layer = 4
collision_mask = 0
metadata/id = "chamber_drawings"
metadata/type = "observation"
metadata/data = {"title": "Wall Drawings", "content": "The walls are covered in drawings. Charcoal on plaster. A house. A family. A girl alone. A circle. The same images, repeated hundreds of times. A child trying to understand what was done to her."}

[node name="CollisionShape" type="CollisionShape3D" parent="Interactables/chamber_drawings"]
