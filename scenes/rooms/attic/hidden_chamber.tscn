[node name="hidden_mirror" type="Area3D" parent="Interactables"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 2.5, 1.5, 0)
collision_layer = 4
collision_mask = 0
metadata/id = "hidden_mirror"
metadata/type = "mirror"
metadata/data = {"title": "Chamber Mirror", "content": "A mirror, cracked but whole. In it: a girl in white. Not behind you — she's in the mirror. She raises one hand. Slowly. She presses her palm against the glass. From the other side."}

[node name="CollisionShape" type="CollisionShape3D" parent="Interactables/hidden_mirror"]
