metadata/data = {"title": "Elizabeth's Final Words", "content": "'They bound me here with blood and salt and words I didn't understand. Father said it was for my own good. Mother held me down. Helena drew the circle. I forgive them. But I cannot leave.'", "on_read_flags": "read_final_note,knows_full_truth"}

